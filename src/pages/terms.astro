<style>
  .page-legal {
    max-width: 800px;
    margin: 0 auto;
    padding: calc(var(--nav-height, 80px) + 3rem) 2rem 5rem;
    color: var(--text-body);
    line-height: 1.8;
  }
  .page-legal h1 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
    color: var(--text-heading);
  }
  .page-legal-date {
    color: var(--text-muted);
    margin-bottom: 3rem;
  }
  .page-legal h2 {
    font-size: 1.2rem;
    font-weight: 700;
    margin: 2rem 0 0.5rem;
    color: var(--text-heading);
  }
  .page-legal a {
    color: var(--brand-primary);
  }
  .page-legal a:hover {
    text-decoration: underline;
  }
</style>
