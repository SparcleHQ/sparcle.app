---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Documentation | Sparcle"
  description="Bolt and Aeira documentation. Coming soon."
  canonical="https://sparcle.app/docs"
>
  <main class="page-security">
    <section class="sec-hero">
      <div class="container">
        <p class="section-eyebrow">Documentation</p>
        <h1>Coming soon.</h1>
        <p class="sec-lede">
          Public documentation is in preparation. In the meantime, the
          <a href="/architecture">architecture overview</a> and the
          <a href="/security">security &amp; compliance page</a> cover the most-asked questions.
        </p>
        <div class="sec-ctas">
          <a href="/architecture" class="btn btn-primary btn-lg">
            Architecture &rarr;
          </a>
          <a href="/security" class="btn btn-secondary btn-lg">
            Security &amp; compliance &rarr;
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
