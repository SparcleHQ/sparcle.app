---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/marketing/SectionHeader.astro";
import ProofCard from "../components/marketing/ProofCard.astro";
import BlockQuote from "../components/marketing/BlockQuote.astro";
---

<BaseLayout
  title="Why Sparcle | Mission, Proof & Enterprise Metrics"
  description="Sparcle exists to help organizations reclaim the time and money lost to workplace fragmentation. See our mission, proof metrics, and the research behind our platform."
  canonical="https://sparcle.app/why-sparcle"
>
  <!-- ========================================
       WHY SPARCLE
       ======================================== -->
  <section id="why-sparcle" class="section-solution section-solution--page">
    <div class="container">
      <SectionHeader
        label="Our Mission"
        heading="Reclaim Time.<br>Unlock Potential."
      />

      <div class="page-prose">
        <p>
          Sparcle exists for one reason: to help organizations reclaim the time and money lost to workplace fragmentation. Knowledge workers today juggle dozens of applications, losing hours every day to context switching, information searching, and tool hopping. We believe this is a solvable problem.
        </p>
        <p>
          We built <strong>Bolt</strong> — an enterprise AI operating system — and <strong>Aeira</strong> — an ACL-aware enterprise index — to give every employee instant, secure access to the collective intelligence of their organization. No replacement. No migration. No friction.
        </p>
      </div>

      <BlockQuote
        quote="Your workforce burns <strong>~5 weeks per year</strong> reorienting after interruptions."
        citation="Gloria Mark, UC Irvine — Attention Span: A Groundbreaking Way to Restore Balance, Happiness and Productivity"
        href="/research.html"
      />
    </div>
  </section>

  <!-- ========================================
       PROOF & METRICS
       ======================================== -->
  <section id="proof" class="section-proof">
    <div class="container">
      <SectionHeader
        label="Built & Deployed"
        heading="Real Product.<br>Real Metrics."
        intro="Production-grade systems deployed today. These numbers reflect running code, real integrations, and filed patent applications."
      />

      <div class="proof-grid">
        <ProofCard
          metric="8"
          label="Security Pipeline Layers"
          description="Identity validation, PII scrubbing, policy guardrails, rate limiting, multi-tier caching, audit logging, zero client tokens, PII restoration — every request traverses all eight."
        />
        <ProofCard
          metric="30+"
          label="Enterprise Integrations"
          description="Microsoft 365, Google Workspace, Slack, GitHub, Jira, Salesforce, Notion, Zendesk, ServiceNow, Confluence — connected via open MCP, not proprietary APIs."
        />
        <ProofCard
          metric="3"
          label="Patents Pending"
          description="Multi-tier caching architecture (US 63/951,582), dynamic MCP discovery (63/952,804), and adaptive cross-system priority engine (63/952,801)."
        />
        <ProofCard
          metric="<1hr"
          label="Time to Deploy"
          description="Connect your IdP, configure your MCP servers, and deploy Bolt in under an hour. Your team is productive on day one — no migration, no retraining."
        />
        <ProofCard
          metric="0"
          label="Tools Replaced"
          description="Bolt sits above your existing stack. It doesn't replace any tool — it makes every tool your team already uses more accessible and more productive."
        />
        <ProofCard
          metric="~$3M+"
          label="Estimated Annual ROI"
          description="For 1,000 employees at $50/hr loaded cost. Reclaim hours lost to context switching, information searching, and app-hopping every single day."
        />
      </div>

      <div class="section-cta-row">
        <a href="/research.html" class="btn btn-secondary btn-lg">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
          </svg>
          Explore Our Research
        </a>
      </div>
    </div>
  </section>

  <!-- ========================================
       CTA
       ======================================== -->
  <section class="section-cta">
    <div class="container">
      <div class="cta-box">
        <h2>See What Unified Intelligence Looks Like</h2>
        <p>
          Schedule a 30-minute technical walkthrough with our team.
          We'll show you how Bolt and Aeira work with your existing systems —
          no slides, just a live demo.
        </p>
        <div class="cta-actions">
          <a href="mailto:bolt@sparcle.app?subject=Enterprise%20Pilot%20Inquiry" class="btn btn-primary btn-xl">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
              <polyline points="22,6 12,13 2,6" />
            </svg>
            <span>bolt@sparcle.app</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
