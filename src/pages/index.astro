---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageSection from "../components/ui/PageSection.astro";
import CardGrid from "../components/ui/CardGrid.astro";
import Card from "../components/ui/Card.astro";
import CTAStrip from "../components/ui/CTAStrip.astro";
import Pill from "../components/ui/Pill.astro";
import PersonaStrip from "../components/marketing/PersonaStrip.astro";

const proofs = [
  { metric: "100+",     label: "Enterprise Systems", body: "Via open MCP, not proprietary APIs." },
  { metric: "Your IP.", label: "Always Protected",  body: "Regardless of which AI model you use or where it runs." },
  { metric: "<1hr",     label: "To Deploy",         body: "Cloud, VPC, or air-gapped." },
];
---
<BaseLayout
  title="Private, Self-Hosted Enterprise AI — Runs In Your Perimeter (BYO LLM) | Sparcle"
  description="Sparcle (Bolt + Aeira): private, self-hosted enterprise AI agent + governed data plane. BYO LLM, on-prem / VPC / air-gapped. A ChatGPT/Copilot alternative for HIPAA, GDPR, and regulated teams whose data cannot leave their network."
  canonical="https://sparcle.app/"
>
  <main class="page-home">
    <!--
      HERO — preserved with its bespoke 2-video grid + modal player.
      The video-grid behavior is genuinely page-specific (deep-link via
      ?video=…, hover-preview-then-modal). Outer hero structure uses the
      same nav-clearance + center-aligned pattern as Hero.astro.
    -->
    <section class="hero section-stripe-a" id="hero">
      <div class="hero-bg-gradient"></div>

      <div class="container">
        <div class="hero-centered">
          <div class="hero-content-centered">
            <h1>
              Your AI. Inside Your Network.<br>
              <span class="text-gradient">Stay in Control.</span>
            </h1>

            <p class="hero-description">
              Your people are already using AI on their most sensitive work — and the alternative
              to a governed surface is confidential data, source code, and customer records pasted
              into whatever cloud AI is closest. Bolt gives your whole workforce a responsible
              alternative: <strong>token-optimized, privacy-first, governed, and identity-aware</strong>,
              running inside your own perimeter with your own LLM. Cut breach risk, stay compliant,
              and keep everyone productive — in the most regulated industries.
            </p>
            <p class="hero-meta" style="font-size:0.92rem;opacity:0.72;margin-top:0.85rem;">
              Works with your identity stack — Microsoft 365, Google Workspace, Zoho, or any OIDC provider.
            </p>

            <div class="hero-metrics">
              <div class="metric">
                <div class="metric-value">Day 1</div>
                <div class="metric-label">Compliance readiness</div>
              </div>
              <div class="metric">
                <div class="metric-value">Your IP.</div>
                <div class="metric-label">Always protected, regardless of AI model</div>
              </div>
              <div class="metric">
                <div class="metric-value">Any LLM</div>
                <div class="metric-label">Yours or ours — switch anytime</div>
              </div>
            </div>
          </div>

          <div class="hero-video-full">
            <!-- Hero video: Bolt + Aeira combined story (1:30). Bigger than the
                 two-tile row below to signal "start here." -->
            <div class="hero-video-hero" id="heroVideoHero">
              <div class="hero-video-card hero-video-card--hero" data-video-src="media/bolt-aeira-90s.mp4?v=20260606a" data-video-title="Bolt and Aeira. Intelligent Execution. Defensible Answers." role="button" tabindex="0" aria-label="Open Bolt and Aeira combined story with audio">
                <video class="hero-preview-video" muted playsinline preload="metadata" loop autoplay>
                  <source src="media/bolt-aeira-90s.mp4?v=20260606a" type="video/mp4">
                </video>
                <div class="video-controls-overlay video-preview-overlay">
                  <div class="video-play-btn" title="Click to watch with audio">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polygon points="6,4 6,20 16,12" fill="white" stroke="none" />
                      <path d="M18 8.5c1.2 1 2 2.2 2 3.5s-.8 2.5-2 3.5" opacity="0.7" />
                      <path d="M20 6c2 1.5 3 3.5 3 6s-1 4.5-3 6" opacity="0.4" />
                    </svg>
                  </div>
                </div>
                <div class="video-card-label">
                  <span class="video-card-label__eyebrow">Start here · 1:30</span>
                  <span class="video-card-label__title">Bolt + Aeira: the full story</span>
                  <span class="video-card-label__sub">Why your AI lives in your network, not theirs</span>
                </div>
              </div>
            </div>

            <!-- Supporting row — product walkthrough + brand video. -->
            <div class="hero-video-grid" id="heroVideoGrid">
              <div class="hero-video-card" data-video-src="media/Bolt-Walkthrough.mp4" data-video-title="Bolt Walkthrough" role="button" tabindex="0" aria-label="Open Bolt Walkthrough with audio">
                <video class="hero-preview-video" muted playsinline preload="metadata" loop>
                  <source src="media/Bolt-Walkthrough.mp4" type="video/mp4">
                </video>
                <div class="video-controls-overlay video-preview-overlay">
                  <div class="video-play-btn" title="Click to watch with audio">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polygon points="6,4 6,20 16,12" fill="white" stroke="none" />
                      <path d="M18 8.5c1.2 1 2 2.2 2 3.5s-.8 2.5-2 3.5" opacity="0.7" />
                      <path d="M20 6c2 1.5 3 3.5 3 6s-1 4.5-3 6" opacity="0.4" />
                    </svg>
                  </div>
                </div>
                <div class="video-card-label">
                  <span class="video-card-label__eyebrow">Product · 1:27</span>
                  <span class="video-card-label__title">Why Bolt</span>
                  <span class="video-card-label__sub">See it in action</span>
                </div>
              </div>

              <div class="hero-video-card" data-video-src="media/Bolt-pure-intelligent-execution.mp4" data-video-title="Bolt Pure Intelligent Execution" role="button" tabindex="0" aria-label="Open Bolt Pure Intelligent Execution with audio">
                <video class="hero-preview-video" muted playsinline preload="metadata" loop>
                  <source src="media/Bolt-pure-intelligent-execution.mp4" type="video/mp4">
                </video>
                <div class="video-controls-overlay video-preview-overlay">
                  <div class="video-play-btn" title="Click to watch with audio">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polygon points="6,4 6,20 16,12" fill="white" stroke="none" />
                      <path d="M18 8.5c1.2 1 2 2.2 2 3.5s-.8 2.5-2 3.5" opacity="0.7" />
                      <path d="M20 6c2 1.5 3 3.5 3 6s-1 4.5-3 6" opacity="0.4" />
                    </svg>
                  </div>
                </div>
                <div class="video-card-label">
                  <span class="video-card-label__eyebrow">Vision · 1:16</span>
                  <span class="video-card-label__title">How Bolt</span>
                  <span class="video-card-label__sub">Pure intelligent execution</span>
                </div>
              </div>
            </div>
            <p class="video-caption">Hover to zoom and preview muted. Click any video to watch full view with audio.</p>
          </div>

          <!--
            Free download is the only true no-human path in the hero. Make
            it the primary CTA so a regulated buyer with no customer
            references can touch the product before scheduling anything.
            The architecture-review call remains secondary for buyers who
            want the conversation first.
          -->
          <div class="hero-ctas">
            <a href="/download" class="btn btn-primary btn-lg">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                <polyline points="7 10 12 15 17 10" />
                <line x1="12" y1="15" x2="12" y2="3" />
              </svg>
              <span>Get Bolt &middot; Free for individuals</span>
            </a>
            <a href="#" onclick="openContactModal('Architecture Review'); return false;" class="btn btn-secondary btn-lg">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="4" width="18" height="18" rx="2" />
                <line x1="16" y1="2" x2="16" y2="6" />
                <line x1="8" y1="2" x2="8" y2="6" />
                <line x1="3" y1="10" x2="21" y2="10" />
              </svg>
              Schedule architecture review
            </a>
          </div>

          <p class="hero-tertiary-link">
            Full platform on your laptop &middot; your org credentials &middot; evaluate with real data &middot; no call required
          </p>

          <div class="hero-trust-strip">
            <Pill variant="neutral" size="sm"><strong>Patent-pending</strong> governance</Pill>
            <Pill variant="neutral" size="sm">Multi-layer security pipeline</Pill>
            <Pill variant="neutral" size="sm">Privilege-safe &middot; HIPAA &middot; GDPR &middot; DPDPA workflows</Pill>
            <Pill variant="neutral" size="sm">BYO LLM &middot; BYOK</Pill>
            <Pill variant="neutral" size="sm">On-Prem &middot; VPC &middot; Air-Gap Ready</Pill>
            <Pill variant="neutral" size="sm">No outbound prompt to inspect</Pill>
          </div>

          <div id="heroVideoModal" class="hero-video-modal">
            <button type="button" id="heroModalClose" class="hero-modal-close" aria-label="Close">&times;</button>
            <video id="heroModalVideo" controls playsinline class="hero-modal-video"></video>
          </div>
        </div>
      </div>
    </section>

    <!--
      Pre-launch by design — the absence of public logos is intentional. The
      ICP (defense, federal, regulated finance, AmLaw, healthcare M&A) often
      contractually forbids vendor reference. Flipping that constraint into
      identity: we choose partners, we don't collect logos.
    -->
    <PageSection
      eyebrow="Pre-launch by design"
      title="Our customers don't appear here. That's the contract."
      stripe="b"
      width="content"
    >
      <div class="design-partners-grid">
        <div class="design-partner-logo">Healthcare</div>
        <div class="design-partner-logo">Defense</div>
        <div class="design-partner-logo">Financial</div>
        <div class="design-partner-logo">Federal</div>
        <div class="design-partner-logo">Legal</div>
      </div>
      <p class="design-partners-note">
        Sparcle deploys into environments where vendor reference is contractually forbidden.
        We are not collecting logos &mdash; we are choosing partners. The first 50 founding
        customers get founder-led integration, 25% off list locked for 24 months, direct
        roadmap influence, and a contract structured for your security posture, not ours.
        <br>
        <a href="#" onclick="openContactModal('Founding Customer Application'); return false;">Apply for Founding Customer status &rarr;</a>
        &middot;
        <a href="#" onclick="openContactModal('Founding Customer Reference Request'); return false;">Request reference under NDA</a>
      </p>
    </PageSection>

    <!-- Founding customers banner -->
    <PageSection stripe="a">
      <div class="founding-banner">
        <div class="founding-banner__lhs">
          <div class="founding-banner__badge">Founding Customers Program</div>
          <h3 class="founding-banner__title">First 50 customers — 25% off, locked for 24 months</h3>
          <p class="founding-banner__desc">
            We're building Bolt and Aeira with a small group of founding customers who get
            direct access to the founding team, influence on the roadmap, and pricing locked
            at 25% below published rates for 24 months. Open through end of 2026 or until
            50 customers are signed — whichever comes first.
          </p>
          <a href="#" onclick="openContactModal('Founding Customer Application'); return false;" class="btn btn-primary btn-lg">
            Apply for Founding Customer status &rarr;
          </a>
        </div>
        <div class="founding-banner__rhs">
          <ul class="founding-banner__perks">
            <li>25% off any Bolt or Aeira tier (24-month price lock)</li>
            <li>Direct founder access &middot; weekly office hours</li>
            <li>Roadmap influence &middot; priority on feature requests</li>
            <li>Optional co-marketing (case study, joint announcement)</li>
            <li>Locked grandfather pricing as you grow into bigger tiers</li>
          </ul>
        </div>
      </div>
    </PageSection>

    <!-- Our platform: Bolt + Aeira -->
    <PageSection
      eyebrow="Our Platform"
      title="Governance first. Then unstoppable productivity."
      lede="<strong>Bolt</strong> is the sovereign AI operating system that deploys inside your perimeter — governed, auditable, and compliant from day one. <strong>Aeira</strong> is the ACL-aware index that makes every answer grounded and permission-safe. Together, they turn governance into a foundation, not a bottleneck."
      stripe="b"
    >
      <CardGrid cols={2} gap="lg">
        <article class="platform-card">
          <div class="platform-card__header">
            <img src="/images/bolt-logo.svg" alt="Bolt" class="platform-card__logo" width="56" height="56">
            <div>
              <h3>Bolt</h3>
              <p class="platform-card__subtitle">Sovereign AI Operating System</p>
            </div>
            <Pill variant="brand" size="sm" class="platform-card__badge">Governed Agentic Platform</Pill>
          </div>
          <p class="platform-card__intro">
            Deploys inside your firewall — governed, auditable, and compliant from day&nbsp;one.
            Every employee gets an AI agent that connects to your enterprise systems via open
            MCP and surfaces exactly what they need next.
          </p>
          <ul class="platform-card__features">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              <span><strong>Inside your perimeter</strong> — on-prem, VPC, or air-gapped; PII masked at the LLM boundary; nothing for an edge AI gateway to inspect</span>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v6m0 6v6m-9-9h6m6 0h6"/></svg>
              <span><strong>BYO LLM &middot; BYOK</strong> — zero token markup; swap models without changing compliance posture</span>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
              <span><strong>The One Thing&#x2122;</strong> — patent-pending priority engine surfaces actionable signal from noise across systems</span>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
              <span><strong>Open MCP integrations</strong> — M365, Google, Slack, Jira, Salesforce, GitHub, and a growing roster</span>
            </li>
          </ul>
          <a href="/products.html" class="btn btn-primary btn-lg">Explore Bolt</a>
        </article>

        <article class="platform-card">
          <div class="platform-card__header">
            <img src="/images/aeira-logo.svg" alt="Aeira" class="platform-card__logo" width="56" height="56">
            <div>
              <h3>Aeira</h3>
              <p class="platform-card__subtitle">Compliance-Grade Enterprise Data Plane</p>
            </div>
            <Pill variant="brand" size="sm" class="platform-card__badge">Enterprise Search</Pill>
          </div>
          <p class="platform-card__intro">
            The fully self-hosted data plane for enterprises whose ACL, data-residency,
            and audit-trail bar is non-negotiable. Identity-bound search, provable erasure,
            audit-trail responses your compliance team can sign off on. Built to the bar
            legal, healthcare, financial services, and defense buyers demand. Start with
            Catalog free; scale to Dynamic, Enhanced, or Federated.
          </p>
          <ul class="platform-card__features">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <span><strong>Identity-bound access</strong> — every query filtered to what the calling user is entitled to see</span>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              <span><strong>Provable erasure</strong> — cryptographic proof for GDPR / HIPAA Right to be Forgotten</span>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              <span><strong>Air-gap-ready</strong> — AWS, Azure, GCP, on-prem, or fully air-gapped</span>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              <span><strong>Audit-trail responses</strong> — every result carries the why-filtered context regulators ask for</span>
            </li>
          </ul>
          <a href="/products/aeira.html" class="btn btn-primary btn-lg">Explore Aeira</a>
        </article>
      </CardGrid>
    </PageSection>

    <!-- Bolt is for everyone — role decks after product is established -->
    <PersonaStrip />

    <!-- Stack layers: how Sparcle sits alongside identity, search, edge security. -->
    <PageSection
      eyebrow="How Sparcle sits in your stack"
      title="A different layer. Not a replacement for what's working."
      lede="Sparcle is the AI runtime layer of your enterprise stack. It runs alongside the identity provider, enterprise search, and edge security you've already built — none of which need to change. What does change is where AI runs, and how it's governed."
      stripe="a"
    >
      <div class="stack-layers" role="table" aria-label="How Sparcle sits in your stack">
        <div class="stack-layers__row stack-layers__head" role="row">
          <div class="stack-layers__cell" role="columnheader">Layer in your stack</div>
          <div class="stack-layers__cell" role="columnheader">What that layer does</div>
          <div class="stack-layers__cell stack-layers__cell--sparcle" role="columnheader">Where Sparcle sits</div>
        </div>

        <div class="stack-layers__row" role="row">
          <div class="stack-layers__cell" role="cell" data-label="Layer">
            <strong>Public AI assistants</strong>
            <span class="stack-layers__hint">Copilot 365, Gemini, ChatGPT Enterprise, and similar</span>
          </div>
          <div class="stack-layers__cell" role="cell" data-label="What that layer does">
            Run in the vendor's cloud, on the vendor's models. Productive, but the
            corporate prompt and the retrieved context live on infrastructure you
            don't control.
          </div>
          <div class="stack-layers__cell stack-layers__cell--sparcle" role="cell" data-label="Where Sparcle sits">
            Sparcle runs in <strong>yours</strong>. Same daily productivity surface, your
            perimeter and your choice of LLM. Switch the model later without
            re-running compliance.
          </div>
        </div>

        <div class="stack-layers__row" role="row">
          <div class="stack-layers__cell" role="cell" data-label="Layer">
            <strong>Enterprise search</strong>
            <span class="stack-layers__hint">Glean and similar</span>
          </div>
          <div class="stack-layers__cell" role="cell" data-label="What that layer does">
            Indexes corporate content centrally so employees can find what they need
            across SaaS tools.
          </div>
          <div class="stack-layers__cell stack-layers__cell--sparcle" role="cell" data-label="Where Sparcle sits">
            Aeira's index is <strong>ACL-bound and self-hosted</strong>. Identity travels
            with the query, so every result is already scoped to what the calling
            user is entitled to see.
          </div>
        </div>

        <div class="stack-layers__row" role="row">
          <div class="stack-layers__cell" role="cell" data-label="Layer">
            <strong>Edge AI inspection</strong>
            <span class="stack-layers__hint">Inline AI gateways and SSE proxies</span>
          </div>
          <div class="stack-layers__cell" role="cell" data-label="What that layer does">
            Decrypt outbound prompts at the network edge to catch what employees
            send to public LLMs.
          </div>
          <div class="stack-layers__cell stack-layers__cell--sparcle" role="cell" data-label="Where Sparcle sits">
            Sparcle runs the model <strong>inside your perimeter</strong>, so there is no
            outbound prompt for the edge to inspect. The boundary is identity, not
            the wire.
          </div>
        </div>
      </div>

      <p class="stack-layers__footnote">
        Sparcle is the AI runtime. Your identity stack, enterprise search, and edge
        security keep doing what they already do well.
        <a href="/trust/where-the-model-runs">How the model stays in your perimeter &rarr;</a>
      </p>
    </PageSection>

    <!-- Why Sparcle teaser -->
    <PageSection
      eyebrow="Why Sparcle"
      title="Data sovereignty is not an add-on. It's the foundation."
      lede="Every other AI vendor treats governance as an enterprise upsell. We built it into the architecture from day one — on-prem deployment, multi-layer security, BYO LLM, full audit logging — so your compliance team says yes, not maybe."
      stripe="b"
    >
      <blockquote class="home-blockquote">
        <p>
          &ldquo;Your workforce burns <strong>~5 weeks per year</strong> reorienting after interruptions.&rdquo;
        </p>
        <footer><a href="/research.html">— Gloria Mark, UC Irvine — Attention Span</a></footer>
      </blockquote>

      <CardGrid cols={3}>
        {proofs.map((p) => (
          <Card variant="proof" metric={p.metric} title={p.label}>
            {p.body}
          </Card>
        ))}
      </CardGrid>

      <div style="text-align: center; margin-top: var(--space-block);">
        <a href="/why-sparcle" class="btn btn-secondary btn-lg">
          Our Mission &amp; Story
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </PageSection>

    <a id="contact" class="anchor" aria-hidden="true"></a>
    <CTAStrip
      variant="band"
      title="See Bolt run inside your perimeter on your data."
      lede="Schedule a 30-minute technical walkthrough with our team. We'll show you how Bolt and Aeira work with your existing systems — no slides, just a live demo."
    >
      <a href="#" onclick="openContactModal('Enterprise Pilot Inquiry'); return false;" class="btn btn-primary btn-xl">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
        <span>Schedule a Demo</span>
      </a>
      <Fragment slot="note">
        <a href="/media/Bolt_Strategic_Vision.pdf" target="_blank">Strategic Vision</a>
        &nbsp;&middot;&nbsp;
        <a href="/research.html">Research &amp; Whitepaper</a>
      </Fragment>
    </CTAStrip>
  </main>

  <!--
    Hero-video modal player JS — moved out of the body fragment, scoped to this page.
    Deep-link via ?video=walkthrough|pure or #left|#right; hover-preview the right
    card; full-audio playback on click.
  -->
  <script is:inline>
    (function () {
      var grid = document.getElementById('heroVideoGrid');
      // Cards in DOM order: [0] hero (Bolt+Aeira), [1] Why Bolt (walkthrough),
      // [2] How Bolt (pure-intelligent-execution). Pre-restructure code
      // assumed exactly 2 cards; that assumption is gone now.
      var cards = document.querySelectorAll('.hero-video-card');
      var heroCard = document.querySelector('.hero-video-card--hero') || null;
      var gridCards = grid ? grid.querySelectorAll('.hero-video-card') : [];
      var leftCard = gridCards[0] || null;
      var rightCard = gridCards[1] || null;
      var modal = document.getElementById('heroVideoModal');
      var modalVideo = document.getElementById('heroModalVideo');
      var closeBtn = document.getElementById('heroModalClose');
      if (!cards.length || !modal || !modalVideo) return;

      function playLeftPreview() {
        if (!leftCard) return;
        var lp = leftCard.querySelector('.hero-preview-video');
        if (!lp) return;
        lp.muted = true;
        lp.play().catch(function () {});
      }

      function pauseAllPreviews() {
        cards.forEach(function (c) {
          var p = c.querySelector('.hero-preview-video');
          c.classList.remove('is-active');
          if (!p) return;
          p.pause();
          p.currentTime = 0;
        });
      }

      function activateRightCard() {
        if (!rightCard) return;
        var p = rightCard.querySelector('.hero-preview-video');
        if (!p) return;
        rightCard.classList.add('is-active');
        p.muted = true;
        p.currentTime = 0;
        p.play().catch(function () {});
      }

      function deactivateRightCard() {
        if (!rightCard) return;
        var p = rightCard.querySelector('.hero-preview-video');
        if (!p) return;
        p.pause();
        p.currentTime = 0;
        rightCard.classList.remove('is-active');
      }

      function setVideoParam(slug) {
        var url = new URL(window.location.href);
        if (slug) url.searchParams.set('video', slug);
        else url.searchParams.delete('video');
        window.history.replaceState({}, '', url.toString());
      }

      function getDeepLinkedVideoSlug() {
        var params = new URLSearchParams(window.location.search);
        var q = (params.get('video') || '').toLowerCase();
        if (q) return q;
        var hash = (window.location.hash || '').replace('#', '').trim().toLowerCase();
        if (!hash) return '';
        if (hash.indexOf('video=') === 0) return hash.slice(6);
        if (hash === 'left' || hash === 'right' || hash === 'walkthrough' || hash === 'pure') return hash;
        return '';
      }

      function slugToCard(slug) {
        if (!slug) return null;
        if (slug === 'hero' || slug === 'start-here' || slug === 'bolt-aeira' || slug === 'bolt-and-aeira') return heroCard;
        if (slug === 'left' || slug === 'why-bolt' || slug === 'walkthrough' || slug === 'bolt-walkthrough' || slug === 'demo') return leftCard;
        if (slug === 'right' || slug === 'how-bolt' || slug === 'pure' || slug === 'intelligent' || slug === 'bolt-pure-intelligent-execution') return rightCard;
        return null;
      }

      function openModal(src, slug, syncUrl) {
        if (!src) return;
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
        pauseAllPreviews();
        if (syncUrl) setVideoParam(slug);
        modalVideo.src = src;
        modalVideo.muted = false;
        modalVideo.currentTime = 0;
        modalVideo.play().catch(function () {});
      }

      function closeModal(clearUrlParam) {
        modal.style.display = 'none';
        document.body.style.overflow = '';
        modalVideo.pause();
        modalVideo.removeAttribute('src');
        modalVideo.load();
        if (clearUrlParam) setVideoParam('');
        playLeftPreview();
      }

      if (rightCard) {
        rightCard.addEventListener('mouseenter', activateRightCard);
        rightCard.addEventListener('focus', activateRightCard);
        rightCard.addEventListener('mouseleave', deactivateRightCard);
        rightCard.addEventListener('blur', deactivateRightCard);
      }
      cards.forEach(function (c) {
        var src = c.getAttribute('data-video-src');
        var slug = c === heroCard ? 'bolt-aeira'
                 : c === leftCard ? 'why-bolt'
                 : c === rightCard ? 'how-bolt'
                 : '';
        c.addEventListener('click', function () { openModal(src, slug, true); });
        c.addEventListener('keydown', function (e) {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openModal(src, slug, true); }
        });
      });
      closeBtn.addEventListener('click', function (e) { e.stopPropagation(); closeModal(true); });
      modal.addEventListener('click', function (e) { if (e.target === modal) closeModal(true); });
      document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && modal.style.display === 'flex') closeModal(true); });

      var deep = getDeepLinkedVideoSlug();
      var deepCard = slugToCard(deep);
      if (deepCard) {
        var deepSrc = deepCard.getAttribute('data-video-src');
        var norm = deepCard === heroCard ? 'bolt-aeira'
                 : deepCard === leftCard ? 'why-bolt'
                 : 'how-bolt';
        openModal(deepSrc, norm, true);
      }
      if (modal.style.display !== 'flex') playLeftPreview();
    })();
  </script>
</BaseLayout>

