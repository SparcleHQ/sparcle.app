---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/ui/Hero.astro";
import PageSection from "../components/ui/PageSection.astro";
import CardGrid from "../components/ui/CardGrid.astro";
import Card from "../components/ui/Card.astro";
import CTAStrip from "../components/ui/CTAStrip.astro";
import Pill from "../components/ui/Pill.astro";

const applyEmail = "mailto:bolt@sparcle.app?subject=Bolt%20Founding%20Early%20Adopter%20Application";

const eligibility = [
  { metric: "OS",       label: "Mac, Windows, or Linux",   body: "You can use Bolt in real daily workflows across one of these environments during the 7-day trial." },
  { metric: "Google",   label: "Connected Workflow Testing", body: "You can sign in to Bolt with your Google account and connect services like Gmail, Calendar, Contacts, and Tasks." },
  { metric: "Evidence", label: "Structured Reporting",      body: "You can submit structured feedback on what worked, what did not, and why, with evidence when relevant." },
];

const qualification = [
  { metric: "5/7", label: "Active Usage",       body: "Use Bolt in real workflows on at least 5 of 7 days during your cohort window." },
  { metric: "3+",  label: "Structured Reports", body: "Submit at least three useful reports with expected vs actual behavior and practical impact." },
  { metric: "1",   label: "Final Summary",      body: "Submit one concise end-of-week summary of what worked, what did not, and what to improve." },
];

const privacy = [
  { metric: "Control", label: "You Decide What Connects",    body: "You control which services are connected and can disconnect or revoke access anytime." },
  { metric: "Scope",   label: "Least-Privilege Access",     body: "We request only the permissions needed to support the features you choose to use." },
  { metric: "Policy",  label: "Transparent Terms",           body: "Program participation, eligibility, and data-handling expectations are stated clearly before you apply." },
];
---
<BaseLayout
  title="Bolt Founding Early Adopters | Applications Open"
  description="Applications are open for 5 Bolt Founding Early Adopter seats. Get a free 7-day AI-ready trial and help shape the product with structured feedback."
  canonical="https://sparcle.app/early-partners"
>
  <Fragment slot="head">
    <meta name="robots" content="noindex, nofollow" />
  </Fragment>

  <main class="page-early-partners">
    <Hero
      eyebrow="Applications Open"
      title="Experience Bolt for <strong>free</strong>. Earn rewards for quality feedback."
      lede="Limited seats. Selected 5 applicants get Bolt full features + LLM key + earn up to $50."
    >
      <a class="btn btn-primary btn-lg" href={applyEmail}>Join the Mission</a>
      <a class="btn btn-secondary btn-lg" href="#eligibility">View Eligibility</a>
    </Hero>

    <PageSection
      eyebrow="Quick install"
      title="Two lines. Then you're in."
      stripe="b"
      width="prose"
    >
      <div class="ep-install-wrap">
        <div class="download-section">
          <div class="dl-tabs">
            <button class="dl-tab dl-tab--active" data-platform="macos" type="button">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
              macOS
            </button>
            <button class="dl-tab" data-platform="linux" type="button">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489a2.1 2.1 0 0 0-.084-.006c-.393 0-.777.158-1.048.473-.611.71-.354 1.884.482 2.497-.184.373-.27.77-.27 1.163 0 .63.259 1.248.867 1.687-.186.37-.275.758-.275 1.142 0 .838.537 1.591 1.541 1.846.305 1.166 1.451 2.344 2.527 2.344.348 0 .685-.113.978-.349.328.24.729.349 1.137.349.844 0 1.535-.479 1.879-1.219.417.102.862.155 1.316.155.455 0 .9-.054 1.316-.155.344.74 1.035 1.219 1.879 1.219.408 0 .809-.109 1.137-.349.293.236.63.349.978.349 1.076 0 2.222-1.178 2.527-2.344 1.004-.255 1.541-1.008 1.541-1.846 0-.384-.089-.771-.275-1.142.608-.439.867-1.057.867-1.687 0-.393-.086-.79-.27-1.163.836-.613 1.093-1.787.482-2.497-.271-.315-.655-.473-1.048-.473-.029 0-.057.003-.084.006.123-.805-.009-1.657-.287-2.489-.589-1.771-1.831-3.47-2.716-4.521-.75-1.067-.974-1.928-1.05-3.02-.065-1.491 1.056-5.965-3.17-6.298A5.1 5.1 0 0 0 12.504 0z"/></svg>
              Linux
            </button>
            <button class="dl-tab" data-platform="windows" type="button">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/></svg>
              Windows
            </button>
          </div>

          <div class="dl-panel" data-platform="macos">
            <p class="dl-cmd-hint">Run in Terminal &middot; Apple Silicon &amp; Intel</p>
            <div class="dl-code-block">
              <code>curl -fsSL https://sparcle.app/trial.sh | sh</code>
              <button class="dl-copy-btn" type="button" onclick="navigator.clipboard.writeText('curl -fsSL https://sparcle.app/trial.sh | sh');this.querySelector('span').textContent='Copied!';setTimeout(()=>this.querySelector('span').textContent='Copy',1500)" title="Copy to clipboard">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                <span>Copy</span>
              </button>
            </div>
            <p class="dl-cmd-note">Downloads, installs to /Applications, and launches Bolt Enterprise</p>
          </div>

          <div class="dl-panel" data-platform="linux" hidden>
            <p class="dl-cmd-hint">Run in Terminal &middot; x86_64 &amp; ARM64</p>
            <div class="dl-code-block">
              <code>curl -fsSL https://sparcle.app/trial.sh | sh</code>
              <button class="dl-copy-btn" type="button" onclick="navigator.clipboard.writeText('curl -fsSL https://sparcle.app/trial.sh | sh');this.querySelector('span').textContent='Copied!';setTimeout(()=>this.querySelector('span').textContent='Copy',1500)" title="Copy to clipboard">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                <span>Copy</span>
              </button>
            </div>
            <p class="dl-cmd-note">Auto-detects Linux &middot; installs AppImage to ~/.local/bin</p>
          </div>

          <div class="dl-panel" data-platform="windows" hidden>
            <p class="dl-cmd-hint">Run in PowerShell &middot; x86_64</p>
            <div class="dl-code-block">
              <code>irm https://sparcle.app/trial.ps1 | iex</code>
              <button class="dl-copy-btn" type="button" onclick="navigator.clipboard.writeText('irm https://sparcle.app/trial.ps1 | iex');this.querySelector('span').textContent='Copied!';setTimeout(()=>this.querySelector('span').textContent='Copy',1500)" title="Copy to clipboard">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                <span>Copy</span>
              </button>
            </div>
            <p class="dl-cmd-note">Marks app as trusted &middot; downloads, installs, and launches Bolt</p>
          </div>
        </div>
      </div>
    </PageSection>

    <PageSection
      id="eligibility"
      eyebrow="Eligibility"
      title="Who should apply."
      lede="You should apply if you can run commands, articulate clearly, and provide practical, reproducible insights."
      stripe="a"
    >
      <CardGrid cols={3}>
        {eligibility.map((e) => (
          <Card variant="proof" metric={e.metric} title={e.label}>{e.body}</Card>
        ))}
      </CardGrid>
    </PageSection>

    <PageSection
      eyebrow="Qualification"
      title="How you qualify for appreciation."
      stripe="b"
    >
      <CardGrid cols={3}>
        {qualification.map((q) => (
          <Card variant="proof" metric={q.metric} title={q.label}>{q.body}</Card>
        ))}
      </CardGrid>

      <p class="ep-reward-note">
        <strong>Appreciation rewards are engagement- and quality-based</strong>
        and may range up to <Pill variant="brand" size="md">$50 USD</Pill> for high-value,
        non-duplicate signals. <Pill variant="brand" size="md">LLM key included</Pill>
        so you can start using Bolt right away.
      </p>
    </PageSection>

    <PageSection
      id="privacy"
      eyebrow="Trust"
      title="Privacy and permissions."
      lede="Bolt is designed for controlled, permission-based access to connected services."
      stripe="a"
    >
      <CardGrid cols={3}>
        {privacy.map((p) => (
          <Card variant="proof" metric={p.metric} title={p.label}>{p.body}</Card>
        ))}
      </CardGrid>
      <div style="text-align: center; margin-top: var(--space-block); display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap;">
        <a class="btn btn-secondary" href="/privacy">Read Privacy Policy</a>
        <a class="btn btn-secondary" href="/terms">Read Terms of Use</a>
      </div>
    </PageSection>

    <CTAStrip
      variant="band"
      title="Apply for one of 5 founding early adopter seats."
      lede="If selected, you will get a 7-day AI-ready Bolt experience, direct access to influence product decisions, and quality-based appreciation for your contribution."
    >
      <a class="btn btn-primary btn-xl" href={applyEmail}>Join the Mission</a>
      <Fragment slot="note">
        Prefer a direct intro? Write to <a href="mailto:bolt@sparcle.app">bolt@sparcle.app</a>
      </Fragment>
    </CTAStrip>
  </main>

  <script is:inline>
    (function() {
      function detectPlatform() {
        var ua = navigator.userAgent || '';
        if (ua.indexOf('Win') !== -1) return 'windows';
        if (ua.indexOf('Linux') !== -1) return 'linux';
        return 'macos';
      }
      function selectTab(section, platform) {
        section.querySelectorAll('.dl-tab').forEach(function(t) {
          t.classList.toggle('dl-tab--active', t.dataset.platform === platform);
        });
        section.querySelectorAll('.dl-panel').forEach(function(p) {
          p.hidden = p.dataset.platform !== platform;
        });
      }
      document.addEventListener('DOMContentLoaded', function() {
        var platform = detectPlatform();
        document.querySelectorAll('.download-section').forEach(function(section) {
          selectTab(section, platform);
          section.querySelectorAll('.dl-tab').forEach(function(tab) {
            tab.addEventListener('click', function() {
              selectTab(section, tab.dataset.platform);
            });
          });
        });
      });
    })();
  </script>
</BaseLayout>

<style is:global>
  .ep-install-wrap {
    background: var(--bg-surface-solid);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
  }
  .ep-install-wrap .download-section {
    border-top: none;
    padding-top: 0;
    margin-top: 0;
  }
  .ep-reward-note {
    text-align: center;
    max-width: 60ch;
    margin: var(--space-block) auto 0;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text-body);
  }
  .ep-reward-note strong { color: var(--text-heading); }
  .ep-reward-note .pill { margin: 0 0.15rem; vertical-align: baseline; }
</style>
