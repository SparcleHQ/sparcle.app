---
// Platform-tabbed install widget. Same look + behavior as the install card on
// /download: extracted so /docs/trial-quickstart (and any future page) can
// reuse it without duplicating markup, CSS, or tab-switching JS.
//
// CSS lives at :global scope under .dl-* and .download-section. /download
// also defines the same classes today; rules are identical, so cohabitation
// on the same page is safe. When /download is later refactored to use this
// component, that duplication goes away.
//
// JS is guarded by window.__bolt_install_tabs_attached__ so it never
// double-binds even if the component renders multiple times on one page.

interface PlatformCmd {
  hint: string;     // Small uppercase line above the code block.
  command: string;  // The actual install command (also used by the Copy btn).
  note: string;     // Small note under the code block.
}
interface Props {
  macos: PlatformCmd;
  linux: PlatformCmd;
  windows: PlatformCmd;
}

const { macos, linux, windows } = Astro.props;
---

<div class="download-section">
  <div class="dl-tabs">
    <button class="dl-tab dl-tab--active" data-platform="macos" type="button">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
      macOS
    </button>
    <button class="dl-tab" data-platform="linux" type="button">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489a2.1 2.1 0 0 0-.084-.006c-.393 0-.777.158-1.048.473-.611.71-.354 1.884.482 2.497-.184.373-.27.77-.27 1.163 0 .63.259 1.248.867 1.687-.186.37-.275.758-.275 1.142 0 .838.537 1.591 1.541 1.846.305 1.166 1.451 2.344 2.527 2.344.348 0 .685-.113.978-.349.328.24.729.349 1.137.349.844 0 1.535-.479 1.879-1.219.417.102.862.155 1.316.155.455 0 .9-.054 1.316-.155.344.74 1.035 1.219 1.879 1.219.408 0 .809-.109 1.137-.349.293.236.63.349.978.349 1.076 0 2.222-1.178 2.527-2.344 1.004-.255 1.541-1.008 1.541-1.846 0-.384-.089-.771-.275-1.142.608-.439.867-1.057.867-1.687 0-.393-.086-.79-.27-1.163.836-.613 1.093-1.787.482-2.497-.271-.315-.655-.473-1.048-.473-.029 0-.057.003-.084.006.123-.805-.009-1.657-.287-2.489-.589-1.771-1.831-3.47-2.716-4.521-.75-1.067-.974-1.928-1.05-3.02-.065-1.491 1.056-5.965-3.17-6.298A5.1 5.1 0 0 0 12.504 0z"/></svg>
      Linux
    </button>
    <button class="dl-tab" data-platform="windows" type="button">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/></svg>
      Windows
    </button>
  </div>

  <div class="dl-panel" data-platform="macos">
    <p class="dl-cmd-hint">{macos.hint}</p>
    <div class="dl-code-block">
      <code>{macos.command}</code>
      <button class="dl-copy-btn" data-cmd={macos.command} type="button" title="Copy to clipboard">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        <span>Copy</span>
      </button>
    </div>
    <p class="dl-cmd-note">{macos.note}</p>
  </div>

  <div class="dl-panel" data-platform="linux" hidden>
    <p class="dl-cmd-hint">{linux.hint}</p>
    <div class="dl-code-block">
      <code>{linux.command}</code>
      <button class="dl-copy-btn" data-cmd={linux.command} type="button" title="Copy to clipboard">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        <span>Copy</span>
      </button>
    </div>
    <p class="dl-cmd-note">{linux.note}</p>
  </div>

  <div class="dl-panel" data-platform="windows" hidden>
    <p class="dl-cmd-hint">{windows.hint}</p>
    <div class="dl-code-block">
      <code>{windows.command}</code>
      <button class="dl-copy-btn" data-cmd={windows.command} type="button" title="Copy to clipboard">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        <span>Copy</span>
      </button>
    </div>
    <p class="dl-cmd-note">{windows.note}</p>
  </div>
</div>

<script is:inline>
  (function () {
    // Idempotent: safe to load once per page even if multiple <InstallTabs>
    // render. /download still ships its own inline tab handler today; the
    // guard below prevents double-binding when both run.
    if (window.__bolt_install_tabs_attached__) return;
    window.__bolt_install_tabs_attached__ = true;

    function detectPlatform() {
      var ua = navigator.userAgent || '';
      if (ua.indexOf('Win') !== -1) return 'windows';
      if (ua.indexOf('Linux') !== -1) return 'linux';
      return 'macos';
    }

    function selectTab(section, platform) {
      section.querySelectorAll('.dl-tab').forEach(function (t) {
        t.classList.toggle('dl-tab--active', t.dataset.platform === platform);
      });
      section.querySelectorAll('.dl-panel').forEach(function (p) {
        p.hidden = p.dataset.platform !== platform;
      });
    }

    function copyCmd(btn) {
      var cmd = btn.dataset.cmd || '';
      if (!cmd) return;
      try {
        navigator.clipboard.writeText(cmd);
      } catch (e) {
        // Fallback for very old browsers: create a hidden textarea.
        var ta = document.createElement('textarea');
        ta.value = cmd;
        ta.setAttribute('readonly', '');
        ta.style.position = 'absolute';
        ta.style.left = '-9999px';
        document.body.appendChild(ta);
        ta.select();
        try { document.execCommand('copy'); } catch (e2) {}
        document.body.removeChild(ta);
      }
      var s = btn.querySelector('span');
      if (s) {
        var prev = s.textContent;
        s.textContent = 'Copied!';
        setTimeout(function () { s.textContent = prev || 'Copy'; }, 1500);
      }
    }

    function init() {
      var platform = detectPlatform();
      document.querySelectorAll('.download-section').forEach(function (section) {
        selectTab(section, platform);
        section.querySelectorAll('.dl-tab').forEach(function (tab) {
          tab.addEventListener('click', function () {
            selectTab(section, tab.dataset.platform);
          });
        });
        section.querySelectorAll('.dl-copy-btn').forEach(function (btn) {
          // /download uses inline onclick="navigator.clipboard.writeText(...)"
          // already. Only wire the delegated handler when the button is OUR
          // (data-cmd-based) variant, so the two paths don't both fire.
          if (btn.hasAttribute('data-cmd')) {
            btn.addEventListener('click', function () { copyCmd(btn); });
          }
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

<style is:global>
  /* Install-tabs widget: global so any page importing <InstallTabs>
     picks up the same look. Mirrors the rules at /download (which still
     duplicates them inline today; will be reconciled in a follow-up). */
  .download-section .dl-tabs {
    display: flex;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border-default);
  }
  .download-section .dl-tab {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.7rem 1rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-muted, #888);
    background: transparent;
    border: none;
    border-right: 1px solid var(--border-default);
    cursor: pointer;
    transition: all var(--transition-fast, 0.15s ease);
    font-family: inherit;
  }
  .download-section .dl-tab:last-child {
    border-right: none;
  }
  .download-section .dl-tab:hover {
    color: var(--text-body);
    background: rgba(59, 130, 246, 0.05);
  }
  .download-section .dl-tab--active {
    color: #fff;
    background: #2563eb;
  }
  .download-section .dl-tab--active:hover {
    background: #1d4ed8;
  }
  .download-section .dl-panel {
    padding: 1rem 0 0.25rem;
  }
  .download-section .dl-cmd-hint {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted, #888);
    margin: 0 0 0.4rem;
  }
  .download-section .dl-code-block {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: #1e1e2e;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    font-family: "SF Mono", "Fira Code", "JetBrains Mono", monospace;
  }
  .download-section .dl-code-block code {
    flex: 1;
    font-size: 0.8rem;
    color: #a6e3a1;
    white-space: pre-wrap;
    overflow-wrap: break-word;
    word-break: normal;
    user-select: all;
    line-height: 1.5;
  }
  .download-section .dl-copy-btn {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.65rem;
    border: none;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 600;
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.6);
    cursor: pointer;
    transition: all var(--transition-fast, 0.15s ease);
    white-space: nowrap;
  }
  .download-section .dl-copy-btn:hover {
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
  }
  .download-section .dl-cmd-note {
    font-size: 0.72rem;
    color: var(--text-muted, #888);
    margin: 0.4rem 0 0;
  }
  @media (max-width: 480px) {
    .download-section .dl-tabs {
      flex-direction: column;
    }
    .download-section .dl-tab {
      border-right: none;
      border-bottom: 1px solid var(--border-default);
    }
    .download-section .dl-tab:last-child {
      border-bottom: none;
    }
  }
  /* Print: the widget shows a single dark code block + a clean note.
     Tab switcher is meaningless on paper, so hide it and reveal all three
     panels stacked. */
  @media print {
    .download-section .dl-tabs { display: none !important; }
    .download-section .dl-panel { display: block !important; padding: 0.25rem 0 0.5rem; }
    .download-section .dl-panel[hidden] { display: block !important; }
    .download-section .dl-code-block {
      background: #f0f0f0 !important;
      border: 0.5pt solid #ccc !important;
      padding: 0.4rem 0.6rem !important;
    }
    .download-section .dl-code-block code {
      color: #111 !important;
      font-size: 9.5pt !important;
    }
    .download-section .dl-copy-btn { display: none !important; }
    .download-section .dl-cmd-hint,
    .download-section .dl-cmd-note {
      color: #555 !important;
      font-size: 8.5pt !important;
    }
  }
</style>
