---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { Content as SpecContent, getHeadings } from "../../../content/utility-manifest-spec.md";

// Utility manifest spec — full reference, rendered from the synced markdown.
//
// The .md file is the single source of truth (synced from bolt-api by
// scripts/sync-docs.sh at build time). We wrap it in BaseLayout here so
// the .md stays pristine — no frontmatter, no layout key, just markdown.
//
// Heading IDs are auto-generated by Astro's default rehype slugger, which
// makes deep links like /docs/utilities/spec#4-top-level-schema work out
// of the box (the in-app YAML editor uses this for "open spec at section").
//
// `headings` (id, depth, slug, text) is exposed by the Markdown import for
// the inline table-of-contents on the right.

// Build a flat ToC of h2 + h3 only; depth 1 is the page title (already in
// the markdown, also rendered as h1), depth >= 4 is too granular for a side
// rail.
const toc = getHeadings().filter((h) => h.depth === 2 || h.depth === 3);
---
<BaseLayout
  title="Utility Manifest Spec (v1) | Sparcle"
  description="Bolt utility manifest specification, version 1. Schema, scopes, flow DAG, filters, actions, presentation, scopes of access, and validation rules. The single source of truth for authoring custom utilities."
  canonical="https://sparcle.app/docs/utilities/spec"
>
  <main class="page-spec">
    <div class="spec-shell">
      <aside class="spec-toc" aria-label="On this page">
        <p class="spec-toc__eyebrow"><a href="/docs/utilities">&larr; Apps</a></p>
        <p class="spec-toc__title">On this page</p>
        <ul class="spec-toc__list">
          {toc.map((h) => (
            <li class={`spec-toc__item depth-${h.depth}`}>
              <a href={`#${h.slug}`}>{h.text}</a>
            </li>
          ))}
        </ul>
        <p class="spec-toc__footer">
          <a href="/docs/utilities/quickstart">Quickstart &rarr;</a><br />
          <a href="/docs/utilities/gallery">Sample gallery &rarr;</a>
        </p>
      </aside>
      <article class="spec-body prose">
        <SpecContent />
      </article>
    </div>
  </main>
</BaseLayout>

<style is:global>
  .page-spec {
    background: var(--bg-body);
    min-height: 100vh;
  }
  .spec-shell {
    max-width: 1180px;
    margin: 0 auto;
    padding: calc(var(--nav-height, 80px) + 2.5rem) 1.5rem 5rem;
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 3rem;
    align-items: start;
  }
  .spec-toc {
    position: sticky;
    top: calc(var(--nav-height, 80px) + 1.5rem);
    max-height: calc(100vh - var(--nav-height, 80px) - 3rem);
    overflow-y: auto;
    font-size: 0.85rem;
    line-height: 1.45;
  }
  .spec-toc__eyebrow {
    margin: 0 0 1.5rem;
    font-size: 0.8rem;
  }
  .spec-toc__eyebrow a {
    color: var(--text-muted);
    text-decoration: none;
  }
  .spec-toc__eyebrow a:hover { color: var(--brand-accent); }
  .spec-toc__title {
    margin: 0 0 0.6rem;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
  }
  .spec-toc__list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
  }
  .spec-toc__item {
    padding: 0.2rem 0;
  }
  .spec-toc__item.depth-3 {
    padding-left: 0.85rem;
    font-size: 0.78rem;
  }
  .spec-toc__item a {
    color: var(--text-body);
    text-decoration: none;
  }
  .spec-toc__item a:hover {
    color: var(--brand-primary);
  }
  .spec-toc__footer {
    margin: 0;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border-subtle);
    font-size: 0.8rem;
  }
  .spec-toc__footer a {
    color: var(--brand-accent);
    text-decoration: none;
  }
  .spec-toc__footer a:hover {
    text-decoration: underline;
  }

  /* Prose body — extends the global .prose rules with code-block + table
     polish that the spec relies on heavily. */
  .spec-body {
    min-width: 0;
    max-width: 80ch;
  }
  .spec-body h1 {
    font-size: clamp(1.85rem, 3.5vw, 2.4rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--text-heading);
    margin: 0 0 1rem;
  }
  .spec-body h2 {
    margin-top: 2.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border-subtle);
    scroll-margin-top: calc(var(--nav-height, 80px) + 1rem);
  }
  .spec-body h3,
  .spec-body h4 {
    scroll-margin-top: calc(var(--nav-height, 80px) + 1rem);
  }
  /* Code blocks (the spec is heavy on YAML and JSON examples). */
  .spec-body pre {
    background: var(--bg-elevated);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md, 0.5rem);
    padding: 0.85rem 1rem;
    overflow-x: auto;
    font-size: 0.85rem;
    line-height: 1.5;
    margin: 0.5rem 0 1.25rem;
  }
  .spec-body pre code {
    background: transparent;
    border: none;
    padding: 0;
    font-size: inherit;
  }
  .spec-body table {
    width: 100%;
    border-collapse: collapse;
    margin: 0.5rem 0 1.5rem;
    font-size: 0.92rem;
  }
  .spec-body th,
  .spec-body td {
    border: 1px solid var(--border-default);
    padding: 0.45rem 0.7rem;
    text-align: left;
    vertical-align: top;
  }
  .spec-body th {
    background: var(--bg-elevated);
    font-weight: 600;
    color: var(--text-heading);
  }
  .spec-body hr {
    border: none;
    border-top: 1px solid var(--border-subtle);
    margin: 2rem 0;
  }

  @media (max-width: 900px) {
    .spec-shell {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .spec-toc {
      position: static;
      max-height: none;
    }
    .spec-toc__list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem 0.9rem;
    }
    .spec-toc__item.depth-3 {
      display: none;
    }
  }
</style>
