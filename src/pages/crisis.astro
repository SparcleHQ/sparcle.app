---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/ui/Hero.astro";
import PageSection from "../components/ui/PageSection.astro";
import CardGrid from "../components/ui/CardGrid.astro";
import Card from "../components/ui/Card.astro";
import CTAStrip from "../components/ui/CTAStrip.astro";
import Prose from "../components/ui/Prose.astro";

const stats = [
  { metric: "473",   label: "SaaS apps per enterprise",     body: "Each demanding credentials, attention, cognitive overhead." },
  { metric: "28%",   label: "Of workweek on email",          body: "Only 39% spent on actual role-specific work (McKinsey)." },
  { metric: "47s",   label: "Average attention span",        body: "Down from 2.5 minutes. Attention residue reduces capacity." },
  { metric: "$450B", label: "Annual U.S. productivity loss", body: "The true cost of workplace fragmentation (Asana Anatomy of Work)." },
];

const yes  = '<span class="cmp-yes"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>';
const no   = '<span class="cmp-no"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></span>';
const partial = '<span class="cmp-partial"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/></svg></span>';
---
<BaseLayout
  title="The Crisis: Why Every Enterprise Loses to Workplace Fragmentation | Sparcle"
  description="473 SaaS apps per enterprise, 47s attention spans, $450B annual productivity loss. Every enterprise that takes IP, data residency, and governance seriously benefits from sovereign AI. Regulated industries can't adopt cloud-only AI by law; many other enterprises choose not to. Sparcle is the answer."
  canonical="https://sparcle.app/crisis"
>
  <main class="page-crisis">
    <Hero
      eyebrow="The Hidden Crisis"
      title="Modern work is broken, and cloud AI makes it worse."
      lede="Dr. Gloria Mark's research at UC Irvine revealed a startling truth: attention spans collapsed from 2.5 minutes to 47 seconds in two decades. Microsoft's Work Trend Index confirms 48% of employees describe work as 'chaotic.' This isn't anecdotal. It's systemic."
    />

    <PageSection
      eyebrow="By the numbers"
      title="What fragmentation costs."
      stripe="b"
    >
      <CardGrid cols={4}>
        {stats.map((s) => (
          <Card variant="stat" metric={s.metric} title={s.label}>{s.body}</Card>
        ))}
      </CardGrid>
    </PageSection>

    <PageSection
      eyebrow="Why existing solutions fall short"
      title="They lock you into their ecosystem."
      stripe="a"
      width="prose"
    >
      <Prose>
        <p>
          It's by design; that's their core business model. Every major AI assistant sends
          your employees' data and documents to cloud infrastructure outside your control.
          We don't believe in vendor lock-in.
        </p>
        <p>
          The regulated economy, healthcare ($4.3T), financial services ($4.6T), defense
          ($886B), legal ($350B), cannot adopt cloud-only AI by law. But the same shape of
          risk hits any enterprise that takes its IP seriously: competitive intelligence,
          proprietary research, customer data, internal strategy. We built for the hardest
          case so the solution fits both: the regulated giant that must, and the ambitious
          enterprise that chooses to.
        </p>
      </Prose>
    </PageSection>

    <PageSection
      eyebrow="Comparison brief"
      title="Take this to your decision committee."
      lede="A 1-page Bolt + Aeira vs. Glean / Hebbia / Harvey / Microsoft Copilot: a 14-dimension comparison with honest framing on where we win, where we tie, and where the incumbents win today. Designed to forward to your security and procurement teams without scheduling a call."
      stripe="b"
    >
      <div class="cmp-brief-cta">
        <a href="/docs/pdfs/bolt-aeira-comparison.pdf" class="btn btn-primary btn-lg" download>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
            <polyline points="7 10 12 15 17 10" />
            <line x1="12" y1="15" x2="12" y2="3" />
          </svg>
          Download comparison brief (PDF)
        </a>
        <a href="/docs/pdfs/bolt-aeira-comparison.pdf" target="_blank" rel="noopener" class="btn btn-secondary btn-lg">
          Open in new tab &nearr;
        </a>
      </div>
      <p class="cmp-brief-note">
        Honest framing: the brief includes a "Where they win today" section &mdash; Web UX polish, brand recognition, paying-customer references. We are not pretending those gaps don't exist.
      </p>
    </PageSection>

    <PageSection
      eyebrow="Comparison"
      title="Bolt vs. Copilot 365 &amp; Gemini Workspace"
      lede="Microsoft Copilot 365 is a $30/seat add-on charged <em>on top of</em> existing M365 licenses ($14–22/seat), totaling $44–52/seat, and requires your data to route through Microsoft's Azure OpenAI cloud. Gemini Workspace similarly processes your documents externally."
      stripe="a"
    >
      <div class="cmp-wrap">
        <table class="cmp">
          <colgroup><col/><col/><col/></colgroup>
          <thead>
            <tr>
              <th></th>
              <th class="cmp-th-ours">Bolt</th>
              <th>Copilot 365 &middot; Gemini</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Self-hosted / air-gapped deployment</td>
              <td set:html={yes}></td>
              <td set:html={no}></td>
            </tr>
            <tr>
              <td>Bring Your Own LLM, switch anytime</td>
              <td set:html={yes}></td>
              <td set:html={`${no}<span class="cmp-note">Vendor-locked model</span>`}></td>
            </tr>
            <tr>
              <td>Works with any IdP: 365, Workspace, Zoho, Okta&hellip;</td>
              <td set:html={yes}></td>
              <td set:html={`${no}<span class="cmp-note">Own ecosystem only</span>`}></td>
            </tr>
            <tr>
              <td>IP &amp; PII protected from AI model</td>
              <td set:html={yes}></td>
              <td set:html={no}></td>
            </tr>
            <tr>
              <td>Data plane stays on-prem; only PII-masked prompts reach the LLM</td>
              <td set:html={yes}></td>
              <td set:html={no}></td>
            </tr>
            <tr>
              <td>HIPAA / ITAR / SOX deployable</td>
              <td set:html={yes}></td>
              <td set:html={no}></td>
            </tr>
            <tr>
              <td>Price per seat / month</td>
              <td><span class="cmp-hero-val">$30</span><span class="cmp-note">Bolt Authorize &middot; self-hosted, BYO LLM</span></td>
              <td><strong>$44–52</strong><span class="cmp-note">$30 Copilot + $14–22 M365 base</span></td>
            </tr>
          </tbody>
        </table>
      </div>
    </PageSection>

    <PageSection
      eyebrow="Comparison"
      title="Aeira vs. Glean"
      lede="Glean is the leading enterprise search tool. It's cloud-hosted, SaaS-only, and routes all document indexing through Glean's infrastructure. Aeira offers equivalent search capability, with full data sovereignty."
      stripe="b"
    >
      <div class="cmp-wrap">
        <table class="cmp">
          <colgroup><col/><col/><col/></colgroup>
          <thead>
            <tr>
              <th></th>
              <th class="cmp-th-ours">Aeira</th>
              <th>Glean</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Self-hosted / on-prem deployment</td>
              <td set:html={yes}></td>
              <td set:html={`${no}<span class="cmp-note">SaaS only</span>`}></td>
            </tr>
            <tr>
              <td>4-level ACL filtering: public / department / group / user</td>
              <td set:html={yes}></td>
              <td set:html={`${partial}<span class="cmp-note">Partial</span>`}></td>
            </tr>
            <tr>
              <td>Documents indexed inside your perimeter</td>
              <td set:html={yes}></td>
              <td set:html={no}></td>
            </tr>
            <tr>
              <td>Bring Your Own LLM for AI answers</td>
              <td set:html={yes}></td>
              <td set:html={no}></td>
            </tr>
            <tr>
              <td>Price per seat / month</td>
              <td><span class="cmp-hero-val">Included</span><span class="cmp-note">Included with Bolt Backbone</span></td>
              <td><strong>~$50–65</strong><span class="cmp-note">$50 base + $15 AI add-on &middot; 100-seat min</span></td>
            </tr>
          </tbody>
        </table>
      </div>
    </PageSection>

    <PageSection
      eyebrow="Comparison"
      title="Bolt vs. Harvey"
      lede="Harvey is the leading vertical-AI assistant for legal teams, with purpose-built workflows for diligence, drafting, and review. It is SaaS-only, cloud-routed, and centered on a fixed model provider. Bolt covers the same legal workflows and extends to the rest of the enterprise (M&amp;A, IP, healthcare, defense, finance), with full sovereignty."
      stripe="a"
    >
      <div class="cmp-wrap">
        <table class="cmp">
          <colgroup><col/><col/><col/></colgroup>
          <thead>
            <tr>
              <th></th>
              <th class="cmp-th-ours">Bolt</th>
              <th>Harvey</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Self-hosted / air-gapped deployment</td>
              <td set:html={yes}></td>
              <td set:html={`${no}<span class="cmp-note">SaaS only</span>`}></td>
            </tr>
            <tr>
              <td>Data stays inside your perimeter</td>
              <td set:html={yes}></td>
              <td set:html={`${no}<span class="cmp-note">Routed to vendor cloud</span>`}></td>
            </tr>
            <tr>
              <td>Bring Your Own LLM &middot; swap models without re-certifying</td>
              <td set:html={yes}></td>
              <td set:html={`${no}<span class="cmp-note">Vendor-selected model</span>`}></td>
            </tr>
            <tr>
              <td>IP &amp; PII protected from the AI model</td>
              <td set:html={yes}></td>
              <td set:html={no}></td>
            </tr>
            <tr>
              <td>Identity-bound retrieval across every connected source</td>
              <td set:html={yes}></td>
              <td set:html={`${partial}<span class="cmp-note">Workspace-scoped</span>`}></td>
            </tr>
            <tr>
              <td>Covers legal + M&amp;A + IP + healthcare + defense + finance</td>
              <td set:html={yes}></td>
              <td set:html={`${partial}<span class="cmp-note">Legal-vertical focus</span>`}></td>
            </tr>
            <tr>
              <td>Open MCP integrations &middot; not locked to one ecosystem</td>
              <td set:html={yes}></td>
              <td set:html={no}></td>
            </tr>
            <tr>
              <td>Price per seat / month</td>
              <td><span class="cmp-hero-val">$30</span><span class="cmp-note">Bolt Authorize &middot; published rate</span></td>
              <td><strong>Enterprise contract</strong><span class="cmp-note">Not publicly disclosed</span></td>
            </tr>
          </tbody>
        </table>
      </div>
    </PageSection>

    <CTAStrip
      variant="band"
      title="There is a way out."
      lede="See how Bolt and Aeira give your team the same productivity gains the cloud-AI vendors promise, while keeping your data inside your perimeter and your compliance posture intact."
    >
      <a href="/solution" class="btn btn-primary btn-lg">
        See Our Solution
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="/research.html" class="btn btn-secondary btn-lg">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
          <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
        </svg>
        View Research &amp; Whitepaper
      </a>
    </CTAStrip>
  </main>
</BaseLayout>

<style is:global>
  /* Comparison brief CTA — promotes the downloadable 1-page PDF that
     covers all four competitors at once (Glean · Hebbia · Harvey ·
     Copilot). Sits above the in-page vendor-by-vendor tables. */
  .page-crisis .cmp-brief-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    margin: 0 auto;
  }
  .page-crisis .cmp-brief-note {
    margin: 1.5rem auto 0;
    max-width: 720px;
    text-align: center;
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* Comparison-table primitive. Reused on /crisis for Bolt-vs-Copilot and
     Aeira-vs-Glean. Anchored to canonical tokens so it inherits theme. */
  .cmp-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    background: var(--bg-surface-solid);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
  }
  .cmp {
    width: 100%;
    min-width: 580px;
    border-collapse: collapse;
    font-size: 0.95rem;
  }
  .cmp colgroup col:first-child { width: 55%; }
  .cmp colgroup col:not(:first-child) { width: 22.5%; }
  .cmp thead tr {
    border-bottom: 2px solid var(--border-strong);
  }
  .cmp th {
    padding: 1rem 1.25rem;
    font-weight: 700;
    font-size: 0.9375rem;
    background: var(--bg-muted);
    color: var(--text-heading);
  }
  .cmp th:first-child { text-align: left; }
  .cmp th:not(:first-child) { text-align: center; }
  .cmp tbody tr { border-bottom: 1px solid var(--border-subtle); transition: background 0.15s; }
  .cmp tbody tr:last-child { border-bottom: none; }
  .cmp tbody tr:hover { background: var(--bg-muted); }
  .cmp td { padding: 1rem 1.25rem; font-size: 0.95rem; line-height: 1.5; vertical-align: middle; }
  .cmp td:first-child { text-align: left; color: var(--text-body); }
  .cmp td:not(:first-child) { text-align: center; }

  .cmp-yes,
  .cmp-no,
  .cmp-partial {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
  }
  .cmp-yes     { background: var(--color-success-bg); color: var(--color-success-strong); }
  .cmp-no      { background: var(--color-danger-bg);  color: var(--color-danger-strong); }
  .cmp-partial { background: var(--color-warning-bg); color: var(--color-warning); }

  .cmp-note {
    display: block;
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin-top: 0.3rem;
    font-weight: 400;
  }
  .cmp-hero-val {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-success-strong);
    font-family: var(--font-display);
  }
  .cmp-th-ours {
    color: var(--brand-primary);
  }
</style>
