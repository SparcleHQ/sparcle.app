---
/**
 * Prose — long-form running text at w-prose width.
 *
 * Use for anything >2 sentences or a list-with-paragraphs that needs to read
 * comfortably (the "lede" in a section is shorter and stays inside PageSection;
 * this is for the longer Crisis/Why-Sparcle/Careers-style body content).
 *
 * Renders headings, paragraphs, lists, and links with consistent rhythm and
 * widths so multi-page prose feels like one document.
 *
 * Props:
 *   align   'left' (default) | 'center'
 *   class   extra class
 */
export interface Props {
  align?: 'left' | 'center';
  class?: string;
}
const { align = 'left', class: className = '' } = Astro.props;
---
<div class={`prose w-prose align-${align} ${className}`}>
  <slot />
</div>

<style is:global>
  .prose {
    color: var(--text-body);
  }
  .prose.align-center {
    text-align: center;
  }
  .prose p,
  .prose ul,
  .prose ol,
  .prose blockquote {
    font-size: 1.0625rem;
    line-height: 1.7;
    margin: 0 0 1.25rem;
    max-width: 65ch;
  }
  .prose.align-center p,
  .prose.align-center ul,
  .prose.align-center ol {
    margin-left: auto;
    margin-right: auto;
  }
  .prose h2,
  .prose h3,
  .prose h4 {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--text-heading);
  }
  .prose h2 {
    font-size: 1.625rem;
  }
  .prose h3 {
    font-size: 1.25rem;
    font-family: var(--font-display);
  }
  .prose h4 {
    font-size: 1.0625rem;
    font-weight: 700;
  }
  .prose a {
    color: var(--brand-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose ul,
  .prose ol {
    padding-left: 1.5rem;
  }
  .prose li {
    margin-bottom: 0.5rem;
    list-style: revert;
  }
  .prose blockquote {
    border-left: 3px solid var(--brand-primary);
    padding: 0.75rem 1.25rem;
    background: var(--brand-primary-light);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-style: italic;
    color: var(--text-heading);
  }
  .prose code {
    font-family: var(--font-mono);
    font-size: 0.92em;
    padding: 0.1em 0.4em;
    background: var(--bg-muted);
    border: 1px solid var(--border-subtle);
    border-radius: 4px;
  }
  .prose strong {
    color: var(--text-heading);
    font-weight: 600;
  }
</style>
