---
const decks = [
  { file: "persona-ciso",              icon: "🛡️", tag: "CISO · Security",      title: "AI without the breach" },
  { file: "persona-cio",               icon: "🖥️", tag: "CIO · IT",             title: "Consolidate the sprawl" },
  { file: "persona-cfo",               icon: "💰", tag: "CFO · Finance",         title: "Cut the AI bill" },
  { file: "persona-compliance",        icon: "⚖️", tag: "Compliance · DPO",      title: "GDPR by architecture" },
  { file: "persona-legal",             icon: "📜", tag: "General Counsel",       title: "AI without waiving privilege" },
  { file: "persona-chro",              icon: "👥", tag: "CHRO · People",         title: "AI on people data, safely" },
  { file: "persona-vp-sales",          icon: "📈", tag: "VP Sales · CRO",        title: "Pipeline velocity, zero leak" },
  { file: "persona-platform",          icon: "🔌", tag: "Platform · Integrations", title: "Connect anything" },
  { file: "persona-developer",         icon: "💻", tag: "Developer",             title: "One keystroke, 20 tabs closed" },
  { file: "persona-product-manager",   icon: "🧭", tag: "Product Manager",       title: "Tickets, docs, one box" },
  { file: "persona-finance-ops",       icon: "🧮", tag: "Finance · Ops",         title: "Catch the typo before the wire" },
  { file: "persona-security-analyst",  icon: "📡", tag: "Security · SOC",        title: "Triage in a keystroke" },
  { file: "persona-sales-rep",         icon: "🤝", tag: "Account Executive",     title: "Close faster, type less" },
  { file: "persona-support",           icon: "🎧", tag: "Support · CS",          title: "Faster replies, fewer tabs" },
  { file: "persona-knowledge-worker",  icon: "💼", tag: "Everyday",              title: "Your day, minus the friction" },
];
const loop = [...decks, ...decks];
---

<section class="bfe" aria-label="Bolt is for everyone">
  <div class="bfe-head">
    <p class="bfe-eyebrow">Built for every role</p>
    <h2 class="bfe-title">Bolt is for <span>everyone</span></h2>
    <p class="bfe-sub">From the boardroom to the keyboard. Open the deck for your role — full screen, <kbd>Esc</kbd> to come back.</p>
  </div>

  <div class="bfe-strip-wrap">
    <button class="bfe-arrow l" type="button" data-dir="l" aria-label="Scroll left">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
    </button>
    <div class="bfe-strip">
      <div class="bfe-track">
        {loop.map((d, i) => (
          <button class="bfe-card" type="button" data-key={d.file.replace("persona-", "")} aria-label={`Open the ${d.tag} deck`} tabindex={i < decks.length ? 0 : -1}>
            <span class="bfe-ic">{d.icon}</span>
            <span class="bfe-tag">{d.tag}</span>
            <span class="bfe-name">{d.title}</span>
            <span class="bfe-open">Open deck →</span>
          </button>
        ))}
      </div>
    </div>
    <button class="bfe-arrow r" type="button" data-dir="r" aria-label="Scroll right">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
    </button>
  </div>
</section>

<!-- overlay backdrop blurs the live website; deck host is a real DOM node so
     backdrop-filter actually reaches through — no iframe compositing boundary -->
<div class="bfe-overlay" id="bfeOverlay" hidden>
  <button class="bfe-close" id="bfeClose" type="button" aria-label="Close deck (Esc)">&times;</button>
  <div class="bfe-deck-host" id="bfeDeckHost"></div>
</div>

<style>
  .bfe { padding: clamp(1.75rem, 3.5vw, 3rem) 0; text-align: center; overflow: hidden; width: 100%; align-self: stretch; }
  .bfe-head { max-width: 52ch; margin: 0 auto clamp(1.25rem, 2.5vw, 2rem); padding: 0 1.25rem; }
  .bfe-eyebrow { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--brand-primary); margin: 0 0 0.5rem; }
  .bfe-title { font-size: clamp(1.6rem, 3.2vw, 2.4rem); font-weight: 800; line-height: 1.1; letter-spacing: -0.02em; margin: 0; color: var(--text-heading); }
  .bfe-title span { color: var(--brand-primary); }
  .bfe-sub { color: var(--text-muted); font-size: clamp(0.95rem, 1.3vw, 1.08rem); margin: 0.6rem 0 0; line-height: 1.5; }
  .bfe-sub kbd { font: inherit; font-size: 0.85em; background: var(--brand-primary-light); border: 1px solid var(--border-default); border-radius: 5px; padding: 0.05em 0.4em; color: var(--brand-primary); }

  .bfe-strip { width: 100%; max-width: 100%; overflow-x: auto; overflow-y: hidden; padding: 0.5rem 0; -webkit-mask: linear-gradient(90deg, transparent, #000 5%, #000 95%, transparent); mask: linear-gradient(90deg, transparent, #000 5%, #000 95%, transparent); scrollbar-width: none; -ms-overflow-style: none; cursor: grab; }
  .bfe-strip::-webkit-scrollbar { display: none; }
  .bfe-strip.dragging { cursor: grabbing; }
  .bfe-track { display: flex; gap: 1rem; width: max-content; padding: 0 0.5rem; }

  .bfe-strip-wrap { position: relative; }
  .bfe-arrow { position: absolute; top: 50%; transform: translateY(-50%); z-index: 3; width: 40px; height: 40px; border-radius: var(--radius-full); display: flex; align-items: center; justify-content: center; background: var(--bg-surface-solid); border: 1px solid var(--border-default); color: var(--text-heading); cursor: pointer; box-shadow: 0 6px 18px rgba(10, 22, 48, 0.16); transition: border-color 0.15s, color 0.15s, transform 0.15s; }
  .bfe-arrow:hover { border-color: var(--brand-primary); color: var(--brand-primary); transform: translateY(-50%) scale(1.06); }
  .bfe-arrow.l { left: 8px; }
  .bfe-arrow.r { right: 8px; }
  .bfe-arrow svg { width: 20px; height: 20px; }
  @media (max-width: 640px) { .bfe-arrow { display: none; } }

  .bfe-card { flex: 0 0 248px; height: 192px; display: flex; flex-direction: column; align-items: flex-start; gap: 0.5rem; text-align: left; background: var(--bg-surface-solid); border: 1px solid var(--border-default); border-radius: var(--radius-lg); padding: 1.2rem 1.25rem; cursor: pointer; transition: transform 0.18s, border-color 0.18s, box-shadow 0.18s; position: relative; overflow: hidden; font-family: inherit; color: var(--text-body); box-shadow: 0 6px 20px rgba(10, 22, 48, 0.1); }
  .bfe-card::before { content: ""; position: absolute; inset: 0 0 auto 0; height: 3px; background: linear-gradient(90deg, var(--brand-primary), var(--brand-accent)); opacity: 0.9; transition: opacity 0.18s; }
  .bfe-card:hover { transform: translateY(-5px); border-color: var(--brand-primary); box-shadow: 0 22px 48px rgba(10, 22, 48, 0.22); }
  .bfe-card:hover::before { opacity: 1; }
  .bfe-card:focus-visible { outline: 2px solid var(--brand-primary); outline-offset: 2px; }
  .bfe-ic { display: flex; align-items: center; justify-content: center; width: 46px; height: 46px; border-radius: 12px; font-size: 1.55rem; line-height: 1; background: var(--brand-primary-light); box-shadow: inset 0 0 0 1px var(--brand-primary-light); }
  .bfe-tag { font-size: 0.67rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-muted); }
  .bfe-name { font-size: 1.1rem; font-weight: 700; line-height: 1.18; color: var(--text-heading); flex: 1; }
  .bfe-open { font-size: 0.8rem; font-weight: 600; color: var(--brand-primary); }

  /* Overlay blurs the live website behind it. The deck host is a real DOM element
     (not an iframe) so no compositing boundary — the blurred backdrop shows through
     transparent regions of the deck exactly as intended. */
  .bfe-overlay {
    position: fixed; inset: 0; z-index: 9999;
    display: flex; align-items: center; justify-content: center;
    padding: clamp(10px, 1.6vh, 22px);
    background: rgba(6, 10, 24, 0.38);
    -webkit-backdrop-filter: blur(24px) saturate(1.3);
    backdrop-filter: blur(24px) saturate(1.3);
  }
  .bfe-overlay[hidden] { display: none; }

  /* The shadow host fills the overlay and clips the deck at rounded corners */
  .bfe-deck-host {
    width: 100%; height: 100%;
    border-radius: 16px; overflow: hidden;
    box-shadow: 0 32px 80px rgba(0,0,0,0.48), 0 0 0 1px rgba(255,255,255,0.10);
  }

  .bfe-close { position: fixed; top: 14px; right: 18px; z-index: 10000; width: 42px; height: 42px; border-radius: 50%; border: 1px solid rgba(255,255,255,0.18); background: rgba(13,20,38,0.85); color: #f1f5f9; font-size: 1.6rem; line-height: 1; cursor: pointer; display: flex; align-items: center; justify-content: center; }
  .bfe-close:hover { border-color: var(--brand-accent); color: var(--brand-accent); }

  @media (max-width: 640px) { .bfe-card { flex-basis: 216px; height: 174px; } }
</style>

<script>
  // Inline SVGs — lucide.createIcons() can't scan shadow DOM
  const SVG_ICONS: Record<string, string> = {
    "chevron-left":  `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>`,
    "chevron-right": `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>`,
    "sun":  `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>`,
    "moon": `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"/></svg>`,
  };

  const FROST_CSS = `
    :host { display: block; width: 100%; height: 100%; font-family: 'Inter', system-ui, sans-serif; }
    /* deck fills the host — NOT 100vw/100dvh which would overflow the padded container */
    #deck { width: 100% !important; height: 100% !important; }
    /* light: semi-opaque so site shows through; cards stay near-solid for readability */
    #deck {
      --bg: rgba(235, 242, 255, 0.82);
      --s:  rgba(255, 255, 255, 0.96);
      --s2: rgba(240, 246, 255, 0.88);
      --b:  rgba(37,  99,  235, 0.16);
      --t:  #0b1220; --t2: #334155; --t3: #64748b;
      --a:  #2563eb; --a2: #1d4ed8; --g:  #166534;
      background: transparent !important;
    }
    #deck[data-theme="dark"] {
      --bg: rgba(6,  10,  22,  0.82);
      --s:  rgba(12, 18,  36,  0.96);
      --s2: rgba(16, 24,  46,  0.88);
      --b:  rgba(37, 99,  235, 0.20);
      --t:  #f1f5f9; --t2: #94a3b8; --t3: #64748b;
      --a:  #60a5fa; --a2: #93c5fd; --g:  #22d3a0;
    }
    #viewport { background: transparent !important; }
    /* accent panels fade their bg to transparent — restore a readable tinted surface */
    #deck .spanel.bolt {
      background: linear-gradient(180deg, rgba(37,99,235,0.10), rgba(255,255,255,0.94)) !important;
    }
    #deck[data-theme="dark"] .spanel.bolt {
      background: linear-gradient(180deg, rgba(37,99,235,0.16), rgba(12,18,36,0.94)) !important;
    }
    #bar {
      background: rgba(230, 238, 255, 0.92) !important;
      border-top: 1px solid rgba(160, 190, 240, 0.35) !important;
      -webkit-backdrop-filter: blur(12px); backdrop-filter: blur(12px);
    }
    #deck[data-theme="dark"] #bar {
      background: rgba(5, 9, 20, 0.92) !important;
      border-top: 1px solid rgba(255,255,255,0.08) !important;
    }
    #bar button svg { display: block; }
  `;

  const overlay  = document.getElementById("bfeOverlay")  as HTMLElement | null;
  const deckHost = document.getElementById("bfeDeckHost") as HTMLElement | null;
  const closeBtn = document.getElementById("bfeClose");

  if (overlay && deckHost) {
    const siteTheme = () =>
      document.documentElement.getAttribute("data-theme") || "light";

    const sync = (key: string, slide: number) =>
      history.replaceState(null, "", `#deck=${key}&slide=${slide}`);

    let current = "";
    // Navigation handle for the open deck, so the global keydown can drive it.
    let deckNav: { next: () => void; prev: () => void; first: () => void; last: () => void } | null = null;

    // Load the self-hosted lucide once (CSP allows /decks/lucide.min.js as 'self'),
    // then run cb. Used to render deck content icons inside the shadow root.
    const withLucide = (cb: () => void) => {
      if ((window as any).lucide) { cb(); return; }
      let s = document.getElementById("bfe-lucide") as HTMLScriptElement | null;
      if (!s) {
        s = document.createElement("script");
        s.id = "bfe-lucide";
        s.src = "/decks/lucide.min.js";
        document.head.appendChild(s);
      }
      s.addEventListener("load", () => cb(), { once: true });
    };

    async function openDeck(key: string, startSlide = 0) {
      current = key;
      overlay!.hidden = false;
      document.body.style.overflow = "hidden";
      sync(key, startSlide);

      // Fetch + parse the deck HTML
      const res  = await fetch(`/decks/persona-${key}.html`);
      const html = await res.text();
      const dp   = new DOMParser();
      const ddoc = dp.parseFromString(html, "text/html");

      // Build/clear shadow root on the host element
      const shadow = deckHost!.shadowRoot ?? deckHost!.attachShadow({ mode: "open" });
      shadow.innerHTML = "";

      // Inject deck CSS + our frosted-glass overrides
      const deckCSS = Array.from(ddoc.querySelectorAll("style"))
        .map((s) => s.textContent).join("\n");
      const st = document.createElement("style");
      st.textContent = deckCSS + "\n" + FROST_CSS;
      shadow.appendChild(st);

      // Inject deck body HTML
      const body = document.createElement("div");
      body.style.cssText = "display:contents";
      body.innerHTML = ddoc.body.innerHTML;
      shadow.appendChild(body);

      // Replace [data-lucide] elements with inline SVG (createIcons can't see shadow DOM)
      shadow.querySelectorAll<HTMLElement>("[data-lucide]").forEach((el) => {
        const name = el.getAttribute("data-lucide") ?? "";
        if (SVG_ICONS[name]) { el.innerHTML = SVG_ICONS[name]; el.removeAttribute("data-lucide"); }
      });

      // Set initial theme on #deck before running the script
      const deckEl = shadow.getElementById("deck");
      deckEl?.setAttribute("data-theme", siteTheme());

      // Native slide navigation. The deck ships an inline <script> that drives
      // this, but production CSP forbids unsafe-eval — so we can't run it. The
      // logic is identical across every deck, so we reimplement it here against
      // the shadow root (CSP-safe: this code is bundled as 'self').
      const slidesEls = shadow.querySelectorAll<HTMLElement>(".slide");
      const total = slidesEls.length;
      const counter = shadow.getElementById("counter");
      let idx = startSlide;
      const show = (n: number) => {
        idx = Math.max(0, Math.min(total - 1, n));
        slidesEls.forEach((s, k) => s.classList.toggle("active", k === idx));
        if (counter) counter.textContent = `${idx + 1} / ${total}`;
        sync(key, idx);
      };
      shadow.getElementById("next")?.addEventListener("click", () => show(idx + 1));
      shadow.getElementById("prev")?.addEventListener("click", () => show(idx - 1));
      deckNav = {
        next: () => show(idx + 1),
        prev: () => show(idx - 1),
        first: () => show(0),
        last: () => show(total - 1),
      };
      show(startSlide);

      // Theme button toggles the site theme; MutationObserver mirrors it back in.
      const themeBtn = shadow.getElementById("theme");
      if (themeBtn) {
        themeBtn.addEventListener("click", () => {
          const next = siteTheme() === "dark" ? "light" : "dark";
          document.documentElement.setAttribute("data-theme", next);
        });
      }
      new MutationObserver(() => {
        shadow.getElementById("deck")?.setAttribute("data-theme", siteTheme());
      }).observe(document.documentElement, {
        attributes: true,
        attributeFilter: ["data-theme"],
      });

      // Render the deck's content icons via the self-hosted lucide (CSP 'self').
      // Our inline SVGs already cover the nav icons; this fills in the rest.
      withLucide(() => {
        try {
          (window as any).lucide?.createIcons({ node: shadow.getElementById("deck") });
        } catch { /* non-fatal — inline nav SVGs still render */ }
      });
    }

    function closeDeck() {
      if (overlay!.hidden) return;
      current = "";
      overlay!.hidden = true;
      document.body.style.overflow = "";
      history.replaceState(null, "", location.pathname + location.search);
    }

    document.querySelectorAll<HTMLElement>(".bfe-card").forEach((card) => {
      card.addEventListener("click", () => {
        const k = card.dataset.key;
        if (k) openDeck(k);
      });
    });

    closeBtn?.addEventListener("click", closeDeck);
    window.addEventListener("keydown", (e) => {
      if (overlay!.hidden) return;
      if (e.key === "Escape") { closeDeck(); return; }
      if (!deckNav) return;
      if (e.key === "ArrowRight" || e.key === " ") { deckNav.next(); e.preventDefault(); }
      else if (e.key === "ArrowLeft") { deckNav.prev(); }
      else if (e.key === "Home") { deckNav.first(); }
      else if (e.key === "End") { deckNav.last(); }
    });

    // Deep-link: #deck=<key>&slide=<n>
    const route = () => {
      const p = new URLSearchParams(location.hash.replace(/^#/, ""));
      const k = p.get("deck");
      if (k && k !== current)
        openDeck(k, parseInt(p.get("slide") || "0") || 0);
      else if (!k && !overlay.hidden) closeDeck();
    };
    route();
    window.addEventListener("hashchange", route);
  }

  // ── auto-scroll marquee ──────────────────────────────────────────────────────
  const strip = document.querySelector<HTMLElement>(".bfe-strip");
  const track = strip?.querySelector<HTMLElement>(".bfe-track");
  if (strip && track) {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let overWrap = false, stepping = false, stepT: ReturnType<typeof setTimeout>;
    const half = () => track.scrollWidth / 2;
    const wrap = () => {
      const h = half();
      if (strip.scrollLeft >= h) strip.scrollLeft -= h;
      else if (strip.scrollLeft <= 0) strip.scrollLeft += h;
    };
    const tick = () => {
      if (!reduce && !overWrap && !stepping) { strip.scrollLeft += 0.75; wrap(); }
      requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);

    strip.addEventListener("mouseenter", () => { overWrap = true; });
    strip.addEventListener("mouseleave", () => { overWrap = false; });
    strip.addEventListener("wheel", (e: WheelEvent) => {
      const d = Math.abs(e.deltaX) > Math.abs(e.deltaY) ? e.deltaX : e.deltaY;
      if (d !== 0) { strip.scrollLeft += d; wrap(); e.preventDefault(); }
    }, { passive: false });

    let down = false, startX = 0, startLeft = 0, moved = 0;
    strip.addEventListener("pointerdown", (e: PointerEvent) => {
      down = true; moved = 0; startX = e.pageX; startLeft = strip.scrollLeft;
      strip.classList.add("dragging");
    });
    strip.addEventListener("pointermove", (e: PointerEvent) => {
      if (!down) return;
      const dx = e.pageX - startX; moved += Math.abs(dx);
      strip.scrollLeft = startLeft - dx; wrap();
    });
    const endDrag = () => { down = false; strip.classList.remove("dragging"); };
    strip.addEventListener("pointerup", endDrag);
    strip.addEventListener("pointerleave", endDrag);
    strip.addEventListener("click", (e) => {
      if (moved > 6) { e.stopPropagation(); e.preventDefault(); }
    }, true);

    const step = () =>
      (track.querySelector<HTMLElement>(".bfe-card")?.offsetWidth ?? 248) + 16;
    document.querySelectorAll<HTMLElement>(".bfe-arrow").forEach((btn) => {
      btn.addEventListener("mouseenter", () => { overWrap = true; });
      btn.addEventListener("mouseleave", () => { overWrap = false; });
      btn.addEventListener("click", () => {
        wrap();
        const dir = btn.dataset.dir === "l" ? -1 : 1;
        stepping = true;
        clearTimeout(stepT);
        stepT = setTimeout(() => { stepping = false; }, 550);
        strip.scrollBy({ left: dir * step(), behavior: "smooth" });
      });
    });
  }
</script>
