---
// Premium pass: /products.html is the canonical Bolt product page.
// Aeira lives at /products/aeira.html as its own canonical URL. Each
// product gets its own dedicated page with no tab switcher — "two
// products, both serious" positioning. The dual-content rendering
// path is retained in the component but is no longer wired by the
// public site.
import ProductPageTemplate from "../components/marketing/ProductPageTemplate.astro";
import { boltProductContent } from "../data/offerings";
---

<ProductPageTemplate content={boltProductContent}>
  <link slot="head" rel="stylesheet" href="/css/trust-callout.css" />

    <aside slot="afterHero" class="trust-callout" aria-label="Trust dossier">
      <div class="trust-callout__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
        </svg>
      </div>
      <div class="trust-callout__body">
        <h3 class="trust-callout__title">Reading this for security review?</h3>
        <p class="trust-callout__lede">
          The complete trust dossier &mdash; sub-processor disclosure, controls evidence map, cryptographic-erasure whitepaper, standalone audit-chain verifier, incident-response framework, and vulnerability disclosure policy &mdash; lives at the Trust Center.
        </p>
        <a href="/trust" class="trust-callout__cta">
          Browse the Trust Center &nearr;
        </a>
      </div>
    </aside>
</ProductPageTemplate>
