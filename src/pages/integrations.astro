---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/ui/Hero.astro";
import PageSection from "../components/ui/PageSection.astro";
import Prose from "../components/ui/Prose.astro";
import CTAStrip from "../components/ui/CTAStrip.astro";

// Integration catalog. Built on the open Model Context Protocol: customer
// can run any compliant MCP server, including their own. Logos withheld
// (vendor brand-guidelines vary); page uses category + name to keep
// everything legally clean. Ship with what's accurate today; add as
// integrations actually ship.
const categories = [
  {
    name: "Identity & Access",
    icon: "shield",
    blurb: "Single sign-on, group membership, and access policy resolution.",
    items: [
      { name: "Microsoft Entra ID (Azure AD)", note: "OIDC + SAML + group sync" },
      { name: "Okta", note: "OIDC + SAML + SCIM" },
      { name: "Google Workspace", note: "OIDC + Cloud Identity" },
      { name: "Zoho Directory", note: "OIDC" },
      { name: "Generic OIDC / SAML", note: "Bring your own IdP" },
      { name: "JWT / API tokens", note: "Service-to-service" },
    ],
  },
  {
    name: "Productivity & Collaboration",
    icon: "layers",
    blurb: "Email, calendar, docs, and team chat, read and act with consent.",
    items: [
      { name: "Microsoft 365 (Outlook + Calendar)" }, { name: "Microsoft Teams" },
      { name: "Microsoft OneDrive" }, { name: "Microsoft SharePoint" },
      { name: "Google Gmail" }, { name: "Google Calendar" }, { name: "Google Drive" },
      { name: "Google Docs / Sheets / Slides" },
      { name: "Slack" }, { name: "Discord" },
      { name: "Zoom (meetings + recordings)" }, { name: "Cisco Webex" },
      { name: "Notion" }, { name: "Confluence (Atlassian)" },
      { name: "Coda" }, { name: "Quip" },
    ],
  },
  {
    name: "Engineering & DevOps",
    icon: "code",
    blurb: "Source, builds, issues, and ops, connected at the service level.",
    items: [
      { name: "GitHub" }, { name: "GitLab" }, { name: "Bitbucket" },
      { name: "Jira (Atlassian)" }, { name: "Linear" }, { name: "Asana" },
      { name: "ClickUp" }, { name: "Trello" },
      { name: "Sentry" }, { name: "Datadog" }, { name: "PagerDuty" },
      { name: "Grafana" }, { name: "AWS CloudWatch" }, { name: "Azure Monitor" },
    ],
  },
  {
    name: "Sales & CRM",
    icon: "trending-up",
    blurb: "Pipeline, contacts, and revenue ops without copy-paste between tools.",
    items: [
      { name: "Salesforce" }, { name: "HubSpot" }, { name: "Microsoft Dynamics 365" },
      { name: "Zoho CRM" }, { name: "Pipedrive" }, { name: "Outreach" },
      { name: "Salesloft" }, { name: "Gong" },
    ],
  },
  {
    name: "ITSM & Support",
    icon: "scale",
    blurb: "Tickets, incidents, and customer support, read and respond with policy controls.",
    items: [
      { name: "ServiceNow" }, { name: "Zendesk" }, { name: "Freshdesk" },
      { name: "Intercom" }, { name: "Jira Service Management" },
      { name: "Salesforce Service Cloud" },
    ],
  },
  {
    name: "Knowledge & Search",
    icon: "database",
    blurb: "Internal wikis, knowledge bases, and document repositories.",
    items: [
      { name: "Aeira (built-in)", note: "Compliance-grade search" },
      { name: "Confluence (read)" }, { name: "SharePoint (read)" },
      { name: "Notion (read)" }, { name: "Glean", note: "Federated query" },
      { name: "Elastic / OpenSearch" }, { name: "Algolia" },
    ],
  },
  {
    name: "Data Warehouses & BI",
    icon: "server",
    blurb: "Read structured business data with row-level access controls.",
    items: [
      { name: "Snowflake" }, { name: "Databricks" }, { name: "Google BigQuery" },
      { name: "Amazon Redshift" }, { name: "PostgreSQL" }, { name: "Tableau" },
      { name: "Looker" }, { name: "Power BI" },
    ],
  },
  {
    name: "Storage & Files",
    icon: "monitor",
    blurb: "Document stores and file systems, local + cloud.",
    items: [
      { name: "Box" }, { name: "Dropbox" }, { name: "AWS S3" },
      { name: "Azure Blob Storage" }, { name: "Google Cloud Storage" },
      { name: "Local filesystem (Bolt Native)" },
    ],
  },
  {
    name: "LLM Providers (BYO)",
    icon: "lock",
    blurb: "Hot-swappable inference layer. BYOK for zero token markup.",
    items: [
      { name: "OpenAI" }, { name: "Anthropic Claude" }, { name: "AWS Bedrock" },
      { name: "Google Vertex AI" }, { name: "Azure OpenAI" }, { name: "NVIDIA NIM" },
      { name: "Ollama (local)" }, { name: "vLLM (self-hosted)" },
      { name: "Your own fine-tuned model" },
    ],
  },
];

const iconPaths: Record<string, string> = {
  "layers": '<path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>',
  "shield": '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  "server": '<rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>',
  "trending-up": '<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>',
  "database": '<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>',
  "code": '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  "lock": '<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
  "scale": '<path d="M16 3h5v5"/><path d="M8 3H3v5"/><path d="M21 3l-8.5 8.5"/><path d="M3 3l8.5 8.5"/><path d="M3 21l8.5-8.5"/><path d="M21 21l-8.5-8.5"/>',
  "monitor": '<rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>',
};
---
<BaseLayout
  title="Integrations: 100+ Enterprise Systems via Open MCP Protocol | Sparcle"
  description="Bolt connects to identity (Okta, Entra, Workspace, Zoho), productivity, engineering, sales, ITSM, knowledge, data warehouse, and LLM providers via the Model Context Protocol. BYO MCP servers welcome."
  canonical="https://sparcle.app/integrations/"
>
  <main class="page-integrations">
    <Hero
      eyebrow="Integrations"
      title="Connected to the work your team already does."
      lede={`Bolt connects to <strong>100+</strong> enterprise systems via the open <a href="https://modelcontextprotocol.io" target="_blank" rel="noopener">Model Context Protocol</a>. 103 in-house connectors, ~350 more via Airbyte, and any MCP-compliant server. No proprietary APIs, no vendor lock-in. Bring your own MCP servers and they slot in alongside ours.`}
    >
      <a href="#" onclick="openContactModal('Custom Integration Request'); return false;" class="btn btn-primary btn-lg">
        Request Custom Integration
      </a>
      <a href="#categories" class="btn btn-secondary btn-lg">Browse Categories &darr;</a>
    </Hero>

    <PageSection
      eyebrow="Topology"
      title="One MCP fabric. Everything attaches."
      lede="Your users sit in front of Bolt; Bolt and Aeira sit inside your perimeter; the systems your team already uses attach over the open Model Context Protocol. The LLM endpoint is the only piece you can configure outside the perimeter, and which mode it runs in is your choice."
      stripe="b"
    >
      <div class="ints-diagram" data-expandable tabindex="0" role="button" aria-label="Expand integration topology diagram">
        <svg viewBox="0 0 920 540" class="ints-topology-svg" role="img" aria-labelledby="ints-topology-title ints-topology-desc">
          <title id="ints-topology-title">Sparcle integration topology</title>
          <desc id="ints-topology-desc">Users connect to Bolt and Aeira running inside the customer perimeter. Bolt and Aeira attach to nine categories of customer-owned systems via the open Model Context Protocol: identity, productivity, engineering, sales and CRM, ITSM, knowledge, data warehouses, storage, and LLM providers. The LLM endpoint is the only attachment point that can sit outside the perimeter.</desc>

          <defs>
            <marker id="i-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
              <path class="i-arrow-head" d="M0,0 L10,5 L0,10 z" />
            </marker>
          </defs>

          <style>
            .i-perimeter { fill: none; stroke: var(--text-muted); stroke-width: 1.5; stroke-dasharray: 8 5; opacity: 0.55; }
            .i-perimeter-label { font: 700 11px var(--font-sans, system-ui); fill: var(--text-muted); letter-spacing: 0.12em; }
            .i-platform { fill: var(--brand-primary-light); stroke: var(--brand-primary); stroke-width: 2; }
            .i-user { fill: var(--bg-surface-solid); stroke: var(--text-muted); stroke-width: 1.5; }
            .i-mcp-band { fill: var(--bg-surface-solid); stroke: var(--brand-primary); stroke-width: 1; stroke-dasharray: 4 3; opacity: 0.9; }
            .i-chip { fill: var(--bg-surface-solid); stroke: var(--brand-primary); stroke-width: 1.2; }
            .i-llm-chip { fill: var(--bg-surface-solid); stroke: var(--text-muted); stroke-width: 1.5; stroke-dasharray: 5 3; }
            .i-cat-name { font: 700 12px var(--font-sans, system-ui); fill: var(--text-heading); }
            .i-cat-items { font: 500 10.5px var(--font-sans, system-ui); fill: var(--text-muted); }
            .i-platform-label { font: 700 16px var(--font-sans, system-ui); fill: var(--brand-primary); text-anchor: middle; }
            .i-platform-sub { font: 500 11.5px var(--font-sans, system-ui); fill: var(--text-body); text-anchor: middle; }
            .i-mcp-label { font: 700 11px var(--font-sans, system-ui); fill: var(--brand-primary); text-anchor: middle; letter-spacing: 0.12em; }
            .i-user-label { font: 700 13px var(--font-sans, system-ui); fill: var(--text-heading); text-anchor: middle; }
            .i-user-sub { font: 500 10.5px var(--font-sans, system-ui); fill: var(--text-muted); text-anchor: middle; }
            .i-flow { fill: none; stroke: var(--brand-primary); stroke-width: 1.8; }
            .i-flow-soft { fill: none; stroke: var(--text-muted); stroke-width: 1.2; opacity: 0.55; }
            .i-arrow-head { fill: var(--brand-primary); }
            .i-annotation { font: italic 10px var(--font-sans, system-ui); fill: var(--text-muted); text-anchor: middle; }
          </style>

          <rect class="i-perimeter" x="120" y="30" width="780" height="430" rx="14" />
          <text class="i-perimeter-label" x="136" y="20">CUSTOMER PERIMETER</text>

          <rect class="i-user" x="20" y="220" width="80" height="60" rx="8" />
          <text class="i-user-label" x="60" y="244">Users</text>
          <text class="i-user-sub" x="60" y="263">your team</text>

          <path class="i-flow" d="M105 250 L165 250" marker-end="url(#i-arrow)" />

          <rect class="i-platform" x="170" y="180" width="190" height="140" rx="12" />
          <text class="i-platform-label" x="265" y="218">Bolt + Aeira</text>
          <text class="i-platform-sub" x="265" y="240">runtime &middot; data plane</text>
          <text class="i-platform-sub" x="265" y="258">identity-bound retrieval</text>
          <text class="i-platform-sub" x="265" y="276">PII masking</text>
          <text class="i-platform-sub" x="265" y="294">audit chain</text>

          <rect class="i-mcp-band" x="385" y="220" width="140" height="60" rx="6" />
          <text class="i-mcp-label" x="455" y="244">MCP</text>
          <text class="i-cat-items" x="455" y="264" text-anchor="middle">open protocol</text>

          <path class="i-flow" d="M360 250 L385 250" />
          <path class="i-flow" d="M525 250 L555 250" marker-end="url(#i-arrow)" />

          <rect class="i-chip" x="560" y="65" width="170" height="58" rx="6" />
          <text class="i-cat-name" x="572" y="84">Identity</text>
          <text class="i-cat-items" x="572" y="103">Entra · Okta · Workspace</text>
          <text class="i-cat-items" x="572" y="117">Zoho · OIDC · SAML</text>

          <rect class="i-chip" x="740" y="65" width="155" height="58" rx="6" />
          <text class="i-cat-name" x="752" y="84">Productivity</text>
          <text class="i-cat-items" x="752" y="103">M365 · Google · Slack</text>
          <text class="i-cat-items" x="752" y="117">Teams · Notion · Zoom</text>

          <rect class="i-chip" x="560" y="135" width="170" height="58" rx="6" />
          <text class="i-cat-name" x="572" y="154">Engineering</text>
          <text class="i-cat-items" x="572" y="173">GitHub · GitLab · Jira</text>
          <text class="i-cat-items" x="572" y="187">Linear · Sentry · Datadog</text>

          <rect class="i-chip" x="740" y="135" width="155" height="58" rx="6" />
          <text class="i-cat-name" x="752" y="154">Sales / CRM</text>
          <text class="i-cat-items" x="752" y="173">Salesforce · HubSpot</text>
          <text class="i-cat-items" x="752" y="187">Dynamics · Gong</text>

          <rect class="i-chip" x="560" y="205" width="170" height="58" rx="6" />
          <text class="i-cat-name" x="572" y="224">ITSM &amp; Support</text>
          <text class="i-cat-items" x="572" y="243">ServiceNow · Zendesk</text>
          <text class="i-cat-items" x="572" y="257">Freshdesk · Intercom</text>

          <rect class="i-chip" x="740" y="205" width="155" height="58" rx="6" />
          <text class="i-cat-name" x="752" y="224">Knowledge</text>
          <text class="i-cat-items" x="752" y="243">Aeira · Confluence</text>
          <text class="i-cat-items" x="752" y="257">SharePoint · Glean · Elastic</text>

          <rect class="i-chip" x="560" y="275" width="170" height="58" rx="6" />
          <text class="i-cat-name" x="572" y="294">Warehouses &amp; BI</text>
          <text class="i-cat-items" x="572" y="313">Snowflake · Databricks</text>
          <text class="i-cat-items" x="572" y="327">BigQuery · Tableau · Power BI</text>

          <rect class="i-chip" x="740" y="275" width="155" height="58" rx="6" />
          <text class="i-cat-name" x="752" y="294">Storage</text>
          <text class="i-cat-items" x="752" y="313">Box · Dropbox · S3</text>
          <text class="i-cat-items" x="752" y="327">Azure Blob · GCS</text>

          <rect class="i-llm-chip" x="560" y="345" width="335" height="58" rx="6" />
          <text class="i-cat-name" x="572" y="364">LLM providers (BYO)</text>
          <text class="i-cat-items" x="572" y="383">OpenAI · Anthropic · Bedrock · Vertex · Azure OpenAI</text>
          <text class="i-cat-items" x="572" y="397">NVIDIA NIM · Ollama · vLLM · your own model</text>

          <text class="i-annotation" x="265" y="345">all attachments via MCP</text>
          <text class="i-annotation" x="265" y="360">no proprietary APIs</text>
          <text class="i-annotation" x="265" y="375">customer-owned credentials</text>

          <text class="i-annotation" x="455" y="490">LLM endpoint is the only attachment that may sit outside the perimeter; see /trust/where-the-model-runs</text>
        </svg>
      </div>
    </PageSection>

    <a id="categories" class="anchor" aria-hidden="true"></a>

    <PageSection stripe="a">
      <div class="ints-list">
        {categories.map((cat) => (
          <div class="ints-category">
            <header class="ints-cat-header">
              <div class="ints-cat-icon" set:html={`<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${iconPaths[cat.icon] || ''}</svg>`} />
              <div>
                <h3>{cat.name}</h3>
                <p>{cat.blurb}</p>
              </div>
            </header>
            <ul class="ints-grid">
              {cat.items.map((item) => (
                <li class="int-chip">
                  <span class="int-name">{item.name}</span>
                  {item.note && <span class="int-note">{item.note}</span>}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </PageSection>

    <PageSection
      eyebrow="Bring your own"
      title="Don't see your system? Bring it."
      stripe="b"
      width="prose"
    >
      <Prose align="center">
        <p>
          The Model Context Protocol is open. Any MCP-compliant server slots in alongside Bolt's
          built-in integrations, including custom-built connectors for your internal systems.
          Sparcle ships connector SDKs in TypeScript and Python; the protocol itself is
          language-agnostic.
        </p>
        <p>
          For enterprise contracts, we offer <strong>custom MCP connector development</strong> as
          a professional service, typically 1–3 weeks per system depending on auth complexity
          and the surface area you need exposed.
        </p>
      </Prose>
    </PageSection>

    <CTAStrip
      variant="band"
      title="Ready to connect your stack?"
      lede="Schedule a 30-minute walkthrough. We'll cover which integrations are most relevant for your environment and what custom development (if any) you'd want during pilot."
    >
      <a href="#" onclick="openContactModal('Architecture Review'); return false;" class="btn btn-primary btn-lg">
        Schedule Architecture Review
      </a>
      <a href="/architecture" class="btn btn-secondary btn-lg">How Bolt is built &rarr;</a>
    </CTAStrip>
  </main>
</BaseLayout>

<style is:global>
  .anchor {
    display: block;
    height: 1px;
    margin-top: calc(var(--nav-height, 80px) * -1);
    padding-top: var(--nav-height, 80px);
    visibility: hidden;
  }

  /* Topology diagram container: same visual grammar as the other six
     SVGs on the site (where-the-model-runs, cryptographic-erasure,
     solution, architecture x3). Theme-tracks via CSS vars embedded in
     the SVG. */
  .page-integrations .ints-diagram {
    background: var(--bg-surface-solid);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    padding: 1.5rem 1.75rem;
    max-width: 960px;
    margin: 0 auto;
  }
  .page-integrations .ints-topology-svg {
    display: block;
    width: 100%;
    height: auto;
    max-width: 920px;
    margin: 0 auto;
  }

  .ints-list {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }
  .ints-category {
    border-top: 1px solid var(--border-subtle);
    padding-top: 2rem;
  }
  .ints-category:first-child {
    border-top: none;
    padding-top: 0;
  }
  .ints-cat-header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }
  .ints-cat-icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    background: var(--brand-primary-light);
    color: var(--brand-primary);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ints-cat-header h3 {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--text-heading);
    margin: 0 0 0.4rem;
    font-family: var(--font-display);
    letter-spacing: -0.01em;
  }
  .ints-cat-header p {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.5;
  }
  .ints-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 0.6rem;
  }
  .int-chip {
    background: var(--bg-surface-solid);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    padding: 0.75rem 0.95rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    transition: border-color var(--transition-fast);
  }
  .int-chip:hover {
    border-color: var(--brand-primary-light);
  }
  .int-name {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--text-heading);
  }
  .int-note {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  @media (max-width: 600px) {
    .ints-cat-header {
      flex-direction: column;
      gap: 0.75rem;
    }
  }
</style>
