---
import BaseLayout from "../../layouts/BaseLayout.astro";
import type { ProductPageContent } from "../../data/offerings";

interface Props {
  content: ProductPageContent;
  secondContent?: ProductPageContent;
  activeProduct?: string;
}

const { content, secondContent, activeProduct } = Astro.props;
const hasDual = !!secondContent;
const isSecondActive = activeProduct === 'second';

/* Icon SVG map – Feather-style 24×24 paths */
const iconPaths: Record<string, string> = {
  "layers":      '<path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>',
  "shield":      '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  "server":      '<rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>',
  "trending-up": '<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>',
  "database":    '<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>',
  "code":        '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  "lock":        '<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
  "scale":       '<path d="M16 3h5v5"/><path d="M8 3H3v5"/><path d="M21 3l-8.5 8.5"/><path d="M3 3l8.5 8.5"/><path d="M3 21l8.5-8.5"/><path d="M21 21l-8.5-8.5"/>',
  "monitor":     '<rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>',
  "mail":        '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>',
  "calendar":    '<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>',
  "check-square":'<polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>',
  "smartphone":  '<rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/>',
  "shuffle":     '<polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/>',
  "dollar-sign": '<line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>',
};

const productLogos: Record<string, string> = {
  "Bolt": "/images/bolt-logo.svg",
  "Aeira": "/images/aeira-logo.svg",
};

function renderIcon(iconId: string | undefined): string {
  if (!iconId || !iconPaths[iconId]) return '';
  return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${iconPaths[iconId]}</svg>`;
}
---

<BaseLayout
  title={hasDual ? "Products | Sparcle" : content.title}
  description={hasDual ? "Bolt and Aeira — two products, one vision for enterprise AI." : content.description}
  canonical={content.canonical}
>
  <main class="offering-page" aria-labelledby="offering-title">

    {hasDual && (
      <div class="product-tab-float">
        <div class="product-tab-switch" role="tablist" aria-label="Product">
          <button class={`product-tab ${!isSecondActive ? 'active' : ''}`} data-target="product-section-1" role="tab" aria-selected={!isSecondActive ? "true" : "false"} onclick="switchProductPage(this)"><img src={productLogos[content.productName] || "/images/sparkle-icon.svg"} alt="" class="tab-icon" width="18" height="18" />{content.productName}</button>
          <button class={`product-tab ${isSecondActive ? 'active' : ''}`} data-target="product-section-2" role="tab" aria-selected={isSecondActive ? "true" : "false"} onclick="switchProductPage(this)"><img src={productLogos[secondContent!.productName] || "/images/sparkle-icon.svg"} alt="" class="tab-icon" width="18" height="18" />{secondContent!.productName}</button>
        </div>
      </div>
    )}

    <!-- ── Product 1 ── -->
    <div id="product-section-1" class={`product-section ${!isSecondActive ? 'active' : ''}`}>
      <section class="offering-hero">
        <div class="container">
          <div class="offering-hero-header">
            <img src={productLogos[content.productName] || "/images/sparkle-icon.svg"} alt={`${content.productName} logo`} class="product-logo" width="56" height="56" />
            <div>
              <p class="eyebrow">{content.productKicker}</p>
            </div>
          </div>
          <h1 id="offering-title">{content.productHeadline}</h1>
          <p class="offering-intro">{content.productIntro}</p>

          {content.videoUrl && (
            <div class="product-video-wrap" style="margin-bottom: 2rem;">
              <video controls playsinline preload="metadata">
                <source src={content.videoUrl} type="video/mp4" />
                Your browser does not support the video element.
              </video>
            </div>
          )}

          {content.slidesUrl && (
            <>
              <div class="product-slides-wrap">
                <iframe src={content.slidesUrl} loading="lazy" title={`${content.productName} Slides`}></iframe>
              </div>
              <a class="product-slides-link" href={content.slidesUrl} target="_blank" rel="noopener">Open full slides ↗</a>
            </>
          )}

          <div class="hero-actions">
            <a class="btn btn-primary btn-lg" href={content.primaryCtaHref}>{content.primaryCtaLabel}</a>
            <a class="btn btn-secondary btn-lg" href={content.secondaryCtaHref}>{content.secondaryCtaLabel}</a>
            {content.tertiaryCtaLabel && (
              <a class="btn btn-secondary btn-lg" href={content.tertiaryCtaHref} target={content.tertiaryCtaTarget || "_self"}>{content.tertiaryCtaLabel}</a>
            )}
          </div>
        </div>
      </section>

      {content.architectureHtml && (
        <section class="offering-architecture" aria-label={`${content.productName} architecture`}>
          <div class="container">
            <Fragment set:html={content.architectureHtml} />
          </div>
        </section>
      )}

      <section class={`offering-highlights offering-highlights-${content.productName.toLowerCase()}`} aria-label={`${content.productName} highlights`}>
        <div class="container">
          <div class="section-title-wrap">
            <h2>Why {content.productName}</h2>
            <p>Core capabilities that drive measurable enterprise impact.</p>
          </div>
          <div class="card-grid">
            {content.highlights.map((point) => (
              <article class="feature-card">
                <div class="feature-card-header">
                  <div class="feature-icon" set:html={renderIcon(point.icon)} />
                  <h3>{point.title}</h3>
                </div>
                <p>{point.detail}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      {content.agenticActions && content.agenticActions.length > 0 && (
        <section class="offering-agentic" aria-label={`${content.productName} agentic capabilities`}>
          <div class="container">
            <div class="section-title-wrap">
              <p class="eyebrow">Agentic Desktop Agent</p>
              <h2>{content.productName} doesn't just answer. <em>It takes action.</em></h2>
              <p>Most AI assistants stop at "here's what I found." {content.productName} reads, writes, and executes across your entire stack &mdash; from email to your local file system.</p>
            </div>
            <div class="card-grid">
              {content.agenticActions.map((action) => (
                <article class="feature-card">
                  <div class="feature-card-header">
                    <div class="feature-icon" set:html={renderIcon(action.icon)} />
                    <h3>{action.title}</h3>
                  </div>
                  <p>{action.detail}</p>
                </article>
              ))}
            </div>            
          </div>
        </section>
      )}

      <section class="offering-faq" aria-label={`${content.productName} questions`}>
        <div class="container">
          <div class="faq-section">
            <div class="section-title">
              <h2>Questions?</h2>
            </div>
            <div class="faq-grid">
              {content.faqs.map((item) => (
                <div class="faq-item">
                  <h3>{item.title}</h3>
                  <p>{item.detail}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>
    </div>

    <!-- ── Product 2 ── -->
    {secondContent && (
      <div id="product-section-2" class={`product-section ${isSecondActive ? 'active' : ''}`}>
        <section class="offering-hero">
          <div class="container">
            <div class="offering-hero-header">
              <img src={productLogos[secondContent.productName] || "/images/sparkle-icon.svg"} alt={`${secondContent.productName} logo`} class="product-logo" width="56" height="56" />
              <div>
                <p class="eyebrow">{secondContent.productKicker}</p>
              </div>
            </div>
            <h1>{secondContent.productHeadline}</h1>
            <p class="offering-intro">{secondContent.productIntro}</p>

            {secondContent.videoUrl && (
              <div class="product-video-wrap" style="margin-bottom: 2rem;">
                <video controls playsinline preload="metadata">
                  <source src={secondContent.videoUrl} type="video/mp4" />
                  Your browser does not support the video element.
                </video>
              </div>
            )}

            {secondContent.slidesUrl && (
              <>
                <div class="product-slides-wrap">
                  <iframe src={secondContent.slidesUrl} loading="lazy" title={`${secondContent.productName} Slides`}></iframe>
                </div>
                <a class="product-slides-link" href={secondContent.slidesUrl} target="_blank" rel="noopener">Open full slides ↗</a>
              </>
            )}

            <div class="hero-actions">
              <a class="btn btn-primary btn-lg" href={secondContent.primaryCtaHref}>{secondContent.primaryCtaLabel}</a>
              <a class="btn btn-secondary btn-lg" href={secondContent.secondaryCtaHref}>{secondContent.secondaryCtaLabel}</a>
              {secondContent.tertiaryCtaLabel && (
                <a class="btn btn-secondary btn-lg" href={secondContent.tertiaryCtaHref} target={secondContent.tertiaryCtaTarget || "_self"}>{secondContent.tertiaryCtaLabel}</a>
              )}
            </div>
          </div>
        </section>

        {secondContent.architectureHtml && (
          <section class="offering-architecture" aria-label={`${secondContent.productName} architecture`}>
            <div class="container">
              <Fragment set:html={secondContent.architectureHtml} />
            </div>
          </section>
        )}

        <section class="offering-highlights" aria-label={`${secondContent.productName} highlights`}>
          <div class="container">
            <div class="section-title-wrap">
              <h2>Why {secondContent.productName}</h2>
              <p>Core capabilities that drive measurable enterprise impact.</p>
            </div>
            <div class="card-grid">
              {secondContent.highlights.map((point) => (
                <article class="feature-card">
                  <div class="feature-card-header">
                    <div class="feature-icon" set:html={renderIcon(point.icon)} />
                    <h3>{point.title}</h3>
                  </div>
                  <p>{point.detail}</p>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section class="offering-faq" aria-label={`${secondContent.productName} questions`}>
          <div class="container">
            <div class="faq-section">
              <div class="section-title">
                <h2>Questions?</h2>
              </div>
              <div class="faq-grid">
                {secondContent.faqs.map((item) => (
                  <div class="faq-item">
                    <h3>{item.title}</h3>
                    <p>{item.detail}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </section>
      </div>
    )}

  </main>
</BaseLayout>

<script is:inline>
  function switchProductPage(tab) {
    var tabs = document.querySelectorAll('.product-tab');
    for (var i = 0; i < tabs.length; i++) {
      tabs[i].classList.remove('active');
      tabs[i].setAttribute('aria-selected', 'false');
    }
    tab.classList.add('active');
    tab.setAttribute('aria-selected', 'true');

    var sections = document.querySelectorAll('.product-section');
    for (var j = 0; j < sections.length; j++) {
      sections[j].classList.remove('active');
    }
    document.getElementById(tab.dataset.target).classList.add('active');

    history.replaceState(null, '', window.location.pathname);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  (function() {
    var hash = window.location.hash;
    if (hash === '#aeira') {
      var tab = document.querySelector('[data-target="product-section-2"]');
      if (tab) switchProductPage(tab);
    }
    // Arrow key navigation for tabs (WCAG)
    var tablist = document.querySelector('.product-tab-switch');
    if (tablist) {
      tablist.addEventListener('keydown', function(e) {
        var tabs = Array.from(tablist.querySelectorAll('[role="tab"]'));
        var idx = tabs.indexOf(document.activeElement);
        if (idx < 0) return;
        if (e.key === 'ArrowRight' || e.key === 'ArrowLeft') {
          e.preventDefault();
          var next = e.key === 'ArrowRight' ? (idx + 1) % tabs.length : (idx - 1 + tabs.length) % tabs.length;
          tabs[next].focus();
          switchProductPage(tabs[next]);
        }
      });
    }
  })();
</script>
