---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/ui/Hero.astro";
import PageSection from "../components/ui/PageSection.astro";
import CTAStrip from "../components/ui/CTAStrip.astro";
import Pill from "../components/ui/Pill.astro";

interface DocItem {
  title: string;
  href?: string;
  external?: boolean;
  nda?: boolean;
  soon?: boolean;
  available?: string;
}

interface DocCategory {
  title: string;
  blurb: string;
  items: DocItem[];
}

const categories: DocCategory[] = [
  {
    title: "Getting started",
    blurb: "Install Bolt, try the trial sidecar, run your first cross-source query.",
    items: [
      { title: "Install Bolt desktop (macOS · Linux · Windows)", href: "/download" },
      { title: "Trial sidecar quickstart", href: "/docs/trial-quickstart" },
      { title: "Trial sidecar quickstart (PDF)", href: "/docs/pdfs/trial-quickstart.pdf", external: true },
      { title: "Pricing + tiers", href: "/pricing" },
      { title: "Connecting your IdP (Okta · Entra · OneLogin · Auth0 · Google · Zoho)", href: "/security" },
    ],
  },
  {
    title: "Architecture",
    blurb: "How Bolt + Aeira fit together. What's inside the perimeter, what crosses it.",
    items: [
      { title: "First-conversation brief (PDF)", href: "/docs/pdfs/bolt-aeira-first-conversation-brief.pdf", external: true },
      { title: "Authority Policy architecture overview (PDF)", href: "/docs/pdfs/authority-policy-architecture.pdf", external: true },
      { title: "System overview", href: "/architecture" },
      { title: "Architecture poster (PDF)", href: "/docs/pdfs/bolt-aeira-architecture-poster.pdf", external: true },
      { title: "Bolt + Aeira comparison (PDF)", href: "/docs/pdfs/bolt-aeira-comparison.pdf", external: true },
      { title: "The 2026 agent-orchestrator landscape (PDF)", href: "/docs/pdfs/agent-landscape-2026.pdf", external: true },
    ],
  },
  {
    title: "Build + integrate",
    blurb: "Connect your stack. Use a bundled integration or author a custom one.",
    items: [
      { title: "Utilities overview", href: "/docs/utilities" },
      { title: "Browse sample integrations (32 builtins)", href: "/docs/utilities/gallery" },
      { title: "Write your first custom utility", href: "/docs/utilities/quickstart" },
      { title: "Full manifest spec (v1)", href: "/docs/utilities/spec" },
    ],
  },
  {
    title: "Security",
    blurb: "Threat model, security controls, audit chain, supply-chain attestation.",
    items: [
      { title: "Security & compliance overview", href: "/security" },
      { title: "CISO security architecture brief", nda: true },
      { title: "Aeira threat model (STRIDE)", nda: true },
      { title: "Bolt threat model (STRIDE)", nda: true },
      { title: "Patent-pending 4-axis ACL + audit verifier", href: "/security" },
      { title: "Supply-chain attestation (Cosign + SBOM)", soon: true },
      { title: "External pen-test report", nda: true, available: "On the roadmap" },
    ],
  },
  {
    title: "Compliance",
    blurb: "How Bolt + Aeira meet GDPR, HIPAA, DORA, FedRAMP, and CMMC requirements.",
    items: [
      { title: "Compliance + audit-verifier handbook (PDF)", href: "/docs/pdfs/compliance-handbook.pdf", external: true },
      { title: "Vertical: Defense / DIB / CUI / ITAR (PDF)", href: "/docs/pdfs/vertical-defense.pdf", external: true },
      { title: "Vertical: Federal civilian (PDF)", href: "/docs/pdfs/vertical-federal.pdf", external: true },
      { title: "Vertical: Healthcare · payers · pharma R&D (PDF)", href: "/docs/pdfs/vertical-healthcare.pdf", external: true },
      { title: "Vertical: US financial services (PDF)", href: "/docs/pdfs/vertical-finance.pdf", external: true },
      { title: "Vertical: EU financial services (PDF)", href: "/docs/pdfs/vertical-eu-finance.pdf", external: true },
    ],
  },
  {
    title: "Pilots + economics",
    blurb: "How to run a 90-day pilot and what the cost vs. value math looks like.",
    items: [
      { title: "90-day pilot pre-flight checklist (PDF)", href: "/docs/pdfs/pilot-preflight-checklist.pdf", external: true },
      { title: "Bolt + Aeira TCO calculator (PDF)", href: "/docs/pdfs/bolt-aeira-tco-calculator.pdf", external: true },
      { title: "Helm chart + docker-compose deployment", soon: true },
      { title: "Acceptance criteria template", soon: true },
    ],
  },
  {
    title: "Integrations + connectors",
    blurb: "103 in-house connectors + Airbyte bridge fronting ~350 sources.",
    items: [
      { title: "Integrations overview", href: "/integrations" },
      { title: "Connector catalog", soon: true },
      { title: "Late-bind permission checks", soon: true },
      { title: "Generic adapters: REST · JDBC · web-crawler", soon: true },
      { title: "Airbyte bridge for ~350 additional sources", soon: true },
    ],
  },
];
---
<BaseLayout
  title="Documentation — Bolt + Aeira Architecture, Security, Compliance | Sparcle"
  description="Architecture, security, compliance, connectors, API reference, pilot economics. General enterprise primer plus vertical briefs for Defense, Federal, Healthcare, Finance. Threat models + CISO brief shared under NDA."
  canonical="https://sparcle.app/docs"
>
  <main class="page-docs">
    <Hero
      eyebrow="Documentation"
      title="Docs."
      lede="Bolt + Aeira documentation. Architecture, security, compliance, connectors, API reference, pilots. Some artifacts (threat models, pen-test reports) are shared under NDA — request via the security page."
    >
      <Pill href="/download" variant="brand" size="lg">Try the trial sidecar &rarr;</Pill>
      <Pill href="#" variant="neutral" size="lg" class="js-pill-nda">Request a security brief (NDA) &rarr;</Pill>
      <Pill href="/pricing" variant="neutral" size="lg">Pricing &rarr;</Pill>
      <Pill href="#" variant="neutral" size="lg" class="js-pill-contact">Contact &rarr;</Pill>
    </Hero>

    <PageSection stripe="b">
      <div class="docs-grid">
        {categories.map((cat) => (
          <article class="docs-card">
            <h3>{cat.title}</h3>
            <p class="docs-card__blurb">{cat.blurb}</p>
            <ul class="docs-card__list">
              {cat.items.map((item) => (
                <li>
                  {item.nda ? (
                    <a href="#" onclick={`openContactModal('NDA Document Request: ${item.title.replace(/'/g, "\\'")}'); return false;`}>
                      <span class="docs-card__title">{item.title}</span>
                      <span class="docs-card__tags">
                        <Pill variant="brand" size="sm">NDA</Pill>
                        {item.available && <Pill variant="warning" size="sm">{item.available}</Pill>}
                      </span>
                    </a>
                  ) : item.soon ? (
                    <span class="docs-card__disabled">
                      <span class="docs-card__title">{item.title}</span>
                      <span class="docs-card__tags">
                        <Pill variant="neutral" size="sm">coming soon</Pill>
                      </span>
                    </span>
                  ) : (
                    <a href={item.href} target={item.external ? "_blank" : undefined} rel={item.external ? "noopener" : undefined}>
                      <span class="docs-card__title">{item.title}</span>
                    </a>
                  )}
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </PageSection>

    <CTAStrip
      variant="band"
      title="Need something we don't list?"
      lede="Most NDA artifacts and customer-specific documents are shared during pilot evaluation. Ask and we'll route you to the right brief."
    >
      <a href="#" onclick="openContactModal('Documentation Request'); return false;" class="btn btn-primary btn-lg">
        Request documentation
      </a>
      <a href="/security" class="btn btn-secondary btn-lg">Security &amp; compliance &rarr;</a>
    </CTAStrip>
  </main>

  <script is:inline>
    // Wire the two contact-modal pills (cleaner than inline onclick on the
    // <Pill> component which doesn't expose an onclick prop).
    document.addEventListener('DOMContentLoaded', function () {
      var nda = document.querySelector('.js-pill-nda');
      if (nda) nda.addEventListener('click', function (e) {
        e.preventDefault();
        if (window.openContactModal) window.openContactModal('Security Brief Request');
      });
      var contact = document.querySelector('.js-pill-contact');
      if (contact) contact.addEventListener('click', function (e) {
        e.preventDefault();
        if (window.openContactModal) window.openContactModal('General Inquiry');
      });
    });
  </script>
</BaseLayout>

<style is:global>
  .page-docs .docs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.5rem;
  }
  .page-docs .docs-card {
    background: var(--bg-surface-solid);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    transition: border-color var(--transition-fast), transform var(--transition-fast), box-shadow var(--transition-fast);
  }
  .page-docs .docs-card:hover {
    border-color: var(--brand-primary-light);
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }
  .page-docs .docs-card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.25rem;
    color: var(--text-heading);
    font-family: var(--font-display);
    letter-spacing: -0.01em;
  }
  .page-docs .docs-card__blurb {
    margin: 0 0 1.25rem;
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--text-muted);
  }
  .page-docs .docs-card__list {
    list-style: none;
    padding: 0;
    margin: 0;
    flex: 1;
  }
  .page-docs .docs-card__list li {
    padding: 0.7rem 0;
    border-top: 1px solid var(--border-subtle);
    font-size: 0.92rem;
  }
  .page-docs .docs-card__list li:first-child {
    border-top: none;
    padding-top: 0;
  }
  .page-docs .docs-card__list li a,
  .page-docs .docs-card__list li .docs-card__disabled {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: var(--text-body);
    transition: color var(--transition-fast);
  }
  .page-docs .docs-card__list li a:hover {
    color: var(--brand-primary);
  }
  .page-docs .docs-card__disabled {
    cursor: default;
    color: var(--text-muted);
  }
  .page-docs .docs-card__disabled .docs-card__title {
    font-style: italic;
  }
  .page-docs .docs-card__title { flex: 1; }
  .page-docs .docs-card__tags {
    display: inline-flex;
    gap: 0.4rem;
    flex-shrink: 0;
  }

  /* Hero pill row alignment — the hero already centers its actions slot,
     but we want pills to flow as a tight wrap rather than a vertical stack
     on the desktop hero. */
  .page-docs .hero-band__actions {
    gap: 0.6rem;
  }
</style>
