---
interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
}

const {
  title,
  description = "Sparcle - Unified intelligence for the enterprise.",
  canonical,
  ogTitle = title,
  ogDescription = description,
  ogImage = "https://sparcle.app/images/og-preview.png",
} = Astro.props;

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? "";
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("theme");
          document.documentElement.setAttribute("data-theme",
            t === "dark" || t === "light" ? t : "light");
        } catch {
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark light" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Sparcle, LLC" />
    <meta name="rating" content="general" />
    <meta name="category" content="technology" />
    <meta name="classification" content="Business" />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#020617" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#edf2fb" />

    {canonical && <link rel="canonical" href={canonical} />}
    <meta property="og:type" content="website" />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:site_name" content="Sparcle" />

    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify([
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Sparcle, LLC",
        "legalName": "Sparcle, LLC",
        "url": "https://sparcle.app",
        "logo": "https://sparcle.app/images/bolt-logo.svg",
        "description": "Sparcle builds sovereign AI infrastructure for regulated enterprises — deploy on-prem, bring your own LLM, protect your IP and data at every layer.",
        "foundingDate": "2024",
        "email": "bolt@sparcle.app",
        "sameAs": [
          "https://sparcle.app",
          "https://www.linkedin.com/company/sparcle"
        ],
        "contactPoint": {
          "@type": "ContactPoint",
          "email": "bolt@sparcle.app",
          "contactType": "sales",
          "availableLanguage": "English"
        }
      },
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Bolt",
        "applicationCategory": "BusinessApplication",
        "operatingSystem": "Windows, macOS, Linux, iOS, Android, Web",
        "description": "Sovereign enterprise AI agent — deploy on-prem or VPC, bring your own LLM, connect 60+ systems via MCP. IP and PII protected regardless of AI model.",
        "url": "https://sparcle.app/products.html",
        "offers": [
          {
            "@type": "Offer",
            "name": "Bolt Absolute",
            "price": "30",
            "priceCurrency": "USD",
            "priceSpecification": {
              "@type": "UnitPriceSpecification",
              "price": "30",
              "priceCurrency": "USD",
              "unitText": "seat/month",
              "billingIncrement": 25
            },
            "description": "$30/seat/month (annual) — self-hosted, BYO LLM, full Bolt platform. 25-seat minimum.",
            "url": "https://sparcle.app/pricing"
          },
          {
            "@type": "Offer",
            "name": "Bolt Bundled",
            "price": "60",
            "priceCurrency": "USD",
            "priceSpecification": {
              "@type": "UnitPriceSpecification",
              "price": "60",
              "priceCurrency": "USD",
              "unitText": "seat/month",
              "billingIncrement": 50
            },
            "description": "$60/seat/month (annual) — self-hosted, managed AI with smart routing, 10M tokens/mo. 50-seat minimum.",
            "url": "https://sparcle.app/pricing"
          },
          {
            "@type": "Offer",
            "name": "Bolt Complete",
            "price": "90",
            "priceCurrency": "USD",
            "priceSpecification": {
              "@type": "UnitPriceSpecification",
              "price": "90",
              "priceCurrency": "USD",
              "unitText": "seat/month",
              "billingIncrement": 100
            },
            "description": "$90/seat/month (annual) — Sparcle-managed hosting, multi-region, 99.9% SLA, 15M tokens/mo. 100-seat minimum.",
            "url": "https://sparcle.app/pricing"
          }
        ],
        "provider": {
          "@type": "Organization",
          "name": "Sparcle, LLC",
          "url": "https://sparcle.app"
        },
        "featureList": [
          "Self-hosted / on-prem / VPC / air-gapped deployment",
          "Bring your own LLM — OpenAI, Anthropic, Ollama, NVIDIA NIM",
          "IP and PII protection regardless of AI model",
          "60+ enterprise system integrations via open MCP",
          "8-layer security pipeline",
          "4-level ACL (region / department / group / user)",
          "Agentic actions — email, calendar, tasks, desktop",
          "HIPAA, SOX, ITAR, GDPR deployable"
        ]
      },
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Aeira",
        "applicationCategory": "BusinessApplication",
        "operatingSystem": "Linux (self-hosted)",
        "description": "Sovereign enterprise knowledge index — ACL-aware retrieval substrate for governed search and discovery. Deployed inside your perimeter; pairs with Bolt or any MCP-compatible client.",
        "url": "https://sparcle.app/products/aeira.html",
        "provider": {
          "@type": "Organization",
          "name": "Sparcle, LLC",
          "url": "https://sparcle.app"
        },
        "featureList": [
          "4-level ACL (region / department / group / user)",
          "MCP-native retrieval interface",
          "Self-hosted, no data leaves the enterprise perimeter",
          "Indexes documents, wikis, policies, codebases, and data sources",
          "Pairs with Bolt or runs standalone"
        ]
      }
    ])} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Outfit:wght@600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <link rel="stylesheet" href="/css/variables.css" />
    <link rel="stylesheet" href="/css/styles.css" />
    <link rel="stylesheet" href="/css/sparkle-animation.css" />
    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />

    <!-- Google Analytics 4 -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-Z5BBF4KVH3"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-Z5BBF4KVH3');
    </script>

    <!-- Sparcle config (public) -->
    <script is:inline define:vars={{ turnstileSiteKey }}>
      // Localhost dev fallback uses Cloudflare's documented "always passes" test site key
      // so the widget renders for visual verification. Never used in production.
      var __isLocalhost = location.hostname === 'localhost' || location.hostname === '127.0.0.1';
      window.SPARCLE_CONFIG = {
        turnstileSiteKey: turnstileSiteKey || (__isLocalhost ? '1x00000000000000000000AA' : '')
      };
    </script>
    <!-- Cloudflare Turnstile (loaded async; widgets are rendered programmatically when the contact modal opens) -->
    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" async defer></script>

    <slot name="head" />
  </head>

  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <main id="main-content">
      <slot />
    </main>
    <script is:inline src="/js/shared-nav.js"></script>
  </body>
</html>