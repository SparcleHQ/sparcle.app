---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/ui/Hero.astro";
import PageSection from "../components/ui/PageSection.astro";
import CardGrid from "../components/ui/CardGrid.astro";
import Card from "../components/ui/Card.astro";
import CTAStrip from "../components/ui/CTAStrip.astro";
import Prose from "../components/ui/Prose.astro";
import BlockQuote from "../components/marketing/BlockQuote.astro";

const proofs = [
  { metric: "8",          label: "Security Pipeline Layers",     body: "Identity validation, PII scrubbing, policy guardrails, and audit logging. Plus, BYOK deployment means your prompts never leave your private Azure / AWS network." },
  { metric: "30+",        label: "Enterprise Integrations",       body: "Microsoft 365, Google Workspace, Zoho, Slack, GitHub, Jira, Salesforce, Confluence, ServiceNow — via open MCP, not proprietary APIs. Auth works with any OIDC IdP. No migration. No lock-in." },
  { metric: "Your IP.",   label: "Always Protected",              body: "Your data, your employees' information, and your organization's IP — protected at every layer of Bolt's architecture, regardless of which AI model you use." },
  { metric: "Same-day",   label: "Time to Deploy",                body: "Connect your IdP, configure your MCP servers, and deploy Bolt — no migration, no retraining. Production-ready architecture for fast onboarding." },
  { metric: "Any LLM",    label: "Model-Agnostic by Design",      body: "Switch providers anytime — OpenAI, Anthropic, Ollama, or your own fine-tuned model. Employees see no change. Data posture doesn't move." },
  { metric: "BYOK",       label: "Zero Token Markup",             body: "Bring your own API keys; burn down your existing cloud compute commits without per-token surcharge. Eliminate context-switching across your stack and reclaim productive time." },
];
---
<BaseLayout
  title="Why Sparcle | Mission, Proof & Enterprise Metrics"
  description="Sparcle exists to help organizations reclaim the time and money lost to workplace fragmentation. See our mission, proof metrics, and the research behind our platform."
  canonical="https://sparcle.app/why-sparcle"
>
  <main class="page-why-sparcle">
    <Hero
      eyebrow="Our Mission"
      title="Reclaim time. Unlock potential."
      lede="Sparcle exists for one reason: to give every organization the freedom to use AI on their own terms — without vendor lock-in, without compromising data privacy, and without surrendering control of their intellectual property."
    />

    <PageSection stripe="b" width="content">
      <BlockQuote
        quote="Your workforce burns <strong>~5 weeks per year</strong> reorienting after interruptions."
        citation="Gloria Mark, UC Irvine — Attention Span: A Groundbreaking Way to Restore Balance, Happiness and Productivity"
        href="/research.html"
      />

      <Prose>
        <p>
          Knowledge workers today juggle dozens of applications, losing hours every day to
          context switching and tool hopping. In regulated industries — healthcare, financial
          services, defense, legal — this problem carries an additional weight: most AI
          solutions require organizations to send their data and documents to external clouds
          they don't control.
        </p>
        <p>
          We believe AI governance, data sovereignty, and employee data privacy are not optional
          features — they are the foundation. We built <strong>Bolt</strong>, an enterprise AI
          operating system, and <strong>Aeira</strong>, an ACL-aware enterprise index, so
          organizations operating in a $10 trillion regulated economy can adopt AI fully, stay
          compliant completely, and change their underlying model at any time — without their
          employees noticing, and without their data moving.
        </p>
        <p>
          We also believe every regulated vertical has its own honest definition of authoritative
          — and every competitor forces them to use the vendor's definition. So we built the
          <strong>Authority Policy SDK</strong>: customer-extensible trust scoring that sits on
          top of the ACL, runs inside your perimeter, and ships in Rust or YAML config. Default,
          Regulated, and Healthcare reference packs in the box. Customers write their own — or
          stack on top.
          <strong><em>Your search. Your policy. Your code.</em></strong>
        </p>
        <p>
          No replacement. No migration. No lock-in. No compromise.
        </p>
      </Prose>
    </PageSection>

    <PageSection
      eyebrow="Built &amp; Deployed"
      title="Real product. Real metrics."
      lede="Production-grade systems deployed today. These numbers reflect running code, real integrations, and filed patent applications."
      stripe="a"
    >
      <CardGrid cols={3}>
        {proofs.map((p) => (
          <Card variant="proof" metric={p.metric} title={p.label}>
            {p.body}
          </Card>
        ))}
      </CardGrid>
      <div style="text-align: center; margin-top: var(--space-block);">
        <a href="/research.html" class="btn btn-secondary btn-lg">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
          </svg>
          Explore our research
        </a>
      </div>
    </PageSection>

    <CTAStrip
      variant="band"
      title="See what unified intelligence looks like."
      lede="Schedule a 30-minute technical walkthrough with our team. We'll show you how Bolt and Aeira work with your existing systems — no slides, just a live demo."
    >
      <a href="#" onclick="openContactModal('Enterprise Pilot Inquiry'); return false;" class="btn btn-primary btn-xl">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
          <polyline points="22,6 12,13 2,6"></polyline>
        </svg>
        <span>Schedule a demo</span>
      </a>
    </CTAStrip>
  </main>
</BaseLayout>
