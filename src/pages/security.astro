---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/ui/Hero.astro";
import PageSection from "../components/ui/PageSection.astro";
import CardGrid from "../components/ui/CardGrid.astro";
import Card from "../components/ui/Card.astro";
import CTAStrip from "../components/ui/CTAStrip.astro";
import Pill from "../components/ui/Pill.astro";

const compliance = [
  { regime: "HIPAA",                status: "ready",   pill: "Architecture deployable", notes: "Self-hosted variants meet HIPAA technical safeguards. BAAs available on enterprise contracts during pilot evaluation." },
  { regime: "SOX",                  status: "ready",   pill: "Architecture deployable", notes: "Audit-trail responses, tamper-evident logging, and role-based controls support SOX IT general controls. Customer-specific scope reviewed during pilot." },
  { regime: "ITAR / Export Control",status: "ready",   pill: "Architecture deployable", notes: "Air-gapped Federated tier available. US-person-only access controls and data residency enforced via deployment configuration." },
  { regime: "GDPR / UK GDPR",       status: "ready",   pill: "Architecture deployable", notes: "Provable cryptographic erasure for Right to be Forgotten. EU + UK data residency via region-pinned deployments." },
  { regime: "FCA / PRA (UK financial services)", status: "ready", pill: "Architecture deployable", notes: "Self-hosted posture supports SYSC 8 outsourcing, SS1/21 + PS21/3 operational resilience, SS1/23 third-party risk, and DP5/22 AI model risk. Customer remains the regulated entity; Sparcle ships software, the firm runs it. Architecture brief + DPA + third-party-register template under NDA." },
  { regime: "DORA (EU financial services)", status: "ready", pill: "Architecture deployable", notes: "Self-hosted + BYO LLM avoids ICT third-party concentration risk. Exit-portable via Helm / Docker Compose. ICT incident logging + reporting hooks available." },
  { regime: "SOC 2 Type II",        status: "roadmap", pill: "Roadmap",                  notes: "Audit engagement planned. Honest framing: no formal certification yet. Aligned controls implemented; happy to share gap analysis under NDA." },
  { regime: "FedRAMP Moderate",     status: "roadmap", pill: "Roadmap",                  notes: "Federated tier targeted. Multi-quarter effort; we work with sponsoring agency partners during pilot." },
  { regime: "ISO 27001",            status: "roadmap", pill: "Roadmap",                  notes: "Audit engagement on the path; controls aligned. NDA brief covers timeline." },
];

const ndaItems = [
  ["Architecture brief", "component-level diagrams of Bolt's runtime and Aeira's data plane, including the cache hierarchy, the priority engine's scoring model, and the security pipeline's specific layers"],
  ["Security posture documentation", "threat model, encryption details, key management semantics, audit log format and retention"],
  ["Patent claim summaries", "what the patent-pending architecture covers and how it maps to the runtime"],
  ["Pen-test results", "latest external assessment findings and remediation status"],
  ["Compliance gap analysis", "honest current-vs-target view for SOC 2, ISO 27001, FedRAMP"],
  ["Reference customer conversations", "design partners willing to take a call about their experience"],
  ["Deployment runbook", "Helm charts, Docker Compose, Kubernetes manifests, and the operational guides used during go-live"],
];
---
<BaseLayout
  title="Security & Compliance: Enterprise AI Any CISO Can Sign Off | Sparcle"
  description="Sovereign AI for any enterprise that takes governance seriously. Self-hosted or fully air-gapped. Per-tenant KMS, provable cryptographic erasure, identity-bound queries. Deployable for HIPAA, GDPR, DPDPA, SOX, ITAR."
  canonical="https://sparcle.app/security/"
>
  <link slot="head" rel="stylesheet" href="/css/trust-callout.css" />
  <main class="page-security">
    <Hero
      eyebrow="Security & Compliance"
      title="Built for the work your CISO has to defend."
      lede="Bolt and Aeira are built to the security bar regulated industries demand, which means they work for any enterprise that takes governance seriously, not just the ones a regulator forces to. This page covers our architectural posture, the compliance regimes the platform is deployable for today, and our roadmap. Detailed security briefs, threat models, and pen-test results are shared under NDA."
    >
      <a href="#" onclick="openContactModal('Security Brief Request'); return false;" class="btn btn-primary btn-lg">
        Request Security Brief (NDA)
      </a>
      <a href="/architecture" class="btn btn-secondary btn-lg">
        Architecture posture &rarr;
      </a>
    </Hero>

    <aside class="trust-callout" aria-label="Trust dossier">
      <div class="trust-callout__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
        </svg>
      </div>
      <div class="trust-callout__body">
        <h3 class="trust-callout__title">Reading this for security review?</h3>
        <p class="trust-callout__lede">
          The complete trust dossier (sub-processor disclosure, controls evidence map, cryptographic-erasure whitepaper, standalone audit-chain verifier, incident-response framework, and vulnerability disclosure policy) lives at the Trust Center.
        </p>
        <a href="/trust" class="trust-callout__cta">
          Browse the Trust Center &nearr;
        </a>
      </div>
    </aside>

    <PageSection
      eyebrow="At a glance"
      title="The posture, summarized."
      stripe="b"
    >
      <CardGrid cols={2}>
        <Card title="Your data. Your perimeter.">
          Self-host on AWS, Azure, GCP, on-prem, or fully air-gapped. Every Bolt tier and Aeira
          Federated keep your data plane in your perimeter; Sparcle never hosts your data. If you
          opt into Managed AI, only LLM inference routes through a Sparcle-managed gateway under
          MSA + DPA with zero-retention guarantees from upstream providers; your data stays put.
        </Card>
        <Card title="Identity-bound by design">
          Every query inherits the calling user's identity from your IdP (SAML, OIDC, JWT). Aeira
          filters in-band on every result; Bolt's pipeline applies policy guardrails before any
          prompt reaches the LLM. No bypass mode for callers.
        </Card>
        <Card title="Encrypted & auditable">
          KMS-enveloped storage with per-tenant key isolation. Provable cryptographic erasure for
          GDPR &amp; HIPAA obligations. Audit trail on every query, including which results were
          filtered and why. Specific KMS posture and crypto choices reviewed under NDA.
        </Card>
        <Card title="Patent-pending architecture">
          Bolt's patent-pending architecture covers the runtime architecture, the priority engine,
          and the overlay UI. Detailed claim language is shared under NDA.
        </Card>
        <Card title="Tamper-evident audit you can verify yourself">
          Every privileged action is sealed into an Ed25519-signed Merkle chain. Export a
          self-contained proof bundle and an auditor verifies it completely offline, with no database,
          and nothing from Sparcle, in the verification loop.
        </Card>
        <Card title="Streams to your SIEM out of the box">
          Audit events forward to your SIEM (Splunk, Microsoft Sentinel, or syslog) with no extra
          tooling. Your security team watches Bolt activity in the same place it watches everything else.
        </Card>
      </CardGrid>
    </PageSection>

    <PageSection
      eyebrow="Compliance Posture"
      title="What's deployable today, what's on the roadmap."
      lede="We use precise language about compliance: an architecture is &quot;deployable&quot; for a regime when it can be configured to satisfy that regime's technical requirements, but a formal certification is a separate process with a third-party auditor. Here's where we are honestly."
      stripe="a"
    >
      <div class="data-table">
        <div class="data-table__row data-table__row--head">
          <div>Regime</div>
          <div>Status</div>
          <div>Notes</div>
        </div>
        {compliance.map((row) => (
          <div class="data-table__row">
            <div class="data-table__label">{row.regime}</div>
            <div>
              <Pill variant={row.status === "ready" ? "success" : "brand"} size="sm">{row.pill}</Pill>
            </div>
            <div>{row.notes}</div>
          </div>
        ))}
      </div>
    </PageSection>

    <PageSection
      eyebrow="Deployment Models"
      title="Your data plane stays in your perimeter, always."
      stripe="b"
    >
      <CardGrid cols={2}>
        <Card title="Self-Hosted (every Bolt tier, Aeira Dynamic / Enhanced)">
          You run the data plane and the AI inference. Sparcle ships software, updates, and support.
          Docker Compose for staging, Kubernetes for production HA, air-gap option available. Most
          regulated buyers start here. From $30/seat/month for Bolt; from $999/month for Aeira Dynamic.
        </Card>
        <Card title="Managed AI option (any tier)">
          You keep the data plane in your perimeter. If you'd rather not run inference yourself,
          Sparcle routes only LLM calls through a managed gateway under an MSA + DPA with
          zero-retention guarantees from upstream providers. Your data plane never leaves your
          perimeter; only PII-masked prompts reach the gateway.
        </Card>
        <Card title="Air-Gapped (Aeira Federated)">
          No outbound, no inbound, no telemetry. Multi-region VPC or physically air-gapped. License
          validation via offline-signed token, refreshed on a customer-controlled schedule. Defense,
          federal, and the most-regulated industries. Custom annual contracts from $500K/year.
        </Card>
      </CardGrid>
    </PageSection>

    <PageSection
      eyebrow="Available under NDA"
      title="Where the technical depth lives."
      lede="We deliberately don't publish implementation specifics on the public site. Below is what we share under a mutual NDA during pilot evaluation:"
      stripe="a"
      width="prose"
    >
      <ul class="nda-list">
        {ndaItems.map(([t, body]) => (
          <li>
            <strong>{t}</strong>: {body}
          </li>
        ))}
      </ul>
    </PageSection>

    <CTAStrip
      variant="band"
      title="Take the next step."
      lede="Schedule a 30-minute call to walk through the architecture, request the security brief under NDA, or arrange a reference conversation with a design partner."
    >
      <a href="#" onclick="openContactModal('Security Brief Request'); return false;" class="btn btn-primary btn-lg">
        Request Security Brief (NDA)
      </a>
      <a href="#" onclick="openContactModal('Architecture Review'); return false;" class="btn btn-secondary btn-lg">
        Schedule Architecture Review
      </a>
    </CTAStrip>
  </main>
</BaseLayout>

<style is:global>
  /* Data table: header row + data rows in a card frame.
     Used here for the compliance matrix. Promoted to a primitive
     if more pages adopt it; until then, scoped to security.astro
     and the matching block in architecture.astro. */
  .data-table {
    background: var(--bg-surface-solid);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .data-table__row {
    display: grid;
    grid-template-columns: 200px 180px 1fr;
    border-bottom: 1px solid var(--border-subtle);
  }
  .data-table__row:last-child {
    border-bottom: none;
  }
  .data-table__row > div {
    padding: 1rem 1.2rem;
    font-size: 0.95rem;
    color: var(--text-body);
    line-height: 1.55;
  }
  .data-table__row--head > div {
    font-weight: 700;
    color: var(--text-heading);
    background: var(--bg-muted);
    font-size: 0.86rem;
  }
  .data-table__label {
    font-weight: 600;
    color: var(--text-heading) !important;
    background: var(--bg-muted);
  }
  @media (max-width: 720px) {
    .data-table__row {
      grid-template-columns: 1fr;
    }
    .data-table__row > div {
      padding: 0.6rem 1.1rem;
    }
    .data-table__row--head {
      display: none;
    }
    .data-table__label {
      font-size: 0.78rem !important;
      letter-spacing: 0.4px;
      text-transform: uppercase;
    }
  }

  /* NDA / capabilities list: branded left-border list. Replaces .sec-nda-list. */
  .nda-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.75rem;
  }
  .nda-list li {
    background: var(--bg-surface-solid);
    border: 1px solid var(--border-default);
    border-left: 3px solid var(--brand-primary);
    border-radius: var(--radius-md);
    padding: 0.9rem 1.1rem;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--text-body);
  }
  .nda-list strong {
    color: var(--text-heading);
  }
</style>
