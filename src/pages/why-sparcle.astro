---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/marketing/SectionHeader.astro";
import ProofCard from "../components/marketing/ProofCard.astro";
import BlockQuote from "../components/marketing/BlockQuote.astro";
---

<BaseLayout
  title="Why Sparcle | Mission, Proof & Enterprise Metrics"
  description="Sparcle exists to help organizations reclaim the time and money lost to workplace fragmentation. See our mission, proof metrics, and the research behind our platform."
  canonical="https://sparcle.app/why-sparcle"
>
  <!-- ========================================
       WHY SPARCLE
       ======================================== -->
  <section id="why-sparcle" class="section-solution section-solution--page">
    <div class="container">
      <BlockQuote
        quote="Your workforce burns <strong>~5 weeks per year</strong> reorienting after interruptions."
        citation="Gloria Mark, UC Irvine — Attention Span: A Groundbreaking Way to Restore Balance, Happiness and Productivity"
        href="/research.html"
      />
      <SectionHeader
        label="Our Mission"
        heading="Reclaim Time.<br>Unlock Potential."
      />

      <div class="page-prose">
        <p>
          Sparcle exists for one reason: to give every organization the freedom to use AI
          on their own terms — without vendor lock-in, without compromising data privacy,
          and without surrendering control of their intellectual property.
        </p>
        <p>
          Knowledge workers today juggle dozens of applications, losing hours every day
          to context switching and tool hopping. In regulated industries — healthcare,
          financial services, defense, legal — this problem carries an additional weight:
          most AI solutions require organizations to send their data and documents to
          external clouds they don't control.
        </p>
        <p>
          We believe AI governance, data sovereignty, and employee data privacy are not
          optional features — they are the foundation. We built <strong>Bolt</strong> —
          an enterprise AI operating system — and <strong>Aeira</strong> — an ACL-aware
          enterprise index — so organizations operating in a $10 trillion regulated
          economy can adopt AI fully, stay compliant completely, and change their
          underlying model at any time — without their employees noticing, and without
          their data moving.
        </p>
        <p>
          No replacement. No migration. No lock-in. No compromise.
        </p>
      </div>
    </div>
  </section>

  <!-- ========================================
       PROOF & METRICS
       ======================================== -->
  <section id="proof" class="section-proof">
    <div class="container">
      <SectionHeader
        label="Built & Deployed"
        heading="Real Product.<br>Real Metrics."
        intro="Production-grade systems deployed today. These numbers reflect running code, real integrations, and filed patent applications."
      />

      <div class="proof-grid">
        <ProofCard
          metric="8"
          label="Security Pipeline Layers"
          description="Identity validation, PII scrubbing, policy guardrails, and audit logging. Plus, BYOK deployment means your prompts never leave your private Azure/AWS network."
        />
        <ProofCard
          metric="30+"
          label="Enterprise Integrations"
          description="Microsoft 365, Google Workspace, Zoho, Slack, GitHub, Jira, Salesforce, Confluence, ServiceNow, and more — via open MCP, not proprietary APIs. Auth works with Microsoft 365, Google Workspace, Zoho, Okta, Azure AD, or any OIDC IdP. No migration. No lock-in."
        />
        <ProofCard
          metric="Your IP."
          label="Always Protected"
          description="Your data, your employees' information, and your organization's IP — protected at every layer of Bolt's architecture, regardless of which AI model you use."
        />
        <ProofCard
          metric="<1hr"
          label="Time to Deploy"
          description="Connect your IdP, configure your MCP servers, and deploy Bolt in under an hour. Your team is productive on day one — no migration, no retraining."
        />
        <ProofCard
          metric="Any LLM"
          label="Model-Agnostic by Design"
          description="Switch providers anytime — OpenAI, Anthropic, Ollama, or your own fine-tuned model. Employees see no change. Data posture doesn't move."
        />
        <ProofCard
          metric="25×"
          label="ROI Per Seat"
          description="At $10/seat, Bolt recovers 60+ hrs/year. Plus, BYOK economics means zero token markups—you simply burn down your existing cloud compute commits."
        />
      </div>

      <div class="section-cta-row">
        <a href="/research.html" class="btn btn-secondary btn-lg">
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
          </svg>
          Explore Our Research
        </a>
      </div>
    </div>
  </section>

  <!-- ========================================
       CTA
       ======================================== -->
  <section class="section-cta">
    <div class="container">
      <div class="cta-box">
        <h2>See What Unified Intelligence Looks Like</h2>
        <p>
          Schedule a 30-minute technical walkthrough with our team. We'll show
          you how Bolt and Aeira work with your existing systems — no slides,
          just a live demo.
        </p>
        <div class="cta-actions">
          <a href="#" onclick="openContactModal('Enterprise Pilot Inquiry'); return false;"
            class="btn btn-primary btn-xl">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            <span>Schedule a Demo</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Modal -->
  <div id="contactModalOverlay" class="contact-modal-overlay" role="dialog" aria-modal="true" aria-label="Contact form">
    <div class="contact-modal">
      <button class="contact-modal-close" onclick="closeContactModal()" aria-label="Close">&times;</button>
      <h3 id="contactModalTitle">Get in Touch</h3>
      <p class="modal-subtitle">We'll respond within one business day.</p>
      <form id="contactForm" autocomplete="on">
        <div id="contactFormFields">
          <input type="hidden" id="contactInterest" name="interest" value="">
          <div class="contact-form-group">
            <label for="contactName">Name</label>
            <input type="text" id="contactName" name="name" required placeholder="Jane Smith" autocomplete="name">
          </div>
          <div class="contact-form-group">
            <label for="contactEmail">Work Email</label>
            <input type="email" id="contactEmail" name="email" required placeholder="jane@company.com" autocomplete="email">
          </div>
          <div class="contact-form-group">
            <label for="contactCompany">Company</label>
            <input type="text" id="contactCompany" name="company" placeholder="Acme Corp" autocomplete="organization">
          </div>
          <div class="contact-form-group">
            <label for="contactTeamSize">Team Size</label>
            <select id="contactTeamSize" name="teamSize">
              <option value="">Select…</option>
              <option value="1-10">1–10</option>
              <option value="11-50">11–50</option>
              <option value="51-200">51–200</option>
              <option value="201-500">201–500</option>
              <option value="500+">500+</option>
            </select>
          </div>
          <button type="submit" id="contactSubmitBtn" class="contact-submit-btn">Send Request</button>
        </div>
        <div id="contactFormStatus" class="contact-form-status"></div>
      </form>
    </div>
  </div>

  <script is:inline>
  (function() {
    var contactOverlay = document.getElementById('contactModalOverlay');
    var contactForm    = document.getElementById('contactForm');
    var contactFields  = document.getElementById('contactFormFields');
    var contactStatus  = document.getElementById('contactFormStatus');
    var contactInterest = document.getElementById('contactInterest');
    var contactSubmit  = document.getElementById('contactSubmitBtn');
    var contactTitle   = document.getElementById('contactModalTitle');

    window.openContactModal = function(interest) {
      contactInterest.value = interest || 'General Inquiry';
      contactTitle.textContent = interest || 'Get in Touch';
      contactFields.style.display = '';
      contactStatus.className = 'contact-form-status';
      contactSubmit.disabled = false;
      contactSubmit.textContent = 'Send Request';
      contactOverlay.classList.add('open');
      setTimeout(function() { document.getElementById('contactName').focus(); }, 100);
    };

    window.closeContactModal = function() {
      contactOverlay.classList.remove('open');
      contactForm.reset();
    };

    contactOverlay.addEventListener('click', function(e) {
      if (e.target === contactOverlay) closeContactModal();
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && contactOverlay.classList.contains('open')) closeContactModal();
    });

    contactForm.addEventListener('submit', function(e) {
      e.preventDefault();
      contactSubmit.disabled = true;
      contactSubmit.textContent = 'Sending\u2026';

      var payload = {
        name: document.getElementById('contactName').value.trim(),
        email: document.getElementById('contactEmail').value.trim(),
        company: document.getElementById('contactCompany').value.trim(),
        teamSize: document.getElementById('contactTeamSize').value,
        interest: contactInterest.value
      };

      var FORM_URL = 'https://script.google.com/macros/s/AKfycbzNqgqye15z-BzB6vQyciBp0-5HoGI8TtphENSpYxpWDk_5EB5amv30VDEgOhI58nBTbQ/exec';

      fetch(FORM_URL, {
        method: 'POST',
        mode: 'no-cors',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      }).then(function() {
        contactFields.style.display = 'none';
        contactStatus.className = 'contact-form-status show';
        contactStatus.innerHTML =
          '<div class="status-icon">&#10003;</div>' +
          '<h4>Request Sent!</h4>' +
          '<p>We\u2019ll get back to you within one business day.</p>';
      }).catch(function() {
        contactFields.style.display = 'none';
        contactStatus.className = 'contact-form-status show';
        contactStatus.innerHTML =
          '<div class="status-icon">&#9993;</div>' +
          '<h4>Almost there!</h4>' +
          '<p>Please email us directly at <a href="mailto:bolt@sparcle.app" style="color:var(--brand-primary)">bolt@sparcle.app</a></p>';
      });
    });
  })();
  </script>

</BaseLayout>

