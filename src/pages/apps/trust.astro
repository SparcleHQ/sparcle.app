---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/ui/Hero.astro";
import PageSection from "../../components/ui/PageSection.astro";
import CardGrid from "../../components/ui/CardGrid.astro";
import Card from "../../components/ui/Card.astro";
import CTAStrip from "../../components/ui/CTAStrip.astro";

// The truth table. One row per dimension, three columns per tier.
// This is the page a CISO bookmarks. Every cell maps to runtime
// behavior the platform enforces, not aspirational copy. If a cell
// here drifts from runtime, the runtime is the bug, not the page.
const truthRows = [
  {
    dim: "Who authors the App",
    builtin: "Sparcle",
    admin: "The customer's admin",
    user: "The individual user",
  },
  {
    dim: "Who installs it",
    builtin: "Ships in Bolt",
    admin: "Org admin enables in Settings",
    user: "User drops .yaml in a local folder, clicks Reload",
  },
  {
    dim: "Where it runs",
    builtin: "In-process in the Bolt app",
    admin: "Inside the customer perimeter, via the customer's Bolt service",
    user: "On the user's own machine, end-to-end local",
  },
  {
    dim: "What hits the network",
    builtin: "Nothing",
    admin: "Org-connected systems (Jira, Stripe, internal APIs, ...)",
    user: "Whatever the user's script asks for. With the user's auth, from the user's machine.",
  },
  {
    dim: "Whose identity it runs as",
    builtin: "n/a",
    admin: "Per-user OAuth, scoped to the calling user",
    user: "The user's OS identity. Same as their terminal.",
  },
  {
    dim: "What Sparcle servers see",
    builtin: "Nothing",
    admin: "Nothing about the request body. Audit-chain hashes only.",
    user: "Nothing. Optional audit ping is metadata only: App id, timestamp, ok flag, duration ms. No query. No arguments. No output.",
  },
  {
    dim: "Removable",
    builtin: "Reinstall app to change",
    admin: "Admin disables in Settings; per-org policy",
    user: "User deletes the file; admin can disable the whole tier on a managed device",
  },
];

// Five runtime-enforced properties. These are checks in the loader
// and executor, not items on a policy checklist. Listed in order of
// what they protect against.
const guarantees = [
  {
    title: "Confirm before run",
    body: "Bolt renders a 'Press Enter to run' row instead of firing the command on every keystroke. Authors can customize the prompt copy but cannot turn confirm off. A process spawn per character is not a thing the runtime ships.",
  },
  {
    title: "Never an LLM tool",
    body: "User Apps are never registered as agent tools and never appear in the LLM's tool-use surface. The agent loop does not know they exist. A poisoned document cannot tell the model to run your App because the model cannot run anything.",
  },
  {
    title: "Never staged into chat context",
    body: "App output never auto-attaches to a chat message. The chat composer's attachment surface accepts entity and plugin context, not App rows. Output stays in the dropdown and the right-side preview pane. The LLM only sees it if the user copies and pastes it.",
  },
  {
    title: "argv-only execution",
    body: "Templated commands are tokenized into argv via POSIX shell rules and spawned directly. There is no /bin/sh -c. Multi-statement shell, pipes, command substitution, and backticks are rejected at validate time, before the manifest ever loads.",
  },
  {
    title: "Forced safety fields",
    body: "Every row the runtime emits gets canEscalateAi=false, source=user_bridge, and pii_boundary=enforce stamped on it regardless of what the YAML asks for. Forbidden right-pane kinds (such as entity-graph bindings on a User App) are rejected at load time so a manifest cannot graft itself onto Bolt's entity router.",
  },
];

// What Bolt does NOT do that a remote model or a hostile app on the
// same box might want it to. This is the testable version of the
// "Bolt does not multiply the user's authority" claim.
const cannots = [
  {
    title: "Bolt does not let an LLM invoke a User App",
    body: "There is no agent-tool path to user_util_invoke. Architecturally, not as a flag a future release could flip. A model that wanted a User App to run would have to find a human to type the chip and press Enter.",
  },
  {
    title: "Bolt does not let a poisoned response chain a User App",
    body: "The action buttons rendered for an App row come from the manifest, not from the model. The model cannot inject a new action, a new url, or a new shell command into a row it sees.",
  },
  {
    title: "Bolt does not store User App output it does not own",
    body: "The audit ping, when configured, is metadata. The query, the arguments, the stdout, the stderr: none of it leaves the user's machine via Sparcle. If the script writes to a file, that is the user's file. If it hits an external API, that is the user's request from the user's IP.",
  },
  {
    title: "Bolt does not run User Apps as root",
    body: "The Bolt App Runtime runs as the user. User App commands inherit that identity. There is no privilege escalation path; the runtime does not have privilege to escalate to.",
  },
];

// What this page does NOT claim. Listed because pretending the
// surface is risk-free is what gets a CISO to stop reading.
const honest = [
  {
    title: "Bolt does not review what a user writes",
    body: "Bolt is not an app store. There is no submission, no Sparcle approval, no automated scan of the YAML for intent. The user authors the script and the user owns the consequences. The runtime enforces structural safety; it cannot enforce that the user's intent is benign.",
  },
  {
    title: "User Apps live outside the admin PII masking boundary",
    body: "A User App that hits an external API with the user's auth can send data outside the masking layer admin policies enforce on the rest of Bolt. This is intentional. The user controls what their script does. It is also why admins on managed devices may want to disable the tier entirely.",
  },
  {
    title: "Sharing patterns are file-based, not marketplace",
    body: "If you want to share a User App, you share the YAML file. Gist, repo, internal pack. The recipient reads it, drops it in their folder, clicks Reload. There is no central registry, no signed-manifest verification yet, and no submission queue.",
  },
];
---
<BaseLayout
  title="Bolt Apps trust model | Sparcle"
  description="The trust contract for Bolt Apps. Three tiers (Built-in, Admin, User), three boundaries, five runtime-enforced properties, and the admin disable gate. Where data goes, whose identity runs the request, and what Sparcle servers see. The page a security team bookmarks."
  canonical="https://sparcle.app/apps/trust"
>
  <main class="page-apps-trust">
    <Hero
      eyebrow="Apps · Trust model"
      title="Three tiers. Three boundaries. One contract."
      lede="Bolt Apps are a chip ladder. What rides on the ladder is yours. The same runtime serves three audiences with three trust postures, and the boundary between them is enforced at exec time, not at policy review time. This page is the boundary, written out."
    >
      <a href="#truth" class="btn btn-primary btn-lg">Read the truth table</a>
      <a href="/apps" class="btn btn-secondary btn-lg">Back to Apps</a>
    </Hero>

    <PageSection
      id="disclosure"
      eyebrow="The User App disclosure"
      title="What a User App is, in four sentences."
      lede="This is the wording the Bolt Settings page shows the user when User Apps are enabled. It is also the wording we hold ourselves to on every other surface that describes the tier."
      stripe="b"
    >
      <div class="disclosure-card">
        <p>
          User Apps run, evaluate and process data that user authors on
          user's machine, under user's identity. No AI in the path. No
          Sparcle in the path. Read declarative YAML before you enable.
        </p>
      </div>
    </PageSection>

    <PageSection
      id="truth"
      eyebrow="The truth table"
      title="Who owns what, per tier."
      lede="Read top to bottom. Every cell maps to a runtime behavior the platform enforces; if a cell here drifts from the runtime, the runtime is the bug."
    >
      <div class="truth-table-wrap">
        <table class="truth-table">
          <thead>
            <tr>
              <th scope="col">Dimension</th>
              <th scope="col">Built-in Apps</th>
              <th scope="col">Admin Apps</th>
              <th scope="col">User Apps</th>
            </tr>
          </thead>
          <tbody>
            {truthRows.map((row) => (
              <tr>
                <th scope="row">{row.dim}</th>
                <td>{row.builtin}</td>
                <td>{row.admin}</td>
                <td>{row.user}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </PageSection>

    <PageSection
      id="guarantees"
      eyebrow="What the runtime enforces"
      title="Five properties. None of them author-configurable."
      lede="A manifest that tries to opt out of any of these is rejected at load time. A manifest that tries to smuggle past them at runtime never gets the chance: the executor and the row builder both stamp these properties on every output regardless of what the YAML asks for."
      stripe="b"
    >
      <CardGrid>
        {guarantees.map((g) => (
          <Card title={g.title} accent="success">
            <p>{g.body}</p>
          </Card>
        ))}
      </CardGrid>
    </PageSection>

    <PageSection
      id="cannots"
      eyebrow="The testable claim"
      title="Bolt does not multiply the user's authority."
      lede="A User App runs commands the user could already have run from their terminal. That is the strong version. The four properties below are the specific things a user's terminal does NOT do that Bolt also does not do."
    >
      <CardGrid>
        {cannots.map((c) => (
          <Card title={c.title}>
            <p>{c.body}</p>
          </Card>
        ))}
      </CardGrid>
    </PageSection>

    <PageSection
      id="admin-gate"
      eyebrow="Admin disable"
      title="On a managed device, admins can turn User Apps off."
      lede="Settings, Utilities, User Apps. One toggle. When off, installed Apps stop loading, the launcher detector stops proposing user chips, and invocation refuses at the runtime boundary. Manifest files on disk are kept so re-enabling restores the user's setup identically."
      stripe="b"
    >
      <CardGrid cols={2}>
        <Card eyebrow="Shipped today" title="Device-level toggle">
          <p>
            The Allow User Apps toggle is per-device. An admin who manages
            the OS image (MDM, JAMF, Intune) can pre-write the policy
            file to disabled before the user ever opens Bolt.
          </p>
          <p>
            Path: <code>&lt;app_data&gt;/user-apps-policy.json</code>
            with <code>{"{ \"enabled\": false }"}</code>.
          </p>
        </Card>
        <Card eyebrow="Coming" title="Org-pushed policy">
          <p>
            The same toggle, propagated from the admin tenant down to
            every device on first connect. Removes the need to write the
            policy file via MDM and gives the admin a single dashboard
            view of which devices honor the gate.
          </p>
          <p>
            Until that ships, admins who need org-wide enforcement can
            use the MDM path above.
          </p>
        </Card>
      </CardGrid>
    </PageSection>

    <PageSection
      id="honest"
      eyebrow="What this page does not claim"
      title="The honest map."
      lede="A trust page that does not say what it cannot promise is marketing, not a contract. These are the things the runtime cannot enforce and we will not pretend it does."
    >
      <CardGrid>
        {honest.map((h) => (
          <Card title={h.title}>
            <p>{h.body}</p>
          </Card>
        ))}
      </CardGrid>
    </PageSection>

    <CTAStrip>
      <Fragment slot="title">Build, install, or audit with the same trust contract.</Fragment>
      <Fragment slot="lede">The boundary is the same whether you are authoring an App, deploying it for the org, or reviewing the security posture. Start from the Apps overview or jump into the spec.</Fragment>
      <a href="/apps" class="btn btn-primary btn-lg">Apps overview</a>
      <a href="/docs/utilities/spec" class="btn btn-secondary btn-lg">Manifest spec</a>
    </CTAStrip>
  </main>
</BaseLayout>

<style>
  .disclosure-card {
    border: 1px solid var(--brand-primary-light);
    border-left: 4px solid var(--brand-primary);
    background: var(--bg-surface-solid);
    border-radius: var(--radius-lg);
    padding: 1.5rem 1.75rem;
    max-width: 760px;
    margin: 0 auto;
  }
  .disclosure-card p {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--text-heading);
  }

  .truth-table-wrap {
    width: 100%;
    overflow-x: auto;
  }
  .truth-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.92rem;
    background: var(--bg-surface-solid);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .truth-table th,
  .truth-table td {
    border: 1px solid var(--border-subtle);
    padding: 0.65rem 0.9rem;
    text-align: left;
    vertical-align: top;
    line-height: 1.55;
  }
  .truth-table thead th {
    background: var(--bg-muted);
    color: var(--text-heading);
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .truth-table tbody th {
    background: var(--bg-muted);
    font-weight: 600;
    color: var(--text-heading);
    width: 22%;
  }
  .truth-table tbody td {
    color: var(--text-body);
  }
</style>
