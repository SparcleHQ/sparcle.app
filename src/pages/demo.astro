---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/ui/Hero.astro";
import PageSection from "../components/ui/PageSection.astro";
import FAQ from "../components/ui/FAQ.astro";

// Set PUBLIC_CALENDLY_URL in .env (or Cloudflare env) to enable inline booking.
// e.g. PUBLIC_CALENDLY_URL=https://calendly.com/your-org/sparcle-demo
// Until then the page renders the contact-modal CTA as the primary path.
const calendlyUrl = import.meta.env.PUBLIC_CALENDLY_URL ?? "";

const formats = [
  {
    metric: "15 min",
    label: "Quick Walkthrough",
    body: "Bolt + Aeira live in a single browser tab. Best for an initial &ldquo;is this real&rdquo; check.",
  },
  {
    metric: "30 min",
    label: "Technical Demo",
    body: "Live install on your laptop, your data, your AI key. ACL personas, audit chain, crypto-shred shown end-to-end.",
  },
  {
    metric: "45 min",
    label: "Architecture Review",
    body: "Whiteboard your environment. Identity, deployment, LLM choice, governance contract. Right format for security and platform teams.",
  },
];

const faqs = [
  {
    question: "Who runs the demo?",
    answer:
      "<p>You will be on a call with the founding team. No SDR, no BDR, no scripted pitch. We use the time to understand your workload and show you the parts of the product that fit it.</p>",
  },
  {
    question: "Will my data leave my network during the demo?",
    answer:
      "<p>No. The product runs as a local sidecar on your laptop. We will ask you to turn off WiFi during part of the demo so you can verify it.</p>",
  },
  {
    question: "Do I need to share anything beforehand?",
    answer:
      "<p>Just the form. If you want a custom demo on your own data, tell us what tools you use (Microsoft 365 / Google / your DMS / your CRM) and we will pre-configure the connector list.</p>",
  },
  {
    question: "Can I bring a security or compliance reviewer?",
    answer:
      "<p>Encouraged. The 45-minute architecture review is built for that conversation. We will share the architecture diagram, audit-chain primitives, and a draft DPA in advance if you ask.</p>",
  },
  {
    question: "What happens after the call?",
    answer:
      "<p>If there is fit, we send a one-page proposal within 24 hours: scope, success criteria, price, and timeline. No pressure if the fit is not there; we will tell you that too.</p>",
  },
];
---

<BaseLayout
  title="Book a Demo — Bolt + Aeira | Sparcle"
  description="15-minute walkthrough, 30-minute technical demo, or 45-minute architecture review. Live product, your data, your laptop. Founder-led."
  canonical="https://sparcle.app/demo"
>
  <main class="page-demo">
    <Hero
      eyebrow="Book a Demo"
      title="See Bolt and Aeira live. <strong>On your laptop. Your data.</strong>"
      lede="Three formats, founder-led, no slides. Pick the one that fits the conversation you need to have."
    />

    <PageSection stripe="b" width="content">
      <div class="demo-booking-split">
        <div class="demo-booking-split__left">
          {calendlyUrl ? (
            <div class="demo-calendly-wrap">
              <iframe
                src={calendlyUrl}
                class="demo-calendly-iframe"
                title="Book a demo with Sparcle"
                loading="lazy"
              />
              <p class="demo-calendly-fallback">
                Trouble seeing the calendar?
                <a href="#" onclick="openContactModal('Demo Booking'); return false;">Send us your preferred times</a>
                and we will confirm within one business day.
              </p>
            </div>
          ) : (
            <div class="demo-cta-card">
              <div class="demo-cta-card__eyebrow">Reach the founding team</div>
              <h3 class="demo-cta-card__title">Request a demo slot</h3>
              <p class="demo-cta-card__lede">
                Tell us 1) what work you want AI to help with, 2) the tools your team already uses, and
                3) two windows that work this week or next. We confirm within one business day.
              </p>
              <div class="demo-cta-card__actions">
                <a href="#" onclick="openContactModal('Demo Booking'); return false;" class="btn btn-primary btn-lg">
                  Request a Demo
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14M12 5l7 7-7 7" />
                  </svg>
                </a>
                <a href="/download" class="btn btn-secondary btn-lg">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
                  </svg>
                  Try it now (7-day Trial)
                </a>
              </div>
              <p class="demo-cta-card__note">
                Or email <a href="mailto:bolt@sparcle.app?subject=Demo%20Booking">bolt@sparcle.app</a>
                and we will route directly to a founder.
              </p>
            </div>
          )}
        </div>

        <aside class="demo-booking-split__right">
          <p class="demo-formats-eyebrow">Pick the format</p>
          <h3 class="demo-formats-heading">Three calls, your choice.</h3>
          <p class="demo-formats-sub">No standard demo. The right format depends on whether you are scoping the problem or scoping the rollout.</p>
          <ul class="demo-format-list">
            {formats.map((f) => (
              <li class="demo-format-item">
                <div class="demo-format-item__metric">{f.metric}</div>
                <div class="demo-format-item__copy">
                  <h4 class="demo-format-item__label">{f.label}</h4>
                  <p class="demo-format-item__body" set:html={f.body} />
                </div>
              </li>
            ))}
          </ul>
        </aside>
      </div>
    </PageSection>

    <PageSection
      eyebrow="What you will see"
      title="A real product, not a recording"
      stripe="a"
      width="prose"
      align="left"
    >
      <ul class="demo-checklist">
        <li><strong>Local sidecar install</strong> on a real laptop in front of you. Cmd-Space launcher, scoped actions, MCP tool calls.</li>
        <li><strong>ACL personas in action.</strong> Same query, three different identities, three different result sets. The product enforces what each user is entitled to see.</li>
        <li><strong>Audit chain verifier.</strong> Sealed Merkle chain, signed envelopes, byte-stable replay. Bring a CISO; they will ask for this.</li>
        <li><strong>Crypto-shred for right-to-erasure.</strong> Persistent across process restart. Two dedicated tests behind it.</li>
        <li><strong>BYO LLM.</strong> Swap the model provider live. The data path does not change; the compliance posture does not change.</li>
        <li><strong>Your tool stack.</strong> If you share your stack ahead of time we pre-configure the MCP connectors so the demo runs against your actual surface.</li>
      </ul>
    </PageSection>

    <FAQ items={faqs} stripe="a" />
  </main>
</BaseLayout>

<style is:global>
  .demo-calendly-wrap {
    background: var(--bg-surface-solid);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    padding: 0.5rem;
    box-shadow: var(--shadow-md);
  }
  .demo-calendly-iframe {
    width: 100%;
    height: 720px;
    border: 0;
    border-radius: var(--radius-md);
    display: block;
  }
  .demo-calendly-fallback {
    text-align: center;
    color: var(--text-muted);
    font-size: 0.875rem;
    margin: 0.75rem 0 0.25rem;
  }
  .demo-calendly-fallback a {
    color: var(--brand-primary);
    text-decoration: underline;
    margin-left: 0.25rem;
  }

  /* 2-column booking split — left holds the Calendly iframe OR the
     request-card fallback; right holds the format previews. Keeps the
     section visually balanced when the iframe isn't wired yet. */
  .demo-booking-split {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
    gap: 3rem;
    align-items: start;
  }
  @media (max-width: 880px) {
    .demo-booking-split {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
  .demo-booking-split__left {
    min-width: 0;
  }
  .demo-booking-split__right {
    min-width: 0;
  }

  .demo-formats-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--brand-primary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 0.5rem;
  }
  .demo-formats-heading {
    font-size: clamp(1.25rem, 2.2vw, 1.5rem);
    font-weight: 700;
    color: var(--text-heading);
    margin: 0 0 0.5rem;
    font-family: var(--font-display);
    letter-spacing: -0.01em;
  }
  .demo-formats-sub {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-muted);
    margin: 0 0 1.5rem;
  }
  .demo-format-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.85rem;
  }
  .demo-format-item {
    display: grid;
    grid-template-columns: 78px 1fr;
    gap: 1rem;
    align-items: start;
    background: var(--bg-surface-solid);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    padding: 1rem 1.1rem;
  }
  .demo-format-item__metric {
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--brand-primary);
    letter-spacing: -0.01em;
    padding-top: 0.1rem;
  }
  .demo-format-item__copy {
    min-width: 0;
  }
  .demo-format-item__label {
    margin: 0 0 0.25rem;
    font-size: 0.98rem;
    font-weight: 700;
    color: var(--text-heading);
    font-family: var(--font-display);
  }
  .demo-format-item__body {
    margin: 0;
    font-size: 0.86rem;
    line-height: 1.55;
    color: var(--text-muted);
  }

  .demo-cta-card {
    background: var(--bg-surface-solid);
    border: 1px solid var(--border-default);
    border-left: 4px solid var(--brand-primary);
    border-radius: var(--radius-lg);
    padding: 2.5rem 2.25rem;
    max-width: 720px;
    width: 100%;
    box-shadow: var(--shadow-md);
  }
  .demo-cta-card__eyebrow {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--brand-primary);
    background: var(--brand-primary-light);
    padding: 0.35rem 0.75rem;
    border-radius: var(--radius-full);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .demo-cta-card__title {
    font-size: clamp(1.4rem, 2.4vw, 1.75rem);
    font-weight: 700;
    color: var(--text-heading);
    margin: 0 0 0.75rem;
    font-family: var(--font-display);
    letter-spacing: -0.02em;
  }
  .demo-cta-card__lede {
    color: var(--text-body);
    line-height: 1.65;
    margin: 0 0 1.5rem;
  }
  .demo-cta-card__actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .demo-cta-card__note {
    margin: 1.25rem 0 0;
    color: var(--text-muted);
    font-size: 0.85rem;
  }
  .demo-cta-card__note a {
    color: var(--brand-primary);
    text-decoration: underline;
  }
  @media (max-width: 640px) {
    .demo-cta-card { padding: 1.75rem 1.5rem; }
    .demo-cta-card__actions .btn { width: 100%; }
  }

  .demo-checklist {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.85rem;
  }
  .demo-checklist li {
    position: relative;
    padding-left: 1.75rem;
    color: var(--text-body);
    line-height: 1.65;
  }
  .demo-checklist li::before {
    content: "✓";
    position: absolute;
    left: 0;
    top: 0.1rem;
    color: var(--color-success-strong);
    font-weight: 700;
  }
  .demo-checklist li strong { color: var(--text-heading); }
</style>
