<button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle theme" aria-pressed="false">
  <span class="theme-toggle__sun">Sun</span>
  <span class="theme-toggle__moon">Moon</span>
</button>

<script is:inline>
  const root = document.documentElement;
  const btn = document.getElementById("theme-toggle");

  const applyTheme = (theme) => {
    root.setAttribute("data-theme", theme);
    if (btn) {
      const pressed = theme === "dark" ? "true" : "false";
      btn.setAttribute("aria-pressed", pressed);
    }
  };

  const initial = localStorage.getItem("theme") || root.getAttribute("data-theme") || "dark";
  applyTheme(initial);

  btn?.addEventListener("click", () => {
    const next = root.getAttribute("data-theme") === "dark" ? "light" : "dark";
    localStorage.setItem("theme", next);
    applyTheme(next);
  });
</script>