---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/ui/Hero.astro";
import PageSection from "../../components/ui/PageSection.astro";
import CardGrid from "../../components/ui/CardGrid.astro";
import Card from "../../components/ui/Card.astro";
import CTAStrip from "../../components/ui/CTAStrip.astro";

const frameworks = [
  ["SOX (Sarbanes-Oxley, Sections 302 / 404)", "ICFR-relevant records must be retained, attestable, and tamper-evident. Bolt's Ed25519-signed Merkle audit chain is designed to satisfy the integrity requirement; the standalone verifier is the artifact your auditor runs against the chain."],
  ["SEC Rule 17a-4 + FINRA 4511", "Broker-dealer record-keeping. Records must be retained in WORM or equivalent non-rewritable, non-erasable format. Aeira's WORM-eligible storage path plus the cryptographic-disposal construction is designed to support both retention AND erasure obligations via the same primitive."],
  ["GLBA + NYDFS Part 500", "Customer financial information protection. Bolt's PII masking at the LLM boundary, identity-bound retrieval, and audit-trail responses are the building blocks GLBA and NYDFS require for AI-touching workflows."],
  ["GDPR Art. 17 / 28 (when EU customer data is present)", "Cryptographic erasure is designed to satisfy Right-to-be-Forgotten obligations while preserving SEC and FINRA retention duties. Erasure-with-retention via the same primitive — detailed at /trust/cryptographic-erasure."],
];

const residency = [
  ["WORM-eligible audit chain", "Aeira's audit chain pairs with S3 Object Lock, Azure Immutable Blob, or any object-lock-supporting storage. The chain is byte-stable; replay produces identical bytes."],
  ["Customer-held KMS", "Vault Transit, AWS KMS, Azure Key Vault, or PKCS#11 HSM. The crypto-shred construction means Sparcle cannot read tenant data without the customer-held CMK."],
  ["Erasure-with-retention via one primitive", "Cryptographic disposal of the per-tenant CMK destroys readability; WORM ciphertext remains on the shelf. SOX/SEC retention auditor sees the record; GDPR auditor sees the disposal receipt. Both verifiable."],
  ["Trading-floor and ops latency", "p95 retrieval target ≤ 200ms on 100M-doc tenants — the first published benchmark ships during pilot. Aeira's keyword + vector + graph fusion is sharded for desk-side response latencies."],
];

const workflows = [
  ["Trade-surveillance review", "Cross-source synthesis across order management, communications surveillance, and policy. Authority Policy ranks current policy above superseded; identity-bound retrieval respects desk-and-role scopes."],
  ["KYC and counterparty research", "Multi-source synthesis with citation hygiene. The Authority Policy demotes outdated or rescinded source-of-record material below the cut."],
  ["Regulatory filing prep (10-K, 13-F, ADV)", "Pull authoritative material from internal source-of-record systems; every cited authority resolves; audit chain captures provenance for the auditor."],
  ["Audit and IG response", "Time-bounded audit-chain export with the standalone verifier binary. The auditor runs the verifier; Sparcle is not in the verification loop."],
];

const trustDossier = [
  ["/trust/cryptographic-erasure", "The construction designed to satisfy GDPR Art. 17 erasure AND SEC 17a-4 retention obligations with one primitive. The packet your auditor receives."],
  ["/trust/verify", "The standalone audit-chain verifier. Your auditor runs it offline. The artifact a SOX or SEC audit pack relies on."],
  ["/trust/incident-response", "Five-phase response framework with severity SLAs. The runbook a CISO at a regulated financial institution expects."],
  ["/trust/where-the-model-runs", "How customer financial data is masked before any outbound LLM call; how the three deployment modes compare for trading-floor latency budgets."],
];
---
<BaseLayout
  title="Sparcle for Financial Services | SOX · FINRA · SEC 17a-4 · GLBA"
  description="Sovereign AI for regulated finance. WORM-eligible audit chain, customer-held KMS, cryptographic disposal designed to satisfy GDPR Art. 17 and SEC 17a-4 obligations with the same primitive. Trust artifacts, vertical workflows, and a 1-page printable brief."
  canonical="https://sparcle.app/solutions/finance"
>
  <link slot="head" rel="stylesheet" href="/css/vertical-page.css" />
  <main class="page-vertical">
    <Hero
      eyebrow="Sparcle for Financial Services"
      title="Erasure and retention. One primitive."
      lede="Regulated finance has a structural contradiction: GDPR demands erasure, SEC and FINRA demand retention. Bolt and Aeira resolve it with one cryptographic primitive &mdash; disposal of the per-tenant key destroys readability while WORM ciphertext remains on the shelf. Both auditors satisfied. The verifier binary is in your hands; Sparcle is not in the loop."
    >
      <a href="#" onclick="openContactModal('Finance Architecture Review'); return false;" class="btn btn-primary btn-lg">Schedule finance review</a>
      <a href="/docs/pdfs/vertical-finance.pdf" target="_blank" rel="noopener" class="btn btn-secondary btn-lg">Download 1-page brief</a>
    </Hero>

    <PageSection
      eyebrow="Compliance frameworks"
      title="What Sparcle ships against."
      lede="Financial services compliance is the intersection of SOX, SEC 17a-4, FINRA 4511, GLBA, NYDFS Part 500, and increasingly GDPR Art. 17 when EU customer data is present. Each frame below maps to concrete implementation."
      stripe="b"
    >
      <div class="vertical-list">
        {frameworks.map((row) => (
          <article class="vertical-list__item">
            <h3 class="vertical-list__title">{row[0]}</h3>
            <p class="vertical-list__body">{row[1]}</p>
          </article>
        ))}
      </div>
    </PageSection>

    <PageSection
      eyebrow="Data residency posture"
      title="WORM and key custody, owned by you."
      stripe="a"
    >
      <CardGrid cols={2}>
        {residency.map((row) => (
          <Card title={row[0]}>{row[1]}</Card>
        ))}
      </CardGrid>
    </PageSection>

    <PageSection
      eyebrow="1-page brief"
      title="Take this to your CCO and your auditor."
      lede="The finance-vertical brief covers SOX and SEC posture, WORM-eligible storage, the cryptographic-disposal construction, and the trust artifacts an auditor reviews."
      stripe="b"
    >
      <div class="vertical-pdf-embed" data-expandable tabindex="0" role="button" aria-label="Expand finance vertical brief">
        <iframe
          src="/docs/pdfs/vertical-finance.pdf#view=FitH"
          title="Sparcle for Finance — 1-page brief"
          loading="lazy"
        ></iframe>
      </div>
      <p class="vertical-pdf-actions">
        <a href="/docs/pdfs/vertical-finance.pdf" class="btn btn-secondary btn-lg" download>Download PDF</a>
        <a href="/docs/pdfs/vertical-finance.pdf" target="_blank" rel="noopener" class="btn btn-tertiary btn-lg">Open in new tab &nearr;</a>
      </p>
    </PageSection>

    <PageSection
      eyebrow="Workflows the founding team has built for"
      title="Four anchor use cases."
      lede="The workflows below are scoped with regulated-finance design partners. The Authority Policy SDK and connector configuration are the per-customer tuning points."
      stripe="a"
    >
      <CardGrid cols={2}>
        {workflows.map((row) => (
          <Card title={row[0]}>{row[1]}</Card>
        ))}
      </CardGrid>
    </PageSection>

    <PageSection
      eyebrow="Trust dossier for finance"
      title="The four artifacts your CCO and your auditor will ask for."
      stripe="b"
      width="prose"
      align="left"
    >
      <ul class="vertical-dossier">
        {trustDossier.map((row) => (
          <li><a href={row[0]}>{row[0]}</a> &mdash; {row[1]}</li>
        ))}
      </ul>
    </PageSection>

    <CTAStrip
      variant="band"
      title="Want to walk this against your specific recordkeeping posture?"
      lede="A 30-minute finance architecture review covers your SEC and FINRA obligations, your WORM storage choice, your KMS custody, and the workflows your desks need. Founder-led; the engineering team is on the call."
    >
      <a href="#" onclick="openContactModal('Finance Architecture Review'); return false;" class="btn btn-primary btn-lg">Schedule finance review</a>
      <a href="/solutions" class="btn btn-secondary btn-lg">All industries</a>
    </CTAStrip>
  </main>
</BaseLayout>
