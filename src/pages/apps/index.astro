---
import { Code } from "astro:components";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/ui/Hero.astro";
import PageSection from "../../components/ui/PageSection.astro";
import CardGrid from "../../components/ui/CardGrid.astro";
import Card from "../../components/ui/Card.astro";
import CTAStrip from "../../components/ui/CTAStrip.astro";

// The four-beat in-and-out arc. Bolt's value proposition is not "do
// more in Bolt", it is "do the one thing you needed without leaving
// what you were already in." Bolt is keyboard-summoned, the
// App runs, you act on the result, you dismiss and you are back
// where you started. Utilities are the unit that makes this true.
const arc = [
  {
    badge: "Bring",
    title: "Pull a workflow into reach",
    body: "You are in a terminal, a browser tab, a meeting, an app. Bolt is one keystroke away on every screen. Bolt comes to you; you do not switch context.",
  },
  {
    badge: "Invoke",
    title: "Type the chip",
    body: "= then the chip key then a short query. Built-in, admin-blessed, or one of yours. Bolt renders a Press Enter to run row so nothing fires until you commit.",
  },
  {
    badge: "Act",
    title: "Use the result",
    body: "Copy a value, open a link, paste into a composer, route to another chip. Action buttons are declared in the manifest; Bolt renders them. Results show in the dropdown and the right-side preview pane.",
  },
  {
    badge: "Return",
    title: "Dismiss and you are back",
    body: "Hit Esc, Bolt vanishes, you are exactly where you were. The window you were reading is still in focus. The cursor in the terminal is still in position. The flow you were in did not break.",
  },
];

// Three-tier App taxonomy. Built-in Apps are part of the Bolt app and
// authored by Sparcle. Admin Apps are YAML manifests an org admin
// blesses centrally; they route through the customer's Bolt service
// inside the customer perimeter. User Apps are YAML manifests a
// single user drops into a local folder; they execute on the user's
// own machine and never contact Sparcle servers.
const layers = [
  {
    badge: "Built-in Apps",
    title: "Shipped with Bolt",
    intent: "Pure-client Apps that resolve as you type. Math, date arithmetic, timezones, units, dictionary, color, QR. No network for any of these.",
    examples: "=calc, =date, =tz, =unit, =def, =color, =qr",
    runsWhere: "In-process in the desktop binary.",
    authoredBy: "Sparcle. Updated with the app.",
  },
  {
    badge: "Admin Apps",
    title: "Bring your stack",
    intent: "YAML manifests an admin enables centrally. They route through the customer's Bolt service inside the customer perimeter, against the systems the org has connected. Per-user credentials stay in the customer's vault.",
    examples: "=jira, =stripe, =confluence, =linear, =hubspot",
    runsWhere: "Inside the customer perimeter, against the org's connected systems.",
    authoredBy: "The customer's admin, in Settings.",
  },
  {
    badge: "User Apps",
    title: "Bring your shell. Bring your script. Bring your tools.",
    intent: "YAML manifests a single user drops into a local folder. Each one runs a command on the user's own machine. Sparcle servers are not in the request path. Admins can disable User Apps entirely on a managed device.",
    examples: "=disk, =git-log, =myip, =gitstatus, =ports",
    runsWhere: "On your machine, end-to-end local. Never contacts Sparcle servers.",
    authoredBy: "You. Drop a YAML, click Reload.",
  },
];

// The five non-negotiable properties of the User App runtime.
// Each one corresponds to a check the loader or executor enforces;
// none of them are author-configurable.
const guarantees = [
  {
    title: "Confirm before run",
    body: "Bolt renders a 'Press Enter to run' row instead of firing the shell command on every keystroke. Authors can customize the prompt copy but cannot turn confirm off. Shell exec on incremental input would mean a process spawn per character; the runtime refuses to ship that.",
  },
  {
    title: "Never an LLM tool",
    body: "User Apps are never registered as agent tools and never appear in the LLM's tool-use surface. The agent loop does not know they exist. A poisoned document cannot tell the model to run your App because the model cannot run anything.",
  },
  {
    title: "Never staged into chat context",
    body: "App output never auto-attaches to a chat message. The chat composer's attachment surface accepts entity and plugin context, not App rows. Output stays in the dropdown and the right-side preview pane; the LLM only sees it if you copy and paste it yourself.",
  },
  {
    title: "argv-only execution",
    body: "Templated commands are tokenized into argv via POSIX shell rules and spawned directly. There is no /bin/sh -c. Multi-statement shell, pipes, command substitution, and backticks are rejected at validate time, before the manifest ever loads.",
  },
  {
    title: "Forced safety fields",
    body: "Every row the runtime emits gets canEscalateAi=false, source=user_bridge, and pii_boundary=enforce stamped on it regardless of what the YAML asks for. Forbidden right-pane kinds (such as entity-graph bindings) are rejected at load time so a manifest cannot graft itself onto Bolt's entity router.",
  },
];

// Authoring shape: a real, self-contained manifest. Kept short on
// purpose so the page reads as 'this is the whole thing' rather than
// 'here is one corner of a sprawling spec'. Full spec link below.
const sampleYaml = `schema_version: 1
runtime: bridge
id: git-log
chip: git-log
title: Recent commits
icon: git-branch
description: Show recent commits in a local git repo under ~/dev
placeholder_examples: ["my-app", "infra 30"]
emits: Generic

bridge:
  command:
    macos:   "git -C ~/dev/{{repo}} log --oneline -{{limit | default: 20}}"
    linux:   "git -C ~/dev/{{repo}} log --oneline -{{limit | default: 20}}"
    windows: 'git -C C:\\dev\\{{repo}} log --oneline -{{limit | default: 20}}'
  parse: lines
  timeout_seconds: 5

args:
  - { name: repo,  from: "query.word(0)" }
  - { name: limit, from: "query.word(1)", default: 20 }

presentation:
  widget: list
  title_field: line
  subtitle_field: idx

actions:
  - { id: copy, kind: composer, target: row, label: Copy SHA, insert: "{{line}}" }`;

// Honest "what is shipped vs what is design" framing. This page must
// match the runtime behavior; if a check is here and the runtime does
// not enforce it, that is a bug to fix, not a claim to soften.
const honest = [
  {
    title: "What is shipped",
    body: "The User App runtime, the YAML manifest loader and validator, the confirm-row dispatch, the right-side preview pane (card kind), the chained action that routes to another chip, the Settings page to install and remove Apps, and the device-level Allow User Apps policy gate. Five non-negotiable safety properties are enforced at runtime, not at policy review time.",
  },
  {
    title: "What we do not claim",
    body: "We do not claim that a shell script a user writes is automatically safe. The user wrote the script; the trust model is the same as cron, a shell alias, or a script in their PATH. What we do guarantee is that the Bolt surface does not multiply that trust. Bolt cannot be tricked by a remote model into invoking a User App, and a User App's output cannot leak into a chat context the user did not explicitly stage.",
  },
  {
    title: "What is coming",
    body: "Additional right-pane widget kinds beyond card. A signed manifest format so a team can share Apps without re-authoring trust on every install. A scoped read-only data tier for Apps that only need to expose information to Bolt without arbitrary shell access. An org-pushed policy that propagates the Allow User Apps gate from the admin tenant down to managed devices.",
  },
];
---
<BaseLayout
  title="Bolt Apps: built-in, admin, and yours | Sparcle"
  description="Bolt Apps are launcher chips you summon from any context on any OS. Built-in Apps ship with Bolt. Admin Apps are YAML manifests the customer's admin enables. User Apps are YAML manifests an individual drops into a local folder. The user tier runs end-to-end on the user's machine and never contacts Sparcle servers."
  canonical="https://sparcle.app/apps"
>
  <main class="page-apps">
    <Hero
      eyebrow="Apps"
      title="The surface you are already in."
      lede="Whatever you have open, terminal or browser or a specific app, Bolt is one keystroke away. Bring a workflow into reach, invoke it, act on the result, and return to what you were doing without losing your place. Bolt Apps are the chips that make this work. Some ship with Bolt, some your admin blesses for the org, and some you author yourself and drop into a folder on your own machine. Think of them as VS Code extensions for your launcher."
    >
      <a href="#arc" class="btn btn-primary btn-lg">Bring, invoke, act, return</a>
      <a href="/apps/trust" class="btn btn-secondary btn-lg">Read the trust model</a>
    </Hero>

    <PageSection
      id="arc"
      eyebrow="The four-beat arc"
      title="Bring. Invoke. Act. Return."
      lede="Bolt is not asking you to live in a new app. It is asking for the few seconds between you noticing you need something and you having what you needed. Bolt comes to you, the App runs, you act on the result, you dismiss. Whatever you were in stays the way you left it."
    >
      <CardGrid>
        {arc.map((step) => (
          <Card eyebrow={step.badge} title={step.title}>
            <p>{step.body}</p>
          </Card>
        ))}
      </CardGrid>
    </PageSection>

    <PageSection
      id="layers"
      eyebrow="The three layers"
      title="Built-in, admin, and yours."
      lede="The same chip ladder serves three audiences. The runtime is uniform; what differs is who authors the chip, who blesses it, and where the request goes."
      stripe="b"
    >
      <CardGrid>
        {layers.map((layer) => (
          <Card eyebrow={layer.badge} title={layer.title}>
            <p>{layer.intent}</p>
            <p><strong>Examples</strong>: <code>{layer.examples}</code></p>
            <p><strong>Runs where</strong>: {layer.runsWhere}</p>
            <p><strong>Authored by</strong>: {layer.authoredBy}</p>
          </Card>
        ))}
      </CardGrid>
    </PageSection>

    <PageSection
      id="how"
      eyebrow="The user-tier path"
      title="Where the request goes when you type a user chip."
      lede="The user tier is the most interesting one to map because it is the most private. Typing =git-log &lt;repo&gt; fires a shell command on your machine, parses the output, renders the rows in Bolt, and shows the right-side preview pane. The path is end-to-end local. Sparcle servers see only optional audit metadata, never the query, never the output."
    >
      <div class="user-app-diagram">
        <svg viewBox="0 0 880 620" class="topology-svg" role="img" aria-labelledby="user-flow-title user-flow-desc">
          <title id="user-flow-title">User App request path</title>
          <desc id="user-flow-desc">The Bolt UI detects the user chip and hands the request to the Bolt App Runtime on the same machine. The Bolt App Runtime resolves the YAML manifest, builds a safe argv command, runs it through a secure shell with a timeout, parses stdout into rows, and returns them to the UI for rendering. Sparcle servers receive only an optional audit ping carrying App id, timestamp, ok flag, and duration. No query, no arguments, no output.</desc>

          <defs>
            <marker id="u-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
              <path class="u-arrow-head" d="M0,0 L10,5 L0,10 z" />
            </marker>
          </defs>

          <style>
            .u-perimeter { fill: none; stroke: var(--text-muted); stroke-width: 1.5; stroke-dasharray: 8 5; opacity: 0.55; }
            .u-perimeter-label { font: 600 12px var(--font-display); fill: var(--text-muted); letter-spacing: 0.06em; text-transform: uppercase; }
            .u-box { fill: var(--bg-surface-solid); stroke: var(--border-default); stroke-width: 1.5; rx: 10; ry: 10; }
            .u-box-accent { stroke: var(--brand-primary); stroke-width: 2; }
            .u-box-title { font: 600 14px var(--font-display); fill: var(--text-heading); }
            .u-box-sub { font: 12px var(--font-mono, ui-monospace); fill: var(--text-muted); }
            .u-arrow-line { fill: none; stroke: var(--text-body); stroke-width: 1.5; }
            .u-arrow-head { fill: var(--text-body); }
            .u-arrow-label { font: 500 11px var(--font-display); fill: var(--text-muted); }
            .u-callout { fill: var(--bg-muted); stroke: var(--brand-primary-light); stroke-width: 1; rx: 8; ry: 8; }
            .u-callout-title { font: 700 12px var(--font-display); fill: var(--brand-primary); letter-spacing: 0.06em; text-transform: uppercase; }
            .u-callout-body { font: 13px var(--font-display); fill: var(--text-body); }
          </style>

          <rect class="u-perimeter" x="20" y="40" width="600" height="540" />
          <text class="u-perimeter-label" x="40" y="62">Your machine</text>

          <rect class="u-box u-box-accent" x="60" y="100" width="500" height="80" />
          <text class="u-box-title" x="80" y="130">Bolt UI</text>
          <text class="u-box-sub" x="80" y="152">User types  =git-log &lt;repo&gt;</text>
          <text class="u-box-sub" x="80" y="168">Confirm row renders. Enter to commit.</text>

          <path class="u-arrow-line" d="M310 188 L310 230" marker-end="url(#u-arrow)" />
          <text class="u-arrow-label" x="320" y="212">Local request, never crosses the network</text>

          <rect class="u-box" x="60" y="240" width="500" height="80" />
          <text class="u-box-title" x="80" y="270">Bolt App Runtime</text>
          <text class="u-box-sub" x="80" y="292">Resolves the manifest, builds a safe argv.</text>
          <text class="u-box-sub" x="80" y="308">No shell metacharacters. Multi-statement blocked.</text>

          <path class="u-arrow-line" d="M310 328 L310 370" marker-end="url(#u-arrow)" />
          <text class="u-arrow-label" x="320" y="352">Run with timeout</text>

          <rect class="u-box" x="60" y="380" width="500" height="80" />
          <text class="u-box-title" x="80" y="410">Secure shell</text>
          <text class="u-box-sub" x="80" y="432">stdout, stderr, exit code</text>
          <text class="u-box-sub" x="80" y="448">Parser turns lines or JSON into rows.</text>

          <path class="u-arrow-line" d="M310 460 L310 500" marker-end="url(#u-arrow)" />
          <text class="u-arrow-label" x="320" y="484">Rows and preview binding</text>

          <rect class="u-box u-box-accent" x="60" y="510" width="500" height="50" />
          <text class="u-box-title" x="80" y="540">Results render in Bolt UI</text>

          <rect class="u-callout" x="660" y="240" width="200" height="180" />
          <text class="u-callout-title" x="676" y="266">Optional</text>
          <text class="u-callout-body" x="676" y="292"><tspan x="676" dy="0">Sparcle servers see only</tspan><tspan x="676" dy="18">an audit ping with</tspan><tspan x="676" dy="18">App id, timestamp,</tspan><tspan x="676" dy="18">ok flag, duration ms.</tspan><tspan x="676" dy="22">No query. No args.</tspan><tspan x="676" dy="18">No output.</tspan></text>

          <path class="u-arrow-line" d="M560 540 L760 540 L760 420" marker-end="url(#u-arrow)" stroke-dasharray="4 4" />
        </svg>
      </div>
    </PageSection>

    <PageSection
      id="guarantees"
      eyebrow="The runtime guarantees"
      title="Five properties the runtime enforces."
      lede="None of these are author-configurable. A manifest that tries to opt out of any of them is rejected at load time."
      stripe="b"
    >
      <CardGrid>
        {guarantees.map((g) => (
          <Card title={g.title} accent="success">
            <p>{g.body}</p>
          </Card>
        ))}
      </CardGrid>
    </PageSection>

    <PageSection
      id="manifest"
      eyebrow="The manifest"
      title="A whole App in 25 lines of YAML."
      lede="The example below installs a chip that runs git log in a local repo and shows the commit lines in Bolt. Drop it in your user-apps folder, click Reload, then type =git-log &lt;repo&gt; to try it."
    >
      <div class="manifest-block">
        <Code code={sampleYaml} lang="yaml" theme="github-dark" />
      </div>
    </PageSection>

    <PageSection
      id="install"
      eyebrow="Get started"
      title="Drop a file, click Reload."
      lede="The install flow is the most boring part. There is no package manager, no signed-release pipeline, no consent dialog. Copying a file into a folder is the consent."
      stripe="b"
    >
      <CardGrid>
        <Card eyebrow="1" title="Open the folder">
          <p>In Bolt, go to Settings, then Utilities, then User Utilities. Click Open folder.</p>
          <p>Your OS file manager opens the path Bolt reads at startup.</p>
        </Card>
        <Card eyebrow="2" title="Drop in a YAML">
          <p>Paste the example above into a file named <code>git-log.yaml</code>, or any other manifest you have.</p>
          <p>One file per App. Filename is cosmetic; the <code>id</code> field is what binds the chip.</p>
        </Card>
        <Card eyebrow="3" title="Click Reload">
          <p>Back in Settings, click Reload. The chip appears. Type <code>=git-log</code> to confirm.</p>
          <p>Bolt renders a Press Enter to run row. Hit Enter to fire the command for the first time.</p>
        </Card>
      </CardGrid>
    </PageSection>

    <PageSection
      id="honest"
      eyebrow="What ships, what does not"
      title="The honest map of this surface."
      lede="If something on this page does not match the runtime, that is a bug. We do not soften claims in the docs to cover for runtime drift."
    >
      <CardGrid>
        {honest.map((h) => (
          <Card title={h.title}>
            <p>{h.body}</p>
          </Card>
        ))}
      </CardGrid>
    </PageSection>

    <CTAStrip>
      <Fragment slot="title">Build something local. Keep it yours.</Fragment>
      <Fragment slot="lede">The spec is short, the runtime is conservative, and the data flow is end-to-end local. Read the full manifest reference or jump into the architecture page.</Fragment>
      <a href="/apps/trust" class="btn btn-primary btn-lg">Read the trust model</a>
      <a href="/architecture" class="btn btn-secondary btn-lg">See the architecture</a>
    </CTAStrip>
  </main>
</BaseLayout>

<style>
  .user-app-diagram {
    width: 100%;
    overflow-x: auto;
    padding: 1.5rem 0;
  }
  .topology-svg {
    width: 100%;
    height: auto;
    max-width: 880px;
    display: block;
    margin: 0 auto;
  }
  /* Wrap the Shiki-rendered <Code> output. The component renders its own
     <pre><code> with inline-styled tokens for the chosen theme; we just
     provide the surrounding card chrome (border, radius, scroll). */
  .manifest-block {
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .manifest-block :global(pre) {
    margin: 0;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    font-size: 0.85rem;
    line-height: 1.55;
  }
</style>
