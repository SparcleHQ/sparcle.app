---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 | Sparcle" description="Page not found.">
  <section class="hero">
    <div class="container">
      <p class="hero-eyebrow">404</p>
      <h1>Page not found</h1>
