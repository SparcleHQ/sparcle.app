---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/marketing/SectionHeader.astro";
import ProofCard from "../components/marketing/ProofCard.astro";

const applyEmail =
  "mailto:bolt@sparcle.app?subject=Bolt%20Founding%20Early%20Adopter%20Application";
---

<BaseLayout
  title="Bolt Founding Early Adopters | Applications Open"
  description="Applications are open for 5 Bolt Founding Early Adopter seats. Get a free 7-day AI-ready trial and help shape the product with structured feedback."
  canonical="https://sparcle.app/early-partners"
>
  <Fragment slot="head">
    <meta name="robots" content="noindex, nofollow" />
  </Fragment>

  <section class="section-solution section-solution--page">
    <div class="container">
      <SectionHeader
        label="Applications Open"
        heading="<span class='hero-sentence'>Experience Bolt for <span class='hero-pill hero-pill--free'>FREE</span>.</span><br><span class='hero-sentence'>Earn <span class='hero-pill hero-pill--rewards'>REWARDS</span> for quality feedback.</span>"
        intro="Limited seats. Selected 5 applicants get Bolt full features + LLM key + earn up to $50."
        class="bolt-hero-header"
      />

      <div class="ep-install-wrap" aria-label="Quick install preview">
        <div class="download-section">
          <div class="dl-tabs">
            <button class="dl-tab dl-tab--active" data-platform="macos" type="button">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
              macOS
            </button>
            <button class="dl-tab" data-platform="linux" type="button">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489a2.1 2.1 0 0 0-.084-.006c-.393 0-.777.158-1.048.473-.611.71-.354 1.884.482 2.497-.184.373-.27.77-.27 1.163 0 .63.259 1.248.867 1.687-.186.37-.275.758-.275 1.142 0 .838.537 1.591 1.541 1.846.305 1.166 1.451 2.344 2.527 2.344.348 0 .685-.113.978-.349.328.24.729.349 1.137.349.844 0 1.535-.479 1.879-1.219.417.102.862.155 1.316.155.455 0 .9-.054 1.316-.155.344.74 1.035 1.219 1.879 1.219.408 0 .809-.109 1.137-.349.293.236.63.349.978.349 1.076 0 2.222-1.178 2.527-2.344 1.004-.255 1.541-1.008 1.541-1.846 0-.384-.089-.771-.275-1.142.608-.439.867-1.057.867-1.687 0-.393-.086-.79-.27-1.163.836-.613 1.093-1.787.482-2.497-.271-.315-.655-.473-1.048-.473-.029 0-.057.003-.084.006.123-.805-.009-1.657-.287-2.489-.589-1.771-1.831-3.47-2.716-4.521-.75-1.067-.974-1.928-1.05-3.02-.065-1.491 1.056-5.965-3.17-6.298A5.1 5.1 0 0 0 12.504 0z"/></svg>
              Linux
            </button>
            <button class="dl-tab" data-platform="windows" type="button">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/></svg>
              Windows
            </button>
          </div>

          <div class="dl-panel" data-platform="macos">
            <p class="dl-cmd-hint">Run in Terminal &middot; Apple Silicon &amp; Intel</p>
            <div class="dl-code-block">
              <code>curl -fsSL https://sparcle.app/trial.sh | sh</code>
              <button class="dl-copy-btn" type="button" onclick="navigator.clipboard.writeText('curl -fsSL https://sparcle.app/trial.sh | sh');this.querySelector('span').textContent='Copied!';setTimeout(()=>this.querySelector('span').textContent='Copy',1500)" title="Copy to clipboard">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                <span>Copy</span>
              </button>
            </div>
            <p class="dl-cmd-note">Downloads, installs to /Applications, and launches Bolt Enterprise</p>
          </div>

          <div class="dl-panel" data-platform="linux" hidden>
            <p class="dl-cmd-hint">Run in Terminal &middot; x86_64 &amp; ARM64</p>
            <div class="dl-code-block">
              <code>curl -fsSL https://sparcle.app/trial.sh | sh</code>
              <button class="dl-copy-btn" type="button" onclick="navigator.clipboard.writeText('curl -fsSL https://sparcle.app/trial.sh | sh');this.querySelector('span').textContent='Copied!';setTimeout(()=>this.querySelector('span').textContent='Copy',1500)" title="Copy to clipboard">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                <span>Copy</span>
              </button>
            </div>
            <p class="dl-cmd-note">Auto-detects Linux &middot; installs AppImage to ~/.local/bin</p>
          </div>

          <div class="dl-panel" data-platform="windows" hidden>
            <p class="dl-cmd-hint">Run in PowerShell &middot; x86_64</p>
            <div class="dl-code-block">
              <code>irm https://sparcle.app/trial.ps1 | iex</code>
              <button class="dl-copy-btn" type="button" onclick="navigator.clipboard.writeText('irm https://sparcle.app/trial.ps1 | iex');this.querySelector('span').textContent='Copied!';setTimeout(()=>this.querySelector('span').textContent='Copy',1500)" title="Copy to clipboard">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                <span>Copy</span>
              </button>
            </div>
            <p class="dl-cmd-note">Marks app as trusted &middot; downloads, installs, and launches Bolt</p>
          </div>
        </div>
      </div>

      <div class="section-cta-row" style="margin-top: 0; margin-bottom: 2rem;">
        <a class="btn btn-primary btn-lg" href={applyEmail}>Join the Mission</a>
        <a class="btn btn-secondary btn-lg" href="#eligibility">View Eligibility</a>
      </div>
    </div>
  </section>

  <section id="eligibility" class="section-proof">
    <div class="container">
      <SectionHeader
        label="Eligibility"
        heading="Who Should Apply"
        intro="You should apply if you can run commands, articulate clearly, and provide practical, reproducible insights."
      />
      <div class="proof-grid">
        <ProofCard
          metric="OS"
          label="Mac, Windows, or Linux"
          description="You can use Bolt in real daily workflows across one of these environments during the 7-day trial."
        />
        <ProofCard
          metric="Google"
          label="Connected Workflow Testing"
          description="You can sign in to Bolt with your Google account and connect services like Gmail, Calendar/Meetings, Contacts, and Tasks."
        />
        <ProofCard
          metric="Evidence"
          label="Structured Reporting"
          description="You can submit structured feedback on what worked, what did not, and why, with evidence when relevant."
        />
      </div>
    </div>
  </section>

  <section class="section-solution">
    <div class="container">
      <SectionHeader
        label="Qualification"
        heading="How You Qualify for Appreciation"
      />

      <div class="proof-grid">
        <ProofCard
          metric="5/7"
          label="Active Usage"
          description="Use Bolt in real workflows on at least 5 of 7 days during your cohort window."
        />
        <ProofCard
          metric="3+"
          label="Structured Reports"
          description="Submit at least three useful reports with expected vs actual behavior and practical impact."
        />
        <ProofCard
          metric="1"
          label="Final Summary"
          description="Submit one concise end-of-week summary of what worked, what did not, and what to improve."
        />
      </div>

      <div class="page-prose reward-note" style="margin-top: 2rem;">
        <p class="reward-note-text" style="text-align: center; max-width: 60ch; margin: 0 auto; font-size: 1.08rem;">
          <span class="reward-strong">Appreciation rewards are engagement- and quality-based</span>
          and may range up to <span class="reward-pill" style="display: inline-block; margin: 4px 0.2rem; padding: 0.15rem 0.5rem; border-radius: 999px; border: 1px solid rgba(59, 130, 246, 0.55); background: rgba(59, 130, 246, 0.2); color: var(--brand-primary); font-weight: 700;">$50 USD</span> for
          high-value, non-duplicate signals. <span class="reward-pill" style="display: inline-block; margin: 0 0.2rem; padding: 0.15rem 0.5rem; border-radius: 999px; border: 1px solid rgba(59, 130, 246, 0.55); background: rgba(59, 130, 246, 0.2); color: var(--brand-primary); font-weight: 700;">LLM key included</span>
          so you can start using Bolt right away.
        </p>
      </div>
    </div>
  </section>

  <section id="privacy" class="section-proof">
    <div class="container">
      <SectionHeader
        label="Trust"
        heading="Privacy and Permissions"
        intro="Bolt is designed for controlled, permission-based access to connected services."
      />

      <div class="proof-grid">
        <ProofCard
          metric="Control"
          label="You Decide What Connects"
          description="You control which services are connected and can disconnect or revoke access anytime."
        />
        <ProofCard
          metric="Scope"
          label="Least-Privilege Access"
          description="We request only the permissions needed to support the features you choose to use."
        />
        <ProofCard
          metric="Policy"
          label="Transparent Terms"
          description="Program participation, eligibility, and data-handling expectations are stated clearly before you apply."
        />
      </div>

      <div class="section-cta-row" style="margin-top: 2.25rem;">
        <a class="btn btn-secondary" href="/privacy">Read Privacy Policy</a>
        <a class="btn btn-secondary" href="/terms">Read Terms of Use</a>
      </div>
    </div>
  </section>

  <section id="apply" class="section-cta">
    <div class="container">
      <div class="cta-box">
        <h2>Apply for One of 5 Founding Early Adopter Seats</h2>
        <p>
          If selected, you will get a 7-day AI-ready Bolt experience, direct access to influence
          product decisions, and quality-based appreciation for your contribution.
        </p>
        <div class="cta-actions">
          <a class="btn btn-primary btn-xl" href={applyEmail}>Join the Mission</a>
        </div>
        <p class="cta-resources" style="justify-content: center;">
          Prefer a direct intro? Write to
          <a href="mailto:bolt@sparcle.app">bolt@sparcle.app</a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  (function() {
    function detectPlatform() {
      var ua = navigator.userAgent || '';
      if (ua.indexOf('Win') !== -1) return 'windows';
      if (ua.indexOf('Linux') !== -1) return 'linux';
      return 'macos';
    }

    function selectTab(section, platform) {
      section.querySelectorAll('.dl-tab').forEach(function(t) {
        t.classList.toggle('dl-tab--active', t.dataset.platform === platform);
      });
      section.querySelectorAll('.dl-panel').forEach(function(p) {
        p.hidden = p.dataset.platform !== platform;
      });
    }

    document.addEventListener('DOMContentLoaded', function() {
      var platform = detectPlatform();
      document.querySelectorAll('.download-section').forEach(function(section) {
        selectTab(section, platform);
        section.querySelectorAll('.dl-tab').forEach(function(tab) {
          tab.addEventListener('click', function() {
            selectTab(section, tab.dataset.platform);
          });
        });
      });
    });
  })();
</script>

<style>
  :global(.bolt-hero-header) {
   --hero-pill-border: rgba(56, 189, 248, 0.55);
   --hero-pill-bg: linear-gradient(135deg, rgba(186, 230, 253, 0.75), rgba(191, 219, 254, 0.8));
   --hero-pill-text: #1e3a8a;
   --hero-pill-shadow: 0 1px 0 rgba(255, 255, 255, 0.65), 0 8px 18px rgba(59, 130, 246, 0.12);
  }

  :global([data-theme="dark"] .bolt-hero-header) {
   --hero-pill-border: rgba(96, 165, 250, 0.72);
   --hero-pill-bg: linear-gradient(135deg, rgba(37, 99, 235, 0.34), rgba(56, 189, 248, 0.28));
   --hero-pill-text: #dbeafe;
   --hero-pill-shadow: 0 0 0 1px rgba(125, 211, 252, 0.24), 0 8px 20px rgba(56, 189, 248, 0.28);
  }

  :global(.bolt-hero-header h2) {
    max-width: none;
    margin-left: auto;
    margin-right: auto;
    text-wrap: balance;
    font-size: clamp(2rem, 4.2vw, 3.25rem);
    line-height: 1.15;
  }

  :global(.bolt-hero-header .hero-sentence) {
    display: inline-block;
    white-space: nowrap;
  }

  :global(.bolt-hero-header .hero-pill) {
    display: inline-block;
    white-space: nowrap;
    vertical-align: 0.02em;
    padding: 0.05em 0.5em 0.11em;
    margin: 0 0.05em;
    border-radius: 999px;
    border: 1px solid var(--hero-pill-border);
    background: var(--hero-pill-bg);
    color: var(--hero-pill-text);
    letter-spacing: 0.01em;
    font-weight: 800;
    box-shadow: var(--hero-pill-shadow);
  }

  :global(.bolt-hero-header .hero-pill--free) {
    margin-left: 0.12em;
    margin-right: 0.02em;
  }

  :global(.bolt-hero-header .hero-pill--rewards) {
    margin-left: 0.08em;
    margin-right: 0.12em;
  }

  .reward-note {
    text-align: center;
  }

  .ep-install-wrap {
    max-width: 820px;
    margin: 1.25rem auto 0;
    padding: 0.2rem 0.2rem 0.4rem;
  }

  .download-section {
    border-top: 1px solid var(--border-default);
    padding-top: 1.5rem;
    margin-top: auto;
  }

  .dl-tabs {
    display: flex;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border-default);
  }

  .dl-tab {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.7rem 1rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-muted, #888);
    background: transparent;
    border: none;
    border-right: 1px solid var(--border-default);
    cursor: pointer;
    transition: all var(--transition-fast);
    font-family: inherit;
  }

  .dl-tab:last-child {
    border-right: none;
  }

  .dl-tab:hover {
    color: var(--text-body);
    background: rgba(59, 130, 246, 0.05);
  }

  .dl-tab--active {
    color: #fff;
    background: #2563eb;
  }

  .dl-tab--active:hover {
    background: #1d4ed8;
  }

  .dl-panel {
    padding: 1rem 0 0.25rem;
  }

  .dl-cmd-hint {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted, #888);
    margin: 0 0 0.4rem;
  }

  .dl-code-block {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: #1e1e2e;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    font-family: "SF Mono", "Fira Code", "JetBrains Mono", monospace;
  }

  .dl-code-block code {
    flex: 1;
    font-size: 0.8rem;
    color: #a6e3a1;
    white-space: pre-wrap;
    overflow-wrap: break-word;
    word-break: normal;
    user-select: all;
    line-height: 1.5;
  }

  .dl-copy-btn {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.65rem;
    border: none;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 600;
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.6);
    cursor: pointer;
    transition: all var(--transition-fast);
    white-space: nowrap;
  }

  .dl-copy-btn:hover {
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
  }

  .dl-cmd-note {
    font-size: 0.72rem;
    color: var(--text-muted, #888);
    margin: 0.4rem 0 0;
  }

  .reward-note .reward-note-text {
    max-width: 60ch;
    margin-left: auto;
    margin-right: auto;
    font-size: 1.08rem;
    text-align: center !important;
  }

  .reward-strong {
    font-weight: 700;
  }

  .reward-pill {
    display: inline-block;
    margin: 4px 0.2rem;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--brand-primary) 45%, transparent);
    background: color-mix(in srgb, var(--brand-primary) 16%, transparent);
    font-weight: 700;
    color: var(--brand-primary);
  }

  :global([data-theme="dark"] .reward-pill) {
    border-color: rgba(96, 165, 250, 0.72);
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.22), rgba(56, 189, 248, 0.16));
    color: #dbeafe;
  }

  @media (max-width: 900px) {
    :global(.bolt-hero-header h2) {
      max-width: 18ch;
      font-size: clamp(1.85rem, 7vw, 2.4rem);
    }

    :global(.bolt-hero-header .hero-sentence) {
      white-space: normal;
      padding: 4px;
    }

    .ep-install-wrap {
      padding: 0.95rem;
    }

    .dl-code-block {
      flex-direction: column;
      align-items: stretch;
    }

    .dl-copy-btn {
      width: 100%;
    }
  }

  @media (max-width: 480px) {
    .dl-tabs {
      flex-direction: column;
    }

    .dl-tab {
      border-right: none;
      border-bottom: 1px solid var(--border-default);
    }

    .dl-tab:last-child {
      border-bottom: none;
    }
  }
</style>