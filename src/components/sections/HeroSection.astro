---
import Button from "../ui/Button.astro";

interface Props {
  eyebrow?: string;
  title: string;
  subtitle: string;
  ctaText?: string;
  ctaHref?: string;
}

const { eyebrow, title, subtitle, ctaText, ctaHref } = Astro.props;
---

<section class="hero">
  <div class="container">
    {eyebrow && <p class="hero-eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
    <p class="hero-subtitle">{subtitle}</p>
    {ctaText && ctaHref && <Button href={ctaHref}>{ctaText}</Button>}
  </div>
</section>