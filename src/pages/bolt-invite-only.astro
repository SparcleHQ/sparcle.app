---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Redirecting | Download Bolt"
  description="Redirecting to the Bolt download page."
  canonical="https://sparcle.app/download"
>
  <Fragment slot="head">
    <meta name="robots" content="noindex, nofollow" />
    <meta http-equiv="refresh" content="0; url=/download" />
    <script is:inline>
      window.location.replace('/download');
    </script>
  </Fragment>

  <section class="section-solution section-solution--page">
    <div class="container" style="text-align: center;">
      <h1 style="font-size: clamp(1.8rem, 4vw, 2.4rem); margin-bottom: 0.8rem;">Redirecting to Download...</h1>
      <p>If you are not redirected, <a href="/download" style="color: var(--brand-primary); text-decoration: underline;">open the page here</a>.</p>
    </div>
  </section>
</BaseLayout>