---
import BaseLayout from "../layouts/BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  canonical: string;
  bodyHtml: string;
  headHtml?: string;
  ogImage?: string;
  noindex?: boolean;
}

const { title, description, canonical, bodyHtml, headHtml = "", ogImage, noindex } = Astro.props;
---

<BaseLayout title={title} description={description} canonical={canonical} ogImage={ogImage} noindex={noindex}>
  {headHtml && <Fragment slot="head" set:html={headHtml} />}
  <Fragment set:html={bodyHtml} />
</BaseLayout>
