---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/marketing/SectionHeader.astro";
---

<BaseLayout
  title="Download Bolt | Sparcle"
  description="Download Bolt Personal (free, no login) or Bolt Enterprise Trial (7-day, full platform). macOS, Linux, and Windows."
  canonical="https://sparcle.app/download"
>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      name: "Bolt",
      applicationCategory: "BusinessApplication",
      operatingSystem: "macOS, Linux, Windows",
      description: "Sovereign AI agent for enterprise productivity. Available in Personal (free) and Enterprise Trial editions.",
      url: "https://sparcle.app/download",
      offers: [
        {
          "@type": "Offer",
          name: "Bolt Personal",
          price: "0",
          priceCurrency: "USD",
          description: "Free forever — private AI chat with your own API key, no login required.",
        },
        {
          "@type": "Offer",
          name: "Bolt Enterprise Trial",
          price: "0",
          priceCurrency: "USD",
          description: "7-day free trial of the full enterprise platform. Bring your own IDP, email, and LLM.",
        },
      ],
      provider: {
        "@type": "Organization",
        name: "Sparcle, LLC",
        url: "https://sparcle.app",
      },
    })} />
  </Fragment>

  <section class="section-download section-download--page">
    <div class="container">
      <SectionHeader
        label="Download"
        heading="Get Bolt"
        intro="Choose the edition that fits your needs. Both run on your machine — your data never leaves your device."
      />

      <!-- Edition Cards -->
      <div class="products-showcase platform-grid">

          <!-- ── Personal Edition ── -->
          <div class="product-main">
            <span class="product-badge" style="background:#16a34a;color:#fff;border-color:#16a34a;">FREE FOREVER</span>
