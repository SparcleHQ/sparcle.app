---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/ui/Hero.astro";
import PageSection from "../components/ui/PageSection.astro";
import CardGrid from "../components/ui/CardGrid.astro";
import Card from "../components/ui/Card.astro";
import CTAStrip from "../components/ui/CTAStrip.astro";

const icons = {
  bolt:     '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>',
  database: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="5" rx="8" ry="3"/><path d="M4 5v7c0 1.7 3.6 3 8 3s8-1.3 8-3V5"/><path d="M4 12v7c0 1.7 3.6 3 8 3s8-1.3 8-3v-7"/></svg>',
  network:  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v6m0 6v6m-9-9h6m6 0h6"/></svg>',
  lock:     '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>',
  monitor:  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><polyline points="8 21 12 17 16 21"/></svg>',
  shield:   '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
  globe:    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8.56 2.75c4.37 6.03 6.02 9.42 8.03 17.72m2.54-15.38c-3.72 4.35-8.94 5.66-16.88 5.85m19.5 1.9c-3.5-.93-6.63-.82-8.94 0-2.58.92-5.01 2.86-7.44 6.32"/></svg>',
  book:     '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>',
};
---
<BaseLayout
  title="Solution: Trust Scoring + Authority Policy SDK + ACL-Aware AI | Sparcle"
  description="Bolt is an extensible, governed agentic platform (agentic and non-agentic) over a governance-grade data plane. Most queries run deterministically on-device with no LLM; ACL-aware retrieval plus the Authority Policy SDK lets every enterprise, regulated or not, define its own trust scoring. Runs inside your perimeter."
  canonical="https://sparcle.app/solution/"
>
  <main class="page-solution">
    <Hero
      eyebrow="The Solution"
      title="Two products. One sovereign AI platform."
      lede="Bolt is the extensible, governed agentic platform that eliminates context switching: agentic when reasoning is needed, deterministic and on-device when it isn't, so most queries never touch a model. It runs inside your own perimeter, with your own models, under your own compliance framework. Aeira is the ACL-enforced knowledge index that ensures every answer is grounded, governed, and authorized. Together, they give every knowledge worker instant access to everything your organization knows, with your IP and data protected at every layer."
    >
      <a href="/products.html" class="btn btn-primary btn-lg">Meet Bolt</a>
      <a href="/products/aeira.html" class="btn btn-secondary btn-lg">Meet Aeira</a>
    </Hero>

    <PageSection
      eyebrow="Our Solution"
      title="Four pillars."
      stripe="b"
    >
      <CardGrid cols={2}>
        <Card icon={icons.bolt} eyebrow="01" title="Bolt: Enterprise AI Operating System">
          Ask in natural language, get answers across your enterprise systems, deployed on your
          infrastructure, with your own AI model, in your compliance framework. One Thing&trade;
          surfaces the single most important action right now. Works with Microsoft 365, Google
          Workspace, Zoho, or any OIDC provider. No migration, no lock-in. Unlike Copilot or
          Gemini, your data plane never leaves your perimeter; only PII-masked prompts reach an
          external LLM you choose.
        </Card>
        <Card icon={icons.database} eyebrow="02" title="Aeira: ACL-aware Enterprise Index">
          Access &middot; Enterprise &middot; Index &middot; Retrieval &middot; Augment. From curated
          Catalog to full hybrid search with 4-level ACL filtering, Aeira ensures every user and
          every AI query only sees what they're authorized to access.
        </Card>
        <Card icon={icons.network} eyebrow="03" title="Open MCP + Model Independence">
          Built on the Model Context Protocol, the open standard for AI tool integration. No
          proprietary connectors. No model lock-in. Run any LLM, switch providers whenever you
          want, without employees noticing or your data moving. Your IT team can extend Bolt with
          custom servers in hours, not months.
        </Card>
        <Card icon={icons.lock} eyebrow="04" title="AI Governance Built In, Not Bolted On">
          Your IP and employee data stay protected, regardless of which AI model is running
          underneath. Multi-layer security pipeline, policy guardrails, compliance audit logging,
          and on-prem / VPC / air-gapped deployment options. Designed for HIPAA, GDPR, and DPDPA
          workflows from day one, not retrofitted after.
        </Card>
      </CardGrid>
    </PageSection>

    <PageSection
      eyebrow="Authority Policy SDK"
      title="Every answer carries its receipts."
      lede="ACL-aware retrieval governs who can see what. Authority Policy decides how to rank what they can see, using freshness, approval status, audience targeting, and vertical-specific evidence ladders. Three reference packs ship in the box; customers extend or write their own."
      stripe="a"
    >
      <div class="retrieval-diagram" data-expandable tabindex="0" role="button" aria-label="Expand identity-bound retrieval diagram">
        <svg viewBox="0 0 920 360" class="retrieval-svg" role="img" aria-labelledby="retrieval-title retrieval-desc">
          <title id="retrieval-title">Identity-bound retrieval flow</title>
          <desc id="retrieval-desc">A user query carries identity into Aeira. Aeira applies an ACL pre-filter against the full corpus before retrieval, leaving only rows the calling user is entitled to see. The Authority Policy SDK ranks what remains. The final scoped result is returned with a receipt explaining why each item is included.</desc>

          <defs>
            <marker id="r-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
              <path class="r-arrow-head" d="M0,0 L10,5 L0,10 z" />
            </marker>
          </defs>

          <style>
            .r-box { fill: var(--bg-surface-solid); stroke: var(--brand-primary); stroke-width: 1.5; }
            .r-box--inner { fill: var(--bg-surface-solid); stroke: var(--text-muted); stroke-width: 1; opacity: 0.9; }
            .r-box--filtered { fill: var(--brand-primary-light); stroke: var(--brand-primary); stroke-width: 1.5; }
            .r-container { fill: none; stroke: var(--text-muted); stroke-width: 1.5; stroke-dasharray: 8 5; opacity: 0.55; }
            .r-container-label { font: 700 11px var(--font-sans, system-ui); fill: var(--text-muted); letter-spacing: 0.12em; }
            .r-box-label { font: 600 13px var(--font-sans, system-ui); fill: var(--text-heading); text-anchor: middle; }
            .r-box-sub { font: 500 11px var(--font-sans, system-ui); fill: var(--text-muted); text-anchor: middle; }
            .r-id-badge { font: 700 10px var(--font-sans, system-ui); fill: var(--brand-primary); text-anchor: middle; letter-spacing: 0.08em; }
            .r-flow { fill: none; stroke: var(--brand-primary); stroke-width: 2; }
            .r-flow-drop { fill: none; stroke: var(--brand-primary); stroke-width: 1.5; }
            .r-annotation { font: italic 10.5px var(--font-sans, system-ui); fill: var(--text-muted); text-anchor: middle; }
            .r-arrow-head { fill: var(--brand-primary); }
          </style>

          <rect class="r-box" x="20" y="130" width="160" height="90" rx="8" />
          <text class="r-id-badge" x="100" y="152">QUERY + IDENTITY</text>
          <text class="r-box-label" x="100" y="178">user@org.com</text>
          <text class="r-box-sub" x="100" y="196">role, group, region</text>
          <text class="r-box-sub" x="100" y="212">attached to request</text>

          <path class="r-flow" d="M185 175 L215 175" marker-end="url(#r-arrow)" />

          <rect class="r-container" x="220" y="50" width="380" height="260" rx="14" />
          <text class="r-container-label" x="236" y="38">AEIRA · INSIDE YOUR PERIMETER</text>

          <rect class="r-box--inner" x="245" y="90" width="330" height="60" rx="8" />
          <text class="r-box-label" x="410" y="116">Full corpus</text>
          <text class="r-box-sub" x="410" y="134">every indexed document, every row</text>

          <path class="r-flow-drop" d="M410 155 L410 195" marker-end="url(#r-arrow)" />
          <text class="r-annotation" x="410" y="178">ACL pre-filter applied at the index</text>

          <rect class="r-box--filtered" x="245" y="200" width="330" height="60" rx="8" />
          <text class="r-box-label" x="410" y="226">Entitled candidates</text>
          <text class="r-box-sub" x="410" y="244">only rows this identity is authorized to see</text>

          <text class="r-annotation" x="410" y="290">unauthorized rows never enter the candidate set</text>

          <path class="r-flow" d="M605 230 L645 230" marker-end="url(#r-arrow)" />

          <rect class="r-box" x="650" y="190" width="160" height="80" rx="8" />
          <text class="r-box-label" x="730" y="216">Authority Policy</text>
          <text class="r-box-sub" x="730" y="234">rank what's visible</text>
          <text class="r-box-sub" x="730" y="252">freshness, approval, ladder</text>

          <path class="r-flow" d="M815 230 L850 230" marker-end="url(#r-arrow)" />

          <rect class="r-box--filtered" x="820" y="190" width="80" height="80" rx="8" />
          <text class="r-box-label" x="860" y="220">Result</text>
          <text class="r-box-sub" x="860" y="240">+ receipt</text>
        </svg>
      </div>

      <div class="receipt-grid grid-3">
        <article class="receipt-card">
          <div class="receipt-card__eyebrow">Generic</div>
          <div class="receipt-card__query">&ldquo;Find my Q4 deck&rdquo;</div>
          <div class="receipt-card__answer">
            <div class="receipt-card__title">Q4 Sales Deck.pptx</div>
            <div class="receipt-card__source">Drive &middot; Marketing folder</div>
            <div class="receipt-card__pills">
              <span class="receipt-pill receipt-pill--pos">Updated 2 weeks ago</span>
              <span class="receipt-pill receipt-pill--pos">Approved</span>
              <span class="receipt-pill receipt-pill--pos">For your audience</span>
            </div>
          </div>
          <div class="receipt-card__note">Default pack: freshness, approval, audience targeting.</div>
        </article>

        <article class="receipt-card">
          <div class="receipt-card__eyebrow">Healthcare</div>
          <div class="receipt-card__query">&ldquo;Latest hypertension treatment guideline&rdquo;</div>
          <div class="receipt-card__answer">
            <div class="receipt-card__title">Hypertension Management: Tier 1 Guideline</div>
            <div class="receipt-card__source">Clinical Library &middot; Cardiology</div>
            <div class="receipt-card__pills">
              <span class="receipt-pill receipt-pill--pos">Clinical guideline</span>
              <span class="receipt-pill receipt-pill--pos">CME current</span>
              <span class="receipt-pill receipt-pill--pos">Authoritative source-of-record</span>
            </div>
          </div>
          <div class="receipt-card__note">Healthcare pack: evidence ladder, CME currency.</div>
        </article>

        <article class="receipt-card receipt-card--demoted">
          <div class="receipt-card__eyebrow">Demoted</div>
          <div class="receipt-card__query">&ldquo;Expense policy&rdquo;</div>
          <div class="receipt-card__answer">
            <div class="receipt-card__title">Expense Policy v3 (2023)</div>
            <div class="receipt-card__source">Confluence &middot; Finance space</div>
            <div class="receipt-card__pills">
              <span class="receipt-pill receipt-pill--neg">Retired policy: do not cite</span>
            </div>
          </div>
          <div class="receipt-card__note">Regulated pack: retired policies sink below the cut.</div>
        </article>
      </div>

      <p class="section-tagline">
        <strong>Your search. Your policy. Your code.</strong> Trust scoring runs inside your
        perimeter, on the substrate you already control. Reference packs in Rust + YAML; SDK is
        open to customer impls.
      </p>
    </PageSection>

    <PageSection
      eyebrow="From question to action"
      title="One overlay. Across every system."
      lede="Knowledge workers don't just need answers; they need to act on them. Bolt is the overlay every user already lives in: on top of any app, anywhere. It chains MCP servers, calls sub-agents, and closes the loop. Autonomous when safe. Human-in-the-loop when not. Audit-traced either way."
      stripe="b"
    >
      <div class="action-grid grid-2">
        <article class="action-card action-card--autonomous">
          <div class="action-card__header">
            <span class="action-card__verb">Find</span>
            <span class="action-card__mode action-card__mode--autonomous">Autonomous</span>
          </div>
          <div class="action-card__query">&ldquo;Is the Acme renewal at risk?&rdquo;</div>
          <div class="action-card__chain">
            <code>mdm</code> &middot; <code>salesforce</code> &middot; <code>zendesk</code> &middot; <code>marketo</code>
          </div>
          <div class="action-card__outcome">
            Bolt chains four MCP servers, returns a synthesized assessment with citations.
            Read-only. No side effects. PII masked at the LLM call.
          </div>
        </article>

        <article class="action-card action-card--autonomous">
          <div class="action-card__header">
            <span class="action-card__verb">Pull</span>
            <span class="action-card__mode action-card__mode--autonomous">Autonomous</span>
          </div>
          <div class="action-card__query">&ldquo;Pull the latest engineering hiring docs into this thread.&rdquo;</div>
          <div class="action-card__chain">
            <code>confluence</code> &middot; <code>notion</code> &middot; <code>drive</code> &middot; <code>aeira</code>
          </div>
          <div class="action-card__outcome">
            Bolt searches across the customer's index of choice (Aeira if they run it, or any
            enterprise search reachable over MCP if not) and lands docs inline with freshness
            and approval signals.
          </div>
        </article>

        <article class="action-card action-card--autonomous">
          <div class="action-card__header">
            <span class="action-card__verb">Notify</span>
            <span class="action-card__mode action-card__mode--autonomous">Autonomous</span>
          </div>
          <div class="action-card__query">Watch: &ldquo;Any F500 account with &gt;20% usage decline + open P1 ticket.&rdquo;</div>
          <div class="action-card__chain">
            <code>mdm</code> &middot; <code>zendesk</code> &middot; <code>slack</code> &middot; <code>jira</code>
          </div>
          <div class="action-card__outcome">
            Bolt watch evaluates on schedule, posts the rollup to the CS lead's Slack, files a
            follow-up task. Routing is the action; no external comms yet.
          </div>
        </article>

        <article class="action-card action-card--hitl">
          <div class="action-card__header">
            <span class="action-card__verb">Act</span>
            <span class="action-card__mode action-card__mode--hitl">Human-in-the-loop</span>
          </div>
          <div class="action-card__query">Same watch fires on a tier-1 account.</div>
          <div class="action-card__chain">
            <code>mdm</code> &middot; <code>salesforce</code> &middot; <code>gmail</code> or <code>outlook</code> &middot; <code>docusign</code>
          </div>
          <div class="action-card__outcome">
            Bolt drafts the save-plan email and the contract amendment notes. Holds at the
            send-confirmation gate. CSM reviews, approves, Bolt sends and logs the audit entry.
            Outbound and irreversible actions always gate.
          </div>
        </article>
      </div>

      <p class="section-tagline">
        <strong>Knowledge workers juggle 40+ systems on average.</strong> Most AI products add a
        41st tab. Bolt is the overlay that consumes the other 40 (through MCP, A2A, or any HTTP
        API) and gives every user one place to ask, act, and audit. Same identity, same
        governance, same audit chain across every system they reach.
      </p>
    </PageSection>

    <PageSection
      eyebrow="Platform Capabilities"
      title="Every surface. Every workflow."
      lede="Bolt meets knowledge workers wherever they are: desktop, browser, or mobile. With autonomous execution, ACL-aware retrieval, and an enterprise catalog built in, your team gets instant productivity from day one."
      stripe="a"
    >
      <CardGrid cols={2}>
        <Card icon={icons.monitor} title="Multi-Surface Access">
          <strong>macOS &middot; Windows &middot; Linux &middot; Web &middot; Browser Extension.</strong>
          Native apps, browser extensions, and PWA. Ship Bolt to any mix of platforms with the
          software-distribution tooling you already run. One agent, every platform, same experience.
        </Card>
        <Card icon={icons.shield} title="ACL-Aware Everything">
          <strong>Every query respects your org's access controls.</strong>
          Aeira's 4-level ACL filtering ensures users and AI only see authorized data: org,
          group, role, and individual permissions enforced in real time.
        </Card>
        <Card icon={icons.globe} title="Autonomous Execution">
          <strong>Multi-step workflows in plain language.</strong>
          Draft emails, file tickets, schedule meetings, summarize threads. Bolt plans and
          executes complex workflows with human-in-the-loop confirmation.
        </Card>
        <Card icon={icons.book} title="Enterprise Catalog">
          <strong>Curated company directory, included free.</strong>
          11 directory categories: offices, policies, apps, benefits, holidays, FAQs, training,
          events, departments, security, and people. New hires find the right resource on day one.
          Scales to Dynamic, Enhanced, and Federated search tiers.
        </Card>
      </CardGrid>
    </PageSection>

    <CTAStrip
      variant="band"
      title="Two products. One platform. Your perimeter."
      lede="Schedule a 30-minute call. We'll walk through architecture, deployment models, and what's relevant to your environment."
    >
      <a href="/products.html" class="btn btn-primary btn-lg">Explore Bolt</a>
      <a href="/products/aeira.html" class="btn btn-secondary btn-lg">Explore Aeira</a>
    </CTAStrip>
  </main>
</BaseLayout>

<style is:global>
  /* ---------------------------------------------------------------
     RETRIEVAL DIAGRAM: identity-bound retrieval flow visualization
     above the receipt-grid on /solution. Container provides surface
     + padding; SVG scales to fit. Theme-tracks via CSS vars in the
     embedded <style> inside the SVG.
     --------------------------------------------------------------- */
  .retrieval-diagram {
    background: var(--bg-surface-solid);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    padding: 1.5rem 1.75rem;
    max-width: 960px;
    margin: 0 auto 2rem;
  }
  .retrieval-svg {
    display: block;
    width: 100%;
    height: auto;
    max-width: 920px;
    margin: 0 auto;
  }

  /* ---------------------------------------------------------------
     SECTION-LEVEL TAGLINE: a short closing line after a card grid.
     Used after the receipt-grid and action-grid on /solution.
     --------------------------------------------------------------- */
  .section-tagline {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-muted);
    max-width: 70ch;
    margin: 2rem auto 0;
    text-align: center;
  }
  .section-tagline strong { color: var(--text-heading); font-weight: 600; }

  /* ---------------------------------------------------------------
     RECEIPT-CARD: mock search-result card used to demo the
     Authority Policy SDK. Page-specific UI, but anchored to
     canonical tokens so it matches the rest of the site.
     --------------------------------------------------------------- */
  .receipt-card {
    background: var(--bg-surface-solid);
    border: 1px solid var(--border-default);
    border-left: 3px solid var(--brand-primary);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .receipt-card--demoted {
    border-left-color: var(--color-danger-strong);
  }
  .receipt-card__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
    font-weight: 700;
    margin-bottom: 0.6rem;
  }
  .receipt-card__query {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-heading);
    line-height: 1.25;
    letter-spacing: -0.01em;
  }
  .receipt-card__answer {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px dashed var(--border-default);
  }
  .receipt-card__title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-heading);
    line-height: 1.3;
  }
  .receipt-card__source {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--text-muted);
    margin-top: 0.3rem;
    letter-spacing: 0.04em;
  }
  .receipt-card__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.85rem;
  }
  .receipt-pill {
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.25rem 0.65rem;
    border-radius: var(--radius-full);
    border: 1px solid;
    line-height: 1.3;
    white-space: nowrap;
  }
  .receipt-pill--pos {
    background: var(--color-success-bg);
    border-color: var(--color-success);
    color: var(--color-success-strong);
  }
  .receipt-pill--neg {
    background: var(--color-danger-bg);
    border-color: var(--color-danger);
    color: var(--color-danger-strong);
  }
  .receipt-card__note {
    margin-top: auto;
    padding-top: 1rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* ---------------------------------------------------------------
     ACTION-CARD: verb-led MCP chain visualization. Page-specific.
     --------------------------------------------------------------- */
  .action-card {
    background: var(--bg-surface-solid);
    border: 1px solid var(--border-default);
    border-left: 3px solid var(--brand-primary);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .action-card--autonomous { border-left-color: var(--color-success-strong); }
  .action-card--hitl       { border-left-color: var(--color-warning); }
  .action-card__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .action-card__verb {
    font-family: var(--font-display);
    font-size: 1.65rem;
    font-weight: 700;
    color: var(--text-heading);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .action-card__mode {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
    padding: 0.3rem 0.65rem;
    border-radius: var(--radius-full);
    border: 1px solid;
    white-space: nowrap;
  }
  .action-card__mode--autonomous {
    background: var(--color-success-bg);
    border-color: var(--color-success);
    color: var(--color-success-strong);
  }
  .action-card__mode--hitl {
    background: var(--color-warning-bg);
    border-color: var(--color-warning);
    color: var(--color-warning);
  }
  .action-card__query {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-heading);
    line-height: 1.35;
    margin-bottom: 0.85rem;
    letter-spacing: -0.01em;
