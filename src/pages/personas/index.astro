---
/**
 * Hub for the persona pages.
 *
 * Without this, /personas/ 404s. the URL a visitor or a crawler naturally
 * tries after seeing /personas/ciso/. It also gives the 18 pages a single
 * parent to link them, so discovery does not depend on the homepage strip
 * alone.
 *
 * Cards mirror the homepage strip: same icon, same tag, same short title, from
 * the same list in data/personas. The first cut used each deck's <title> and
 * tagline instead, which printed near-identical text twice on every card
 * ("Bolt. one trusted surface for everything your org runs on" over "One
 * trusted surface for everything your org runs on") and looked nothing like the
 * strip a visitor had just scrolled past.
 *
 * Each card offers both routes to the same content: the page (readable,
 * linkable, indexable) and the deck (the presentation, via the homepage modal).
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/ui/Hero.astro";
import PageSection from "../../components/ui/PageSection.astro";
import CardGrid from "../../components/ui/CardGrid.astro";
import Card from "../../components/ui/Card.astro";
import CTAStrip from "../../components/ui/CTAStrip.astro";
import { ICONS, PERSONAS, personaKey } from "../../data/personas";
import { parseDeck } from "../../lib/deckContent";

// The curated short title says what the persona GETS; the deck's own tagline
// says why. Together they read as a card; the first cut used the deck <title>
// for both and said the same thing twice.
const decks = import.meta.glob("/public/decks/persona-*.html", {
  query: "?raw",
  import: "default",
  eager: true,
}) as Record<string, string>;

const words = (s: string): string[] =>
  s.toLowerCase().replace(/[^a-z0-9\s]/g, " ").split(/\s+/).filter((w) => w.length > 3);

/**
 * The tagline earns its place only when it says something the title does not.
 * For 16 of 18 personas it does ("Triage in a keystroke" / "Triage at the speed
 * of paste"). For the other two it just restates the title. decision-makers is
 * word-for-word identical. and printing both looks like a rendering bug.
 */
const taglineFor = (file: string, title: string): string => {
  const tagline = parseDeck(decks[`/public/decks/${file}.html`] ?? "").tagline;
  if (!tagline) return "";
  const t = words(title);
  if (!t.length) return tagline;
  const echoed = t.filter((w) => tagline.toLowerCase().includes(w)).length / t.length;
  return echoed >= 0.7 ? "" : tagline;
};
---

<BaseLayout
  title="Bolt for your role: CISO, DPO, CIO, CFO, Legal and more | Sparcle"
  description="What Bolt does for your role. Governed AI inside your own perimeter, on the LLM you choose. Pages for the CISO, DPO, General Counsel, CIO, CFO, SOC and more."
  canonical="https://sparcle.app/personas/"
>
  <main>
    <Hero
      eyebrow="Built for every role"
      title="Pick the seat you sit in"
      lede="The same governed AI surface, argued from where you sit. What it changes for your role, and what your security review will ask about it."
      stripe="a"
    />

    <PageSection stripe="b">
      <CardGrid>
        {
          PERSONAS.map((p) => (
            <Card icon={ICONS[p.icon]} eyebrow={p.tag} title={p.title}>
              {taglineFor(p.file, p.title)}
              <div class="persona-card__links" slot="footer">
                <a href={`/personas/${personaKey(p)}/`}>Read →</a>
                <a href={`/#deck=${personaKey(p)}&slide=0`}>Open deck →</a>
              </div>
            </Card>
          ))
        }
      </CardGrid>
    </PageSection>

    <CTAStrip title="See it on your own data" lede="Bolt runs inside your perimeter, on the LLM you choose.">
      <a class="btn btn-primary" href="/download/">Download Bolt</a>
      <a class="btn btn-secondary" href="/demo/">Book a demo</a>
    </CTAStrip>
  </main>
</BaseLayout>

<style>
  .persona-card__links {
    display: flex;
    gap: 1.25rem;
    font-weight: 600;
    font-size: 0.9rem;
  }
</style>
