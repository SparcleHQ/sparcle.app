---
interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = "Sparcle: Sovereign enterprise AI with governance built in. BYO LLM, runs inside your perimeter, data sovereignty by design.",
  canonical,
  ogTitle = title,
  ogDescription = description,
  ogImage = "https://sparcle.app/images/og-preview.png",
  noindex = false,
} = Astro.props;

// This layout is the single owner of the robots directive. Pages must pass
// noindex rather than emitting their own <meta name="robots"> into the head
// slot: two robots tags on one page is a contradiction crawlers resolve by
// their own rules, not ours.
const robotsContent = noindex
  ? "noindex, nofollow"
  : "index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1";

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? "";

// Cache-busting version string for /js/shared-nav.js (and other public
// assets we want to force-refresh on edit). Bump this whenever you edit
// public/js/shared-nav.js — Cloudflare's edge cache otherwise serves the
// stale file for up to 24h (cache-control: max-age=86400). The dashboard
// cache-purge works too, but bumping this is the zero-click path.
const sharedNavVersion = "20260621a";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      // FOUC-prevention: resolve theme before first paint.
      // Tri-state: explicit 'light' / 'dark' from localStorage wins; otherwise
      // honor prefers-color-scheme (auto). Matches shared-nav.js toggle logic.
      (function () {
        try {
          var saved = localStorage.getItem("theme");
          var resolved = (saved === "dark" || saved === "light")
            ? saved
            : (window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
          document.documentElement.setAttribute("data-theme", resolved);
        } catch {
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark light" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Sparcle" />
    <meta name="rating" content="general" />
    <meta name="category" content="technology" />
    <meta name="classification" content="Business" />
    <meta name="robots" content={robotsContent} />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0b1020" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#ffffff" />

    {canonical && <link rel="canonical" href={canonical} />}
    <meta property="og:type" content="website" />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:site_name" content="Sparcle" />

    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />

