---
import BaseLayout from "../layouts/BaseLayout.astro";

// Integration catalog. Built on the open Model Context Protocol — customer
// can run any compliant MCP server, including their own. Logos withheld
// (vendor brand-guidelines vary); page uses category + name to keep
// everything legally clean. Ship with what's accurate today; add as
// integrations actually ship.
const categories = [
  {
    name: "Identity & Access",
    icon: "shield",
    blurb: "Single sign-on, group membership, and access policy resolution.",
    items: [
      { name: "Microsoft Entra ID (Azure AD)", note: "OIDC + SAML + group sync" },
      { name: "Okta", note: "OIDC + SAML + SCIM" },
      { name: "Google Workspace", note: "OIDC + Cloud Identity" },
      { name: "Zoho Directory", note: "OIDC" },
      { name: "Generic OIDC / SAML", note: "Bring your own IdP" },
      { name: "JWT / API tokens", note: "Service-to-service" },
    ],
  },
  {
    name: "Productivity & Collaboration",
    icon: "layers",
    blurb: "Email, calendar, docs, and team chat — read and act with consent.",
    items: [
      { name: "Microsoft 365 (Outlook + Calendar)" },
      { name: "Microsoft Teams" },
      { name: "Microsoft OneDrive" },
      { name: "Microsoft SharePoint" },
      { name: "Google Gmail" },
      { name: "Google Calendar" },
      { name: "Google Drive" },
      { name: "Google Docs / Sheets / Slides" },
      { name: "Slack" },
      { name: "Discord" },
      { name: "Zoom (meetings + recordings)" },
      { name: "Cisco Webex" },
      { name: "Notion" },
      { name: "Confluence (Atlassian)" },
      { name: "Coda" },
      { name: "Quip" },
    ],
  },
  {
    name: "Engineering & DevOps",
    icon: "code",
    blurb: "Source, builds, issues, and ops — connected at the service level.",
    items: [
      { name: "GitHub" },
      { name: "GitLab" },
      { name: "Bitbucket" },
      { name: "Jira (Atlassian)" },
      { name: "Linear" },
      { name: "Asana" },
      { name: "ClickUp" },
      { name: "Trello" },
      { name: "Sentry" },
      { name: "Datadog" },
      { name: "PagerDuty" },
      { name: "Grafana" },
      { name: "AWS CloudWatch" },
      { name: "Azure Monitor" },
    ],
  },
  {
    name: "Sales & CRM",
    icon: "trending-up",
    blurb: "Pipeline, contacts, and revenue ops without copy-paste between tools.",
    items: [
      { name: "Salesforce" },
      { name: "HubSpot" },
      { name: "Microsoft Dynamics 365" },
      { name: "Zoho CRM" },
      { name: "Pipedrive" },
      { name: "Outreach" },
      { name: "Salesloft" },
      { name: "Gong" },
    ],
  },
  {
    name: "ITSM & Support",
    icon: "scale",
    blurb: "Tickets, incidents, and customer support — read and respond with policy controls.",
    items: [
      { name: "ServiceNow" },
      { name: "Zendesk" },
      { name: "Freshdesk" },
      { name: "Intercom" },
      { name: "Jira Service Management" },
      { name: "Salesforce Service Cloud" },
    ],
  },
  {
    name: "Knowledge & Search",
    icon: "database",
    blurb: "Internal wikis, knowledge bases, and document repositories.",
    items: [
      { name: "Aeira (built-in)", note: "Compliance-grade search" },
      { name: "Confluence (read)" },
      { name: "SharePoint (read)" },
      { name: "Notion (read)" },
      { name: "Glean", note: "Federated query" },
      { name: "Elastic / OpenSearch" },
      { name: "Algolia" },
    ],
  },
  {
    name: "Data Warehouses & BI",
    icon: "server",
    blurb: "Read structured business data with row-level access controls.",
    items: [
      { name: "Snowflake" },
      { name: "Databricks" },
      { name: "Google BigQuery" },
      { name: "Amazon Redshift" },
      { name: "PostgreSQL" },
      { name: "Tableau" },
      { name: "Looker" },
      { name: "Power BI" },
    ],
  },
  {
    name: "Storage & Files",
    icon: "monitor",
    blurb: "Document stores and file systems — local + cloud.",
    items: [
      { name: "Box" },
      { name: "Dropbox" },
      { name: "AWS S3" },
      { name: "Azure Blob Storage" },
      { name: "Google Cloud Storage" },
      { name: "Local filesystem (Bolt Native)" },
    ],
  },
  {
    name: "LLM Providers (BYO)",
    icon: "lock",
    blurb: "Hot-swappable inference layer. BYOK for zero token markup.",
    items: [
      { name: "OpenAI" },
      { name: "Anthropic Claude" },
      { name: "AWS Bedrock" },
      { name: "Google Vertex AI" },
      { name: "Azure OpenAI" },
      { name: "NVIDIA NIM" },
      { name: "Ollama (local)" },
      { name: "vLLM (self-hosted)" },
      { name: "Your own fine-tuned model" },
    ],
  },
];

const totalCount = categories.reduce((sum, cat) => sum + cat.items.length, 0);

const iconPaths: Record<string, string> = {
  "layers": '<path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>',
  "shield": '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  "server": '<rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>',
  "trending-up": '<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>',
  "database": '<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>',
  "code": '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  "lock": '<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
  "scale": '<path d="M16 3h5v5"/><path d="M8 3H3v5"/><path d="M21 3l-8.5 8.5"/><path d="M3 3l8.5 8.5"/><path d="M3 21l8.5-8.5"/><path d="M21 21l-8.5-8.5"/>',
  "monitor": '<rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>',
};
---

<BaseLayout
  title="Integrations | Sparcle"
  description="Bolt connects to 60+ enterprise systems via the open Model Context Protocol — identity, productivity, engineering, sales, support, knowledge, data, storage, and LLM providers."
  canonical="https://sparcle.app/integrations"
>
  <main class="page-integrations">
    <!-- Hero -->
    <section class="ints-hero">
      <div class="container">
        <p class="section-eyebrow">Integrations</p>
        <h1>Connected to the work your team already does.</h1>
        <p class="ints-lede">
          Bolt connects to <strong>{totalCount}+</strong> enterprise systems via the open
          <a href="https://modelcontextprotocol.io" target="_blank" rel="noopener">Model Context Protocol</a>.
          No proprietary APIs, no vendor lock-in. Bring your own MCP servers and they slot in alongside ours.
        </p>
        <div class="ints-ctas">
          <a href="#" onclick="openContactModal('Custom Integration Request'); return false;" class="btn btn-primary btn-lg">
            Request Custom Integration
          </a>
          <a href="#categories" class="btn btn-secondary btn-lg">
            Browse Categories &darr;
          </a>
        </div>
      </div>
    </section>

    <!-- Anchor for categories -->
    <a id="categories" class="anchor" aria-hidden="true"></a>

    <!-- Categories -->
    {categories.map((cat) => (
      <section class="ints-category">
        <div class="container">
          <header class="ints-cat-header">
            <div class="ints-cat-icon" set:html={`<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${iconPaths[cat.icon] || ''}</svg>`} />
            <div>
              <h2>{cat.name}</h2>
              <p>{cat.blurb}</p>
            </div>
          </header>
          <ul class="ints-grid">
            {cat.items.map((item) => (
              <li class="int-card">
                <span class="int-name">{item.name}</span>
                {item.note && <span class="int-note">{item.note}</span>}
              </li>
            ))}
          </ul>
        </div>
      </section>
    ))}

    <!-- BYO MCP -->
    <section class="ints-section ints-section-alt">
      <div class="container">
        <p class="section-eyebrow">Bring your own</p>
        <h2>Don't see your system? Bring it.</h2>
        <p class="ints-lede ints-lede--narrow">
          The Model Context Protocol is open. Any MCP-compliant server slots in alongside Bolt's
          built-in integrations — including custom-built connectors for your internal systems.
          Sparcle ships connector SDKs in TypeScript and Python; the protocol itself is language-agnostic.
        </p>
        <p class="ints-lede ints-lede--narrow">
          For enterprise contracts, we offer <strong>custom MCP connector development</strong> as a
          professional service — typically 1–3 weeks per system depending on auth complexity and the
          surface area you need exposed.
        </p>
      </div>
    </section>

    <!-- CTA -->
    <section class="ints-cta-section">
      <div class="container">
        <div class="ints-cta-box">
          <h2>Ready to connect your stack?</h2>
          <p>
            Schedule a 30-minute walkthrough — we'll cover which integrations are most relevant for
            your environment and what custom development (if any) you'd want during pilot.
          </p>
          <div class="ints-ctas">
            <a href="#" onclick="openContactModal('Architecture Review'); return false;" class="btn btn-primary btn-lg">
              Schedule Architecture Review
            </a>
            <a href="/architecture" class="btn btn-secondary btn-lg">
              How Bolt is built &rarr;
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style is:global>
  .page-integrations {
    color: var(--text-body);
  }
  .ints-hero {
    padding: calc(var(--nav-height, 80px) + 3rem) 0 var(--space-section);
    text-align: center;
  }
  .ints-hero h1 {
    margin: 0 auto 1.25rem;
    max-width: 820px;
  }
  .ints-lede {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--text-body);
    max-width: 760px;
    margin: 0 auto 2rem;
  }
  .ints-lede--narrow {
    max-width: 640px;
  }
  .ints-lede a {
    color: var(--brand-primary);
  }
  .ints-lede a:hover {
    text-decoration: underline;
  }
  .ints-ctas {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .anchor {
    display: block;
    height: 1px;
    margin-top: -1px;
    visibility: hidden;
  }

  .ints-category {
    padding: var(--space-block) 0;
    border-top: 1px solid var(--border-subtle);
  }
  .ints-cat-header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    max-width: 980px;
    margin: 0 auto 1.5rem;
  }
  .ints-cat-icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: var(--brand-primary-light);
    color: var(--brand-primary);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ints-cat-header h2 {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--text-heading);
    margin: 0 0 0.4rem;
  }
  .ints-cat-header p {
    font-size: 0.92rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.5;
  }
  .ints-grid {
    list-style: none;
    padding: 0;
    margin: 0 auto;
    max-width: 980px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
  }
  .int-card {
    flex: 1 1 220px;
    background: var(--bg-surface-solid);
    border: 1px solid var(--border-default);
    border-radius: 10px;
    padding: 0.75rem 0.95rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .int-name {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--text-heading);
  }
  .int-note {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .ints-section {
    padding: var(--space-section) 0;
    border-top: 1px solid var(--border-subtle);
    text-align: center;
  }
  .ints-section-alt {
    background: var(--bg-muted);
  }
  .ints-section h2 {
    text-align: center;
    margin: 0 auto 1.5rem;
    max-width: 760px;
  }
  .ints-section .ints-lede {
    margin-left: auto;
    margin-right: auto;
    text-align: left;
  }

  .ints-cta-section {
    padding: var(--space-section) 0;
  }
  .ints-cta-box {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
    padding: 2.5rem 2rem;
    background: var(--bg-surface-solid);
    border: 1px solid var(--border-default);
    border-radius: 18px;
  }
  .ints-cta-box h2 {
    margin: 0 0 1rem;
  }
  .ints-cta-box p {
    color: var(--text-body);
    line-height: 1.6;
    margin: 0 auto 1.5rem;
    max-width: 560px;
  }

  @media (max-width: 600px) {
    .ints-cat-header {
      flex-direction: column;
      gap: 0.75rem;
    }
  }
</style>
